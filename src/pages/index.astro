<script>
  document.body.classList.add('os-desktop');

  // Speed up project detail videos (2x playback)
  document.querySelectorAll('.proj-detail video, .proj-mockup-viewer video').forEach(v => {
    (v as HTMLVideoElement).playbackRate = 2;
  });

  // Lock screen dismiss
  const lockScreen = document.getElementById('lockScreen');
  const lockButton = document.getElementById('lockButton');

  if (lockScreen && !document.documentElement.classList.contains('skip-lock')) {
    const dismiss = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      lockScreen.classList.add('dismissing');
      sessionStorage.setItem('lyla-visited', 'true');

      setTimeout(() => {
        lockScreen.style.display = 'none';
      }, 450);

      if (lockButton) lockButton.removeEventListener('click', dismiss);
      document.removeEventListener('keydown', dismissKey);
    };

    const dismissKey = (e: Event) => dismiss(e);

    if (lockButton) lockButton.addEventListener('click', dismiss);
    document.addEventListener('keydown', dismissKey);
  }

  // Mini player
  const plTracks = [
    { title: 'Tití Me Preguntó', artist: 'Bad Bunny', duration: '5:21', secs: 321 },
    { title: 'TURiSTA', artist: 'Bad Bunny', duration: '3:45', secs: 225 },
    { title: 'NUEVAYoL', artist: 'Bad Bunny', duration: '3:30', secs: 210 },
    { title: 'DtMF', artist: 'Bad Bunny', duration: '3:15', secs: 195 },
  ];
  let plIdx = 0;
  let plPlaying = true;
  let plProgress = 0;
  const plTitle = document.getElementById('playerTitle');
  const plArtist = document.getElementById('playerArtist');
  const plDuration = document.getElementById('playerDuration');
  const plElapsed = document.getElementById('playerElapsed');
  const plFill = document.getElementById('playerFill');
  const plNext = document.getElementById('playerNextTrack');
  const plPlayBtn = document.getElementById('playerPlay');
  const plPrevBtn = document.getElementById('playerPrev');
  const plNextBtn = document.getElementById('playerNext');

  const plPlayIcon = document.getElementById('playerPlayIcon');

  function plUpdate() {
    const t = plTracks[plIdx];
    const nx = plTracks[(plIdx + 1) % plTracks.length];
    if (plTitle) plTitle.textContent = t.title;
    if (plArtist) plArtist.textContent = t.artist;
    if (plDuration) plDuration.textContent = '-' + t.duration;
    if (plNext) plNext.textContent = nx.title + ' \u2014 ' + nx.artist;
    plProgress = 0;
  }

  function plFormatTime(s: number) {
    return Math.floor(s / 60) + ':' + String(Math.floor(s % 60)).padStart(2, '0');
  }

  setInterval(() => {
    if (!plPlaying) return;
    const t = plTracks[plIdx];
    plProgress += 0.5;
    const pct = Math.min((plProgress / 30) * 100, 100);
    if (plFill) plFill.style.width = pct + '%';
    const fakeElapsed = Math.floor((pct / 100) * t.secs);
    if (plElapsed) plElapsed.textContent = plFormatTime(fakeElapsed);
    const remaining = t.secs - fakeElapsed;
    if (plDuration) plDuration.textContent = '-' + plFormatTime(remaining);
    if (pct >= 100) {
      plIdx = (plIdx + 1) % plTracks.length;
      plUpdate();
    }
  }, 500);

  if (plPlayBtn) {
    plPlayBtn.addEventListener('click', () => {
      plPlaying = !plPlaying;
      if (plPlayIcon) {
        plPlayIcon.className = plPlaying ? 'px-pause' : 'px-play';
      }
    });
    // Start as playing
    if (plPlayIcon) plPlayIcon.className = 'px-pause';
  }
  if (plNextBtn) {
    plNextBtn.addEventListener('click', () => {
      plIdx = (plIdx + 1) % plTracks.length;
      plUpdate();
    });
  }
  if (plPrevBtn) {
    plPrevBtn.addEventListener('click', () => {
      plIdx = (plIdx - 1 + plTracks.length) % plTracks.length;
      plUpdate();
    });
  }

  // Photos app — tap to view detail
  const photoCaptions = [
    'the setup — Barcelona, 2026',
    'new home — skyline view',
    'employee of the month',
    '3am debugging',
    'fuel',
    'beach day',
    'the first prototype',
    'golden hour',
    'close enough :)',
  ];

  document.querySelectorAll('[data-photo]').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt((btn as HTMLElement).dataset.photo || '0');
      const detail = document.getElementById('photosDetail');
      const gridView = document.getElementById('photosGridView');
      const detailImg = document.getElementById('photosDetailImg');
      const detailCaption = document.getElementById('photosDetailCaption');
      if (!detail || !gridView || !detailImg || !detailCaption) return;

      // Copy the thumbnail — keep original size, scale up with transform
      detailImg.innerHTML = '';
      const clone = (btn as HTMLElement).cloneNode(true) as HTMLElement;
      const btnRect = (btn as HTMLElement).getBoundingClientRect();
      clone.style.width = btnRect.width + 'px';
      clone.style.height = btnRect.height + 'px';
      clone.style.borderRadius = '8px';
      clone.style.position = 'relative';
      clone.style.flexShrink = '0';
      clone.style.transform = 'scale(3)';
      clone.style.transformOrigin = 'center center';
      detailImg.appendChild(clone);
      detailCaption.textContent = photoCaptions[idx] || '';
      gridView.style.display = 'none';
      detail.style.display = 'flex';
    });
  });

  const photosCloseBtn = document.getElementById('photosDetailClose');
  if (photosCloseBtn) {
    photosCloseBtn.addEventListener('click', () => {
      const detail = document.getElementById('photosDetail');
      const gridView = document.getElementById('photosGridView');
      if (detail) detail.style.display = 'none';
      if (gridView) gridView.style.display = '';
    });
  }

  // Gallery popup — tap screenshot to open full-screen
  document.querySelectorAll('[data-gallery-open]').forEach(item => {
    item.addEventListener('click', () => {
      const media = item.querySelector('img, video') as HTMLElement;
      if (!media) return;
      const popup = document.createElement('div');
      popup.className = 'gallery-popup';
      const clone = media.cloneNode(true) as HTMLElement;
      if (clone.tagName === 'VIDEO') {
        (clone as HTMLVideoElement).controls = true;
        (clone as HTMLVideoElement).autoplay = true;
        (clone as HTMLVideoElement).muted = false;
      }
      const closeBtn = document.createElement('button');
      closeBtn.className = 'gallery-popup-close';
      closeBtn.textContent = '\u00d7';
      closeBtn.addEventListener('click', () => popup.remove());
      popup.addEventListener('click', (e) => { if (e.target === popup) popup.remove(); });
      popup.appendChild(clone);
      popup.appendChild(closeBtn);
      document.body.appendChild(popup);
    });
  });

  // RPG stat bar animation — fill from 0 when about panel opens
  const aboutPanel = document.querySelector('[data-panel-id="about"]');
  if (aboutPanel) {
    const observer = new MutationObserver(() => {
      if (aboutPanel.classList.contains('open')) {
        aboutPanel.querySelectorAll('[data-rpg-width]').forEach(bar => {
          const el = bar as HTMLElement;
          el.style.width = '0%';
          setTimeout(() => { el.style.width = el.dataset.rpgWidth || '0%'; }, 300);
        });
      }
    });
    observer.observe(aboutPanel, { attributes: true, attributeFilter: ['class'] });
  }

  // Lazy-load videos — only set src when parent window/panel opens
  document.querySelectorAll('.os-window, .mobile-panel').forEach(container => {
    const lazyVideos = container.querySelectorAll('video[data-lazy-src]');
    if (!lazyVideos.length) return;
    let loaded = false;
    const obs = new MutationObserver(() => {
      if (loaded || !container.classList.contains('open')) return;
      loaded = true;
      lazyVideos.forEach(v => {
        const video = v as HTMLVideoElement;
        const src = video.dataset.lazySrc;
        if (src && !video.src) {
          video.src = src;
          if (video.hasAttribute('autoplay')) video.play().catch(() => {});
        }
      });
    });
    obs.observe(container, { attributes: true, attributeFilter: ['class'] });
  });
</script>

<script>
  // ===== DUCK RUNNER GAME — SOUNDS =====
  const duckSfx = {
    _ctx: null as AudioContext | null,
    _getCtx() {
      if (!this._ctx || this._ctx.state === 'closed') {
        this._ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      }
      if (this._ctx.state === 'suspended') this._ctx.resume();
      return this._ctx;
    },

    // Short chirpy jump sound
    jump() {
      try {
        const ctx = this._getCtx();
        const t = ctx.currentTime;
        const osc = ctx.createOscillator();
        osc.type = 'square';
        osc.frequency.setValueAtTime(500, t);
        osc.frequency.exponentialRampToValueAtTime(900, t + 0.08);
        const gain = ctx.createGain();
        gain.gain.setValueAtTime(0.15, t);
        gain.gain.exponentialRampToValueAtTime(0.01, t + 0.1);
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.start(t);
        osc.stop(t + 0.1);
      } catch (e) {}
    },

    // Quick blip when passing an obstacle
    score() {
      try {
        const ctx = this._getCtx();
        const t = ctx.currentTime;
        const osc = ctx.createOscillator();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(880, t);
        osc.frequency.setValueAtTime(1100, t + 0.03);
        const gain = ctx.createGain();
        gain.gain.setValueAtTime(0.1, t);
        gain.gain.exponentialRampToValueAtTime(0.01, t + 0.08);
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.start(t);
        osc.stop(t + 0.08);
      } catch (e) {}
    },

    // Sad quack on death — lower pitch, longer
    death() {
      try {
        const ctx = this._getCtx();
        const t = ctx.currentTime;
        // Noise burst
        const bufSize = ctx.sampleRate * 0.3;
        const noiseBuf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
        const data = noiseBuf.getChannelData(0);
        for (let i = 0; i < bufSize; i++) data[i] = Math.random() * 2 - 1;
        const noise = ctx.createBufferSource();
        noise.buffer = noiseBuf;
        const bp = ctx.createBiquadFilter();
        bp.type = 'bandpass';
        bp.frequency.setValueAtTime(800, t);
        bp.frequency.exponentialRampToValueAtTime(300, t + 0.25);
        bp.Q.value = 4;
        // Low tone
        const osc = ctx.createOscillator();
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(500, t);
        osc.frequency.exponentialRampToValueAtTime(200, t + 0.25);
        // Envelope
        const gain = ctx.createGain();
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(0.25, t + 0.02);
        gain.gain.setValueAtTime(0.25, t + 0.08);
        gain.gain.exponentialRampToValueAtTime(0.01, t + 0.3);
        noise.connect(bp);
        bp.connect(gain);
        osc.connect(gain);
        gain.connect(ctx.destination);
        noise.start(t);
        osc.start(t);
        noise.stop(t + 0.3);
        osc.stop(t + 0.3);
      } catch (e) {}
    },

    // Soft thud when duck lands
    land() {
      try {
        const ctx = this._getCtx();
        const t = ctx.currentTime;
        const osc = ctx.createOscillator();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(150, t);
        osc.frequency.exponentialRampToValueAtTime(60, t + 0.08);
        const gain = ctx.createGain();
        gain.gain.setValueAtTime(0.12, t);
        gain.gain.exponentialRampToValueAtTime(0.01, t + 0.1);
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.start(t);
        osc.stop(t + 0.1);
      } catch (e) {}
    },
  };

  // ===== DUCK RUNNER GAME =====
  function initDuckGame(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = false;

    let W = 320, H = 240, scale = 1;
    function resize() {
      const rect = canvas.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      W = rect.width * dpr;
      H = rect.height * dpr;
      canvas.width = W;
      canvas.height = H;
      const isMobile = window.innerWidth <= 768;
      scale = Math.max(1, Math.floor(Math.min(W, H) / (isMobile ? 90 : 130)));
      ctx.imageSmoothingEnabled = false;
      groundY = H * 0.75;
    }

    // Game state
    let state: 'playing' | 'dead' = 'playing';
    let groundY = 0;
    let score = 0;
    let best = parseInt(sessionStorage.getItem('duckBest') || '0');
    let speed = 3;
    let frameCount = 0;
    let duckRunFrame = 0;

    // Duck
    const duck = { x: 0, y: 0, w: 0, h: 0, vy: 0, jumping: false };

    // Obstacles
    type Obstacle = { x: number; y: number; w: number; h: number; type: string; passed: boolean };
    let obstacles: Obstacle[] = [];
    let spawnTimer = 0;

    // Clouds
    type Cloud = { x: number; y: number; w: number; h: number };
    let clouds: Cloud[] = [];

    function reset() {
      score = 0;
      speed = 3;
      frameCount = 0;
      obstacles = [];
      spawnTimer = 0;
      duck.vy = 0;
      duck.jumping = false;
      clouds = [];
      for (let i = 0; i < 4; i++) {
        clouds.push({
          x: Math.random() * W,
          y: H * 0.05 + Math.random() * H * 0.25,
          w: (20 + Math.random() * 30) * scale,
          h: (6 + Math.random() * 6) * scale,
        });
      }
    }

    function px(n: number) { return n * scale; }

    // Duck sprite — drawn as colored rectangles
    function drawDuck(x: number, y: number, dead: boolean) {
      const s = scale;
      const p = (dx: number, dy: number, w: number, h: number, c: string) => {
        ctx.fillStyle = c;
        ctx.fillRect(x + dx * s, y + dy * s, w * s, h * s);
      };
      // Body
      p(0, 4, 8, 5, '#FFE066');
      // Head
      p(2, 0, 4, 4, '#FFE066');
      // Eye
      if (dead) {
        // X eyes
        p(3, 1, 1, 1, '#222');
        p(4, 2, 1, 1, '#222');
        p(4, 1, 1, 1, '#222');
        p(3, 2, 1, 1, '#222');
      } else {
        p(4, 2, 1, 1, '#222');
      }
      // Beak
      p(6, 2, 2, 1, '#FF6B00');
      // Feet — animate
      if (dead) {
        // Feet up (rolled over)
        p(2, 9, 2, 1, '#FF6B00');
        p(5, 9, 2, 1, '#FF6B00');
      } else if (duck.jumping) {
        p(2, 9, 2, 1, '#FF6B00');
        p(5, 9, 2, 1, '#FF6B00');
      } else if (duckRunFrame === 0) {
        p(2, 9, 1, 1, '#FF6B00');
        p(6, 9, 1, 1, '#FF6B00');
      } else {
        p(3, 9, 2, 1, '#FF6B00');
      }
      duck.w = 8 * s;
      duck.h = 10 * s;
    }

    function spawnObstacle() {
      const types = ['rock', 'rock_lg', 'mushroom', 'log', 'flower', 'puddle'];
      const type = types[Math.floor(Math.random() * types.length)];
      let w: number, h: number;
      switch (type) {
        case 'rock':      w = px(4); h = px(4); break;
        case 'rock_lg':   w = px(6); h = px(5); break;
        case 'mushroom':  w = px(4); h = px(5); break;
        case 'log':       w = px(8); h = px(3); break;
        case 'flower':    w = px(3); h = px(7); break;
        case 'puddle':    w = px(10); h = px(2); break;
        default:          w = px(4); h = px(4);
      }
      obstacles.push({
        x: W + 10,
        y: groundY - h,
        w, h, type,
        passed: false,
      });
    }

    function drawObstacle(o: Obstacle) {
      const s = scale;
      switch (o.type) {
        case 'rock':
        case 'rock_lg':
          ctx.fillStyle = '#888';
          ctx.fillRect(o.x, o.y, o.w, o.h);
          ctx.fillStyle = '#aaa';
          ctx.fillRect(o.x + s, o.y + s, o.w - 2 * s, s);
          break;
        case 'mushroom':
          // Stem
          ctx.fillStyle = '#E8D8C0';
          ctx.fillRect(o.x + s, o.y + px(2), px(2), px(3));
          // Cap
          ctx.fillStyle = '#CC2222';
          ctx.fillRect(o.x, o.y, o.w, px(3));
          // Dots
          ctx.fillStyle = '#FFF';
          ctx.fillRect(o.x + s, o.y + s, s, s);
          ctx.fillRect(o.x + px(3) - s, o.y + s, s, s);
          break;
        case 'log':
          ctx.fillStyle = '#8B5A2B';
          ctx.fillRect(o.x, o.y, o.w, o.h);
          ctx.fillStyle = '#A0703C';
          ctx.fillRect(o.x, o.y, o.w, s);
          // Rings
          ctx.fillStyle = '#6B4226';
          ctx.fillRect(o.x + px(2), o.y + s, s, s);
          ctx.fillRect(o.x + px(5), o.y + s, s, s);
          break;
        case 'flower':
          // Stem
          ctx.fillStyle = '#4A8F4A';
          ctx.fillRect(o.x + s, o.y + px(3), s, px(4));
          // Petals
          ctx.fillStyle = '#FFD700';
          ctx.fillRect(o.x, o.y, o.w, px(3));
          ctx.fillStyle = '#FF6B00';
          ctx.fillRect(o.x + s, o.y + s, s, s);
          break;
        case 'puddle':
          ctx.fillStyle = '#5BA8D4';
          ctx.fillRect(o.x, o.y, o.w, o.h);
          ctx.fillStyle = '#7CC4E8';
          ctx.fillRect(o.x + s, o.y, o.w - 2 * s, s);
          break;
      }
    }

    function jump() {
      if (state === 'dead') {
        state = 'playing';
        reset();
        duck.x = W * 0.15;
        duck.y = groundY - px(10);
        return;
      }
      if (!duck.jumping) {
        duck.vy = -px(2.4);
        duck.jumping = true;
        duckSfx.jump();
      }
    }

    function update() {
      if (state !== 'playing') return;
      frameCount++;

      // Duck physics
      const wasAirborne = duck.jumping;
      duck.vy += px(0.18);
      duck.y += duck.vy;
      if (duck.y >= groundY - px(10)) {
        duck.y = groundY - px(10);
        duck.vy = 0;
        duck.jumping = false;
        if (wasAirborne) duckSfx.land();
      }

      // Run animation
      if (frameCount % 8 === 0) duckRunFrame = duckRunFrame === 0 ? 1 : 0;

      // Speed increase
      speed = 3 + Math.floor(score / 10) * 0.5;
      const spd = px(speed * 0.3);

      // Spawn first obstacle right after duck lands (~1.5s), then regular intervals
      if (frameCount < 45) { spawnTimer = 0; }
      if (frameCount === 45) {
        // Spawn first obstacle closer so it arrives within ~2-3s
        spawnObstacle();
        obstacles[obstacles.length - 1].x = W * 0.7;
      }
      spawnTimer++;
      const baseInterval = Math.max(30, 80 - score * 2);
      const spawnInterval = baseInterval + Math.floor(Math.random() * 40) - 10;
      if (spawnTimer >= spawnInterval) {
        spawnTimer = 0;
        spawnObstacle();
      }

      // Move obstacles
      for (let i = obstacles.length - 1; i >= 0; i--) {
        const o = obstacles[i];
        o.x -= spd;
        // Score
        if (!o.passed && o.x + o.w < duck.x) {
          o.passed = true;
          score++;
          duckSfx.score();
          if (score > best) {
            best = score;
            sessionStorage.setItem('duckBest', String(best));
          }
        }
        // Remove off-screen
        if (o.x + o.w < -20) {
          obstacles.splice(i, 1);
        }
      }

      // Move clouds
      for (const c of clouds) {
        c.x -= spd * 0.15;
        if (c.x + c.w < 0) {
          c.x = W + Math.random() * 100;
          c.y = H * 0.05 + Math.random() * H * 0.25;
        }
      }

      // Collision
      const dBox = { x: duck.x + px(1), y: duck.y + px(1), w: duck.w - px(2), h: duck.h - px(2) };
      for (const o of obstacles) {
        const oBox = { x: o.x + px(0.5), y: o.y + px(0.5), w: o.w - px(1), h: o.h - px(1) };
        if (dBox.x < oBox.x + oBox.w && dBox.x + dBox.w > oBox.x &&
            dBox.y < oBox.y + oBox.h && dBox.y + dBox.h > oBox.y) {
          state = 'dead';
          duckSfx.death();
          return;
        }
      }
    }

    function draw() {
      // Sky
      ctx.fillStyle = '#87CEEB';
      ctx.fillRect(0, 0, W, H);

      // Clouds
      ctx.fillStyle = 'rgba(255,255,255,0.7)';
      for (const c of clouds) {
        ctx.fillRect(c.x, c.y, c.w, c.h);
        ctx.fillRect(c.x + c.w * 0.2, c.y - c.h * 0.5, c.w * 0.6, c.h * 0.6);
      }

      // Ground
      ctx.fillStyle = '#5CA05C';
      ctx.fillRect(0, groundY, W, H - groundY);
      ctx.fillStyle = '#4A8F4A';
      ctx.fillRect(0, groundY, W, px(2));

      // Ground detail — little grass tufts
      ctx.fillStyle = '#6BB86B';
      for (let i = 0; i < W; i += px(8)) {
        ctx.fillRect(i, groundY - px(1), px(1), px(1));
      }

      // Obstacles
      for (const o of obstacles) drawObstacle(o);

      // Duck
      {
        if (state === 'dead') {
          ctx.save();
          ctx.translate(duck.x + duck.w / 2, duck.y + duck.h / 2);
          ctx.rotate(Math.PI / 2);
          drawDuck(-duck.w / 2, -duck.h / 2, true);
          ctx.restore();
        } else {
          drawDuck(duck.x, duck.y, false);
        }
      }

      // Score
      if (state === 'playing' || state === 'dead') {
        ctx.fillStyle = '#222';
        ctx.font = `bold ${px(3)}px "IBM Plex Mono", monospace`;
        ctx.textAlign = 'right';
        ctx.fillText(String(score), W - px(3), px(5));
        ctx.font = `${px(2)}px "IBM Plex Mono", monospace`;
        ctx.fillStyle = '#666';
        ctx.fillText(`BEST: ${best}`, W - px(3), px(8));
      }

      // Game over
      if (state === 'dead') {
        ctx.fillStyle = 'rgba(0,0,0,0.5)';
        ctx.fillRect(0, 0, W, H);

        ctx.fillStyle = '#FF6B00';
        ctx.font = `bold ${px(8)}px "Space Grotesk", sans-serif`;
        ctx.textAlign = 'center';
        ctx.fillText('QUACK!', W / 2, H * 0.35);

        ctx.fillStyle = '#FFF';
        ctx.font = `bold ${px(5)}px "IBM Plex Mono", monospace`;
        ctx.fillText(`SCORE: ${score}`, W / 2, H * 0.5);

        ctx.font = `${px(3.5)}px "IBM Plex Mono", monospace`;
        ctx.fillStyle = '#ccc';
        ctx.fillText(`BEST: ${best}`, W / 2, H * 0.58);

        ctx.font = `${px(3)}px "IBM Plex Mono", monospace`;
        ctx.fillStyle = '#999';
        ctx.fillText('tap to retry', W / 2, H * 0.7);
      }
    }

    function gameLoop() {
      update();
      draw();
      requestAnimationFrame(gameLoop);
    }

    // Controls
    canvas.addEventListener('click', (e) => { e.preventDefault(); jump(); });
    canvas.addEventListener('touchstart', (e) => { e.preventDefault(); jump(); }, { passive: false });
    document.addEventListener('keydown', (e) => {
      if (e.code === 'Space' || e.key === ' ') {
        // Only handle space if this canvas is visible
        if (canvas.offsetParent !== null) {
          e.preventDefault();
          jump();
        }
      }
    });

    // Observe resize
    const ro = new ResizeObserver(() => resize());
    ro.observe(canvas);

    let loopStarted = false;

    function startGame() {
      resize();
      state = 'playing';
      reset();
      duck.x = W * 0.15;
      duck.y = 0;
      duck.vy = 0;
      duck.jumping = true;
      if (!loopStarted) {
        loopStarted = true;
        gameLoop();
      }
    }

    // Watch for container becoming visible (panel.open or window.open)
    const container = canvas.closest('.mobile-panel, .os-window');
    if (container) {
      const obs = new MutationObserver(() => {
        if (container.classList.contains('open')) {
          startGame();
        }
      });
      obs.observe(container, { attributes: true, attributeFilter: ['class'] });
    }
  }

  // Initialize both canvases when they exist
  const mobileCanvas = document.getElementById('duckGameMobile') as HTMLCanvasElement;
  const desktopCanvas = document.getElementById('duckGameDesktop') as HTMLCanvasElement;
  if (mobileCanvas) initDuckGame(mobileCanvas);
  if (desktopCanvas) initDuckGame(desktopCanvas);
</script>

