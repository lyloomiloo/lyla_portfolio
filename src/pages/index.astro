        { label: 'GO MODE', caption: 'GO — destination routing' },
        { label: 'EXPLORE MODE', caption: 'EXPLORE — vibe-based discovery' },
        { label: 'WANDER MODE', caption: 'WANDER — compass + curated pins' },
