  <!-- Spotify-style playlist -->
  <MobilePanel id="playlist" title="" fullscreen>
    <div class="spotify-app">
      <div class="spotify-header">
        <div class="spotify-cover">///</div>
        <div class="spotify-info">
          <div class="spotify-playlist-label">PLAYLIST</div>
