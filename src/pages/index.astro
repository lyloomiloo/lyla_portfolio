---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import AboutSection from '../components/AboutSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import Contact from '../components/Contact.astro';
import RetroElements from '../components/RetroElements.astro';
import RetroWindow from '../components/RetroWindow.astro';
import GlitchText from '../components/GlitchText.astro';
---
<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <RetroElements type="marquee" />
    <RetroElements type="pixel-robot-strip" />

    <section id="projects">
      <div class="section-label reveal"><GlitchText text="Projects" tag="span" intensity="subtle" interval={6000} /></div>
      <RetroWindow title="projects.exe">
        <ProjectGrid />
      </RetroWindow>
    </section>

    <section id="about" class="about-section">
      <AboutSection />
    </section>

    <RetroElements type="rec-loader" />

    <section id="skills">
      <div class="section-label reveal"><GlitchText text="Capabilities" tag="span" intensity="subtle" interval={8000} /></div>
      <RetroWindow title="capabilities.dll">
        <SkillsSection />
      </RetroWindow>
    </section>

    <RetroElements type="pixel-creature-strip" />
    <RetroElements type="kaomoji-strip" />

    <section id="contact" style="padding-bottom: 5rem;">
      <div class="section-label reveal">Contact</div>
      <RetroWindow title="contact.txt" draggable={true}>
        <div style="padding: 1.5rem;">
          <Contact />
        </div>
      </RetroWindow>
      <div style="margin-top: 2rem;">
        <RetroElements type="loading-text" />
      </div>
    </section>
  </main>

  <!-- Floating decorative windows -->
  <div class="floating-windows">
    <div class="float-win float-1">
      <div class="float-bar"><span class="float-dots">● ● ●</span> <span>secrets.txt</span></div>
    </div>
    <div class="float-win float-2">
      <div class="float-bar"><span class="float-dots">● ● ●</span> <span>todo.md</span></div>
    </div>
    <div class="float-win float-3">
      <div class="float-bar"><span class="float-dots">● ● ●</span> <span>not_a_virus.exe</span></div>
    </div>
  </div>

  <!-- Taskbar -->
  <nav class="taskbar" data-taskbar>
    <span class="taskbar-start">▸</span>
    <a href="#hero" class="taskbar-item" data-section="hero">home.exe</a>
    <a href="#projects" class="taskbar-item" data-section="projects">projects.exe</a>
    <a href="#about" class="taskbar-item" data-section="about">about.exe</a>
    <a href="#skills" class="taskbar-item" data-section="skills">capabilities.dll</a>
    <a href="#contact" class="taskbar-item" data-section="contact">contact.txt</a>
    <span class="taskbar-clock" data-taskbar-clock></span>
  </nav>
</BaseLayout>

<script>
  // Taskbar active section highlight
  const sections = document.querySelectorAll('section[id]');
  const taskbarItems = document.querySelectorAll('.taskbar-item');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        taskbarItems.forEach(item => {
          item.classList.toggle('active', item.getAttribute('data-section') === id);
        });
      }
    });
  }, { threshold: 0.3 });

  sections.forEach(s => observer.observe(s));

  // Taskbar clock
  const clock = document.querySelector('[data-taskbar-clock]');
  function updateClock() {
    if (!clock) return;
    const now = new Date();
    clock.textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 30000);
</script>

<style>
  .about-section {
    padding: 0 !important;
  }

  /* Floating decorative windows */
  .floating-windows {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .float-win {
    position: absolute;
    width: 140px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    box-shadow: 3px 3px 0 rgba(0,0,0,0.05);
    opacity: 0.15;
  }

  .float-bar {
    padding: 4px 8px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    display: flex;
    gap: 6px;
  }

  .float-dots {
    font-size: 0.45rem;
    color: var(--orange);
  }

  .float-1 {
    top: 15%;
    right: 5%;
    transform: rotate(3deg);
    height: 80px;
  }

  .float-2 {
    top: 55%;
    left: 3%;
    transform: rotate(-2deg);
    height: 60px;
  }

  .float-3 {
    top: 78%;
    right: 8%;
    transform: rotate(1.5deg);
    height: 70px;
  }

  /* Taskbar */
  .taskbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--dark);
    border-top: 1px solid #444;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    height: 32px;
    gap: 0;
  }

  .taskbar-start {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--green);
    padding: 0 12px 0 4px;
    border-right: 1px solid #444;
    margin-right: 4px;
  }

  .taskbar-item {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #888;
    padding: 4px 10px;
    text-decoration: none;
    border-right: 1px solid #333;
    transition: background 0.15s, color 0.15s;
  }

  .taskbar-item:hover {
    background: #333;
    color: #ccc;
  }

  .taskbar-item.active {
    background: #444;
    color: var(--green);
  }

  .taskbar-clock {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #888;
    padding: 0 8px;
  }

  @media (max-width: 768px) {
    .floating-windows {
      display: none;
    }

    .taskbar-item {
      font-size: 0.65rem;
      padding: 4px 6px;
    }

    .taskbar-clock {
      display: none;
    }
  }
</style>
