    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--border);
    color: var(--text-dim);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .messages-contact {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }
  .messages-status {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: #00CC55;
  }
  .messages-thread {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    -webkit-overflow-scrolling: touch;
  }
  .msg {
    max-width: 75%;
    padding: 10px 14px;
    border-radius: 16px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .msg-them {
    align-self: flex-start;
    background: #e5e5ea;
    color: #000;
    border-bottom-left-radius: 4px;
  }
  .msg-me {
    align-self: flex-end;
    background: #FF6B00;
    color: #FFF;
    border-bottom-right-radius: 4px;
  }
  .msg-time {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: inherit;
    opacity: 0.5;
    display: block;
    margin-top: 4px;
  }
  .msg-typing {
    align-self: flex-start;
    background: #e5e5ea;
    padding: 10px 16px;
    border-radius: 16px;
    display: flex;
    gap: 4px;
  }
  .typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #999;
    animation: typing-bounce 1.2s ease-in-out infinite;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* ========== Weather App ========== */
  .weather-app {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .weather-scene {
    width: 100%;
    height: 200px;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .weather-sunny {
    background: linear-gradient(to bottom, #87CEEB 0%, #b8e6ff 100%);
  }
  .weather-sunny::before {
    content: '';
    position: absolute;
    top: 30px;
    right: 40px;
    width: 50px;
    height: 50px;
    background: #FFE600;
    border-radius: 50%;
    box-shadow: 0 0 20px #FFE600;
  }
  .weather-sunny::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to bottom, #6db36d, #4a9e4a);
  }
  .weather-cloudy {
    background: linear-gradient(to bottom, #b0b8c0 0%, #d0d4d8 100%);
  }
  .weather-cloudy::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to bottom, #5a8a5a, #4a7a4a);
  }
  .weather-rainy {
    background: linear-gradient(to bottom, #6a7a8a 0%, #8a9aaa 100%);
  }
  .weather-rainy::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to bottom, #4a6a4a, #3a5a3a);
  }
  .weather-temp {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1;
  }
  .weather-desc {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-dim);
    margin: 0.3rem 0;
  }
  .weather-location {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .weather-details {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  /* ========== App Store — Project detail ========== */
  .appstore {
    margin: -1.5rem;
  }
  .appstore-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 1rem;
  }
  .appstore-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    border: 1px solid var(--border);
    flex-shrink: 0;
    background: #fff;
    object-fit: contain;
  }
  .appstore-head-text { flex: 1; }
  .appstore-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }
  .appstore-sub {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
  }
  .appstore-get {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    background: var(--orange);
    padding: 6px 18px;
    border-radius: 14px;
    text-decoration: none;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }
  /* Stats strip — like App Store ratings/age/chart row */
  .appstore-stats-strip {
    display: flex;
    align-items: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 8px 0;
    margin: 0 1rem;
  }
  .appstore-stat {
    flex: 1;
    text-align: center;
  }
  .appstore-stat-val {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }
  .appstore-stat-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--text-dim);
  }
  .appstore-stat-divider {
    width: 1px;
    height: 28px;
    background: var(--border);
    flex-shrink: 0;
  }
  /* Screenshots */
  .appstore-screenshots {
    padding: 1rem;
    overflow-x: auto;
    display: flex;
    gap: 10px;
    -webkit-overflow-scrolling: touch;
  }
  .appstore-screenshot {
    flex-shrink: 0;
    height: 240px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #111;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .appstore-screenshot img,
  .appstore-screenshot video {
    height: 100%;
    display: block;
  }
  .appstore-screenshot:has(video)::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    background: rgba(0,0,0,0.5);
    border-radius: 50%;
    border: 2px solid #fff;
  }
  .appstore-screenshot:has(video)::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-45%, -50%);
    z-index: 1;
    border-style: solid;
    border-width: 6px 0 6px 10px;
    border-color: transparent transparent transparent #fff;
  }
  .appstore-screenshot { position: relative; }

  /* Gallery popup overlay */
  .gallery-popup {
    position: fixed;
    inset: 0;
    z-index: 10001;
    background: rgba(0,0,0,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .gallery-popup img,
  .gallery-popup video {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
  }
  .gallery-popup-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.2);
    border: none;
    border-radius: 50%;
    color: #fff;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .appstore-desc {
    padding: 0 1rem 1rem;
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text);
  }
  .appstore-section {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
    margin: 1rem 1rem 0.8rem;
    color: var(--text);
  }
  .appstore-features { padding: 0 1rem; }
  .appstore-feat {
    display: flex;
    gap: 8px;
    margin-bottom: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--text-mid);
  }
  .appstore-dot {
    color: var(--orange);
    flex-shrink: 0;
    font-weight: 700;
  }
  .appstore-concept {
    padding: 0 1rem;
    margin-bottom: 1rem;
  }
  .appstore-concept-label {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: 0.2rem;
  }
  .appstore-concept-desc {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--text-mid);
    line-height: 1.4;
  }
  .appstore-info { padding: 0 1rem 1rem; }
  .appstore-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .appstore-row.last { border-bottom: none; }
  .appstore-key { color: var(--text-dim); }

  /* ========== RPG Character Sheet — About ========== */
  .rpg-sheet {
    margin: -1.5rem;
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  /* Character card — side by side */
  .rpg-card {
    display: flex;
    gap: 12px;
    border: 1px solid var(--border);
    padding: 10px;
  }
  .rpg-card-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .rpg-avatar {
    width: 56px;
    height: 56px;
    background: #333;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .rpg-lvl-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    background: var(--orange);
    padding: 1px 6px;
  }
  .rpg-card-right { flex: 1; }
  .rpg-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
  }
  .rpg-class {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .rpg-title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--orange);
    vertical-align: middle;
  }
  /* Bordered box sections */
  .rpg-box {
    border: 1px solid var(--border);
    padding: 8px 10px;
  }
  .rpg-box-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
    letter-spacing: 0.06em;
  }
  /* Stat rows */
  .rpg-stat {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 5px;
  }
  .rpg-stat:last-child { margin-bottom: 0; }
  .rpg-stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--orange);
    min-width: 28px;
  }
  .rpg-stat-name {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text);
    min-width: 80px;
  }
  .rpg-bar {
    flex: 1;
    height: 10px;
    background: var(--border);
    overflow: hidden;
  }
  .rpg-bar-fill {
    height: 100%;
    width: 0%;
    transition: width 0.8s steps(10);
    background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(255,255,255,0.3) 2px, rgba(255,255,255,0.3) 3px);
  }
  .rpg-stat-num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text);
    min-width: 22px;
    text-align: right;
  }
  /* Timeline */
  .rpg-timeline { }
  .rpg-tl {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .rpg-tl:last-child { border-bottom: none; }
  .rpg-tl-lvl {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--orange);
    min-width: 18px;
  }
  .rpg-tl-co {
    flex: 1;
    font-weight: 700;
    color: var(--text);
  }
  .rpg-tl-yr {
    font-size: 0.68rem;
    color: var(--text-dim);
  }
  .rpg-tl.active {
    color: var(--orange);
  }
  .rpg-tl.active .rpg-tl-co { color: var(--orange); }
  .rpg-tl.active .rpg-tl-yr { color: var(--orange); }
  /* Badges — 4 across */
  .rpg-badges {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }
  .rpg-badge {
    text-align: center;
    padding: 6px 2px;
  }
  .rpg-pixel-badge {
    width: 20px;
    height: 20px;
    margin: 0 auto 4px;
    display: grid;
    grid-template-columns: repeat(5, 4px);
    grid-template-rows: repeat(5, 4px);
    image-rendering: pixelated;
  }
  .rpg-pixel-badge div {
    width: 4px;
    height: 4px;
  }
  .rpg-badge-name {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    color: var(--text);
  }
  .rpg-badge-sub {
    font-family: var(--font-mono);
    font-size: 0.48rem;
    color: var(--text-dim);
  }
  /* Quests */
  .rpg-quests { }
  .rpg-quest {
    display: flex;
    gap: 6px;
    padding: 3px 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }
  .rpg-quest .rpg-q-name { text-decoration: underline; }
  .rpg-quest:last-child { border-bottom: none; }
  .rpg-q-icon { color: var(--orange); font-weight: 700; }
  .rpg-q-name { flex: 1; color: var(--text); }
  .rpg-q-drop { color: var(--text-dim); }

  /* Keep old stats classes for compatibility */
  .stats-dash {
    margin: -1.5rem;
    padding: 1.5rem;
  }
  .stats-profile {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .stats-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #333;
    border: 2px solid #444;
    display: flex;
    align-items: center;
    justify-content: center;
