  }
  .stats-ring-svg {
    width: 64px;
    height: 64px;
  }
  .stats-ring-num {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin-top: -44px;
    position: relative;
  }
  .stats-ring-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--text-dim);
    margin-top: 14px;
    display: block;
  }
  .stats-section-title {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
    margin: 1.2rem 0 0.8rem;
    color: var(--text);
  }
  .stats-exp { margin-bottom: 1rem; }
  .stats-exp-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 3px;
  }
  .stats-exp-co {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--orange);
  }
  .stats-exp-yr {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
  }
  .stats-bar {
    height: 6px;
    background: var(--border);
    border-radius: 3px;
    margin: 3px 0;
    overflow: hidden;
  }
  .stats-bar-fill {
    height: 100%;
    border-radius: 3px;
  }
  .stats-exp-role {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
  }
  .stats-quote {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-style: italic;
    color: var(--text-dim);
    margin-top: 0.4rem;
    line-height: 1.4;
    max-width: 260px;
    margin-left: auto;
    margin-right: auto;
  }
  .stats-pixel-badges {
    display: flex;
    justify-content: space-between;
    gap: 6px;
  }
  .stats-pixel-badge {
    flex: 1;
    text-align: center;
  }
  .stats-pixel-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    margin: 0 auto 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    image-rendering: pixelated;
  }
  .stats-pixel-name {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--text);
  }
  .stats-pixel-event {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--text-dim);
  }

  /* ========== Mobile Skills — Settings app ========== */
  .m-settings {
    margin: -1.5rem;
    padding: 0.8rem;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .m-settings-group {
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .m-settings-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }
  .m-settings-dot {
    width: 8px;
    height: 8px;
    flex-shrink: 0;
  }
  .m-settings-item {
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: 0.86rem;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }
  .m-settings-item.last { border-bottom: none; }

  /* ========== Mobile Contact — vCard ========== */
