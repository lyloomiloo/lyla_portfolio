<script>
  document.body.classList.add('os-desktop');

  // Speed up project detail videos (2x playback)
  document.querySelectorAll('.proj-detail video, .proj-mockup-viewer video').forEach(v => {
    (v as HTMLVideoElement).playbackRate = 2;
  });

  // Lock screen dismiss
  const lockScreen = document.getElementById('lockScreen');
  const lockButton = document.getElementById('lockButton');

  if (lockScreen && !document.documentElement.classList.contains('skip-lock')) {
    const dismiss = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      lockScreen.classList.add('dismissing');
      sessionStorage.setItem('lyla-visited', 'true');

      setTimeout(() => {
        lockScreen.style.display = 'none';
      }, 450);

      // Wait for window-manager to be ready, then open about
      const tryOpen = () => {
        if (typeof window.openWindow === 'function') {
          window.openWindow('about');
        } else {
          setTimeout(tryOpen, 100);
        }
      };
      setTimeout(tryOpen, 1500);

      if (lockButton) lockButton.removeEventListener('click', dismiss);
      document.removeEventListener('keydown', dismissKey);
    };

    const dismissKey = (e: Event) => dismiss(e);

    if (lockButton) lockButton.addEventListener('click', dismiss);
    document.addEventListener('keydown', dismissKey);
  }

  // Mini player
  const plTracks = [
    { title: 'Tití Me Preguntó', artist: 'Bad Bunny', duration: '5:21', secs: 321 },
    { title: 'TURiSTA', artist: 'Bad Bunny', duration: '3:45', secs: 225 },
    { title: 'NUEVAYoL', artist: 'Bad Bunny', duration: '3:30', secs: 210 },
    { title: 'DtMF', artist: 'Bad Bunny', duration: '3:15', secs: 195 },
  ];
  let plIdx = 0;
  let plPlaying = true;
  let plProgress = 0;
  const plTitle = document.getElementById('playerTitle');
  const plArtist = document.getElementById('playerArtist');
  const plDuration = document.getElementById('playerDuration');
  const plElapsed = document.getElementById('playerElapsed');
  const plFill = document.getElementById('playerFill');
  const plNext = document.getElementById('playerNextTrack');
  const plPlayBtn = document.getElementById('playerPlay');
  const plPrevBtn = document.getElementById('playerPrev');
  const plNextBtn = document.getElementById('playerNext');

  const plPlayIcon = document.getElementById('playerPlayIcon');

  function plUpdate() {
    const t = plTracks[plIdx];
    const nx = plTracks[(plIdx + 1) % plTracks.length];
    if (plTitle) plTitle.textContent = t.title;
    if (plArtist) plArtist.textContent = t.artist;
    if (plDuration) plDuration.textContent = '-' + t.duration;
    if (plNext) plNext.textContent = nx.title + ' \u2014 ' + nx.artist;
    plProgress = 0;
  }

  function plFormatTime(s: number) {
    return Math.floor(s / 60) + ':' + String(Math.floor(s % 60)).padStart(2, '0');
  }

  setInterval(() => {
    if (!plPlaying) return;
    const t = plTracks[plIdx];
    plProgress += 0.5;
    const pct = Math.min((plProgress / 30) * 100, 100);
    if (plFill) plFill.style.width = pct + '%';
    const fakeElapsed = Math.floor((pct / 100) * t.secs);
    if (plElapsed) plElapsed.textContent = plFormatTime(fakeElapsed);
    const remaining = t.secs - fakeElapsed;
    if (plDuration) plDuration.textContent = '-' + plFormatTime(remaining);
    if (pct >= 100) {
      plIdx = (plIdx + 1) % plTracks.length;
      plUpdate();
    }
  }, 500);

  if (plPlayBtn) {
    plPlayBtn.addEventListener('click', () => {
      plPlaying = !plPlaying;
      if (plPlayIcon) {
        plPlayIcon.className = plPlaying ? 'px-pause' : 'px-play';
      }
    });
    // Start as playing
    if (plPlayIcon) plPlayIcon.className = 'px-pause';
  }
  if (plNextBtn) {
    plNextBtn.addEventListener('click', () => {
      plIdx = (plIdx + 1) % plTracks.length;
      plUpdate();
    });
  }
  if (plPrevBtn) {
    plPrevBtn.addEventListener('click', () => {
      plIdx = (plIdx - 1 + plTracks.length) % plTracks.length;
      plUpdate();
    });
  }
</script>

<style is:global>
  /* Scrolling orange marquee bar */
  .marquee-bar {
    position: fixed;
    bottom: 32px;
    left: 0;
    right: 0;
    z-index: 9998;
    overflow: hidden;
    background: #FF6B00;
    padding: 6px 0;
  }
  .marquee-inner {
    display: flex;
    white-space: nowrap;
    will-change: transform;
    animation: marqueeScroll 18s linear infinite;
  }
  .marquee-inner span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #1E1E1E;
    padding-right: 3rem;
  }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-25%); }
  }

  /* Mini player — flat, retro, pixel art */
  .mp {
    padding: 1rem 1.2rem;
    font-family: var(--font-mono);
    background: var(--bg-card);
  }
  .mp-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }
  .mp-artist {
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-bottom: 0.8rem;
  }

  /* Progress bar */
  .mp-progress {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.8rem;
  }
  .mp-time {
    font-size: 0.6rem;
    color: var(--text-dim);
    min-width: 28px;
    font-variant-numeric: tabular-nums;
  }
  .mp-bar {
    flex: 1;
    height: 4px;
    background: var(--border);
  }
  .mp-bar-fill {
    height: 100%;
    width: 0%;
    background: #FF6B00;
    transition: width 0.4s linear;
  }

  /* Controls */
  .mp-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.8rem;
  }
  .mp-btn {
    width: 32px;
    height: 32px;
    background: var(--bg);
    border: 1px solid var(--border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    image-rendering: pixelated;
  }
  .mp-btn:hover {
    border-color: #FF6B00;
  }
  .mp-btn:active {
    background: var(--border);
  }
  .mp-btn--play {
    width: 36px;
    height: 36px;
    border-width: 2px;
  }

  /* Pixel art transport icons — 5x5 grids */
  .px-prev, .px-next, .px-play, .px-pause {
    display: grid;
    grid-template-columns: repeat(5, 3px);
    grid-template-rows: repeat(5, 3px);
    image-rendering: pixelated;
  }
  .px-prev div, .px-next div, .px-play div, .px-pause div {
    width: 3px;
    height: 3px;
  }

  /*
    Play ▶ (right-pointing triangle):
    X . . . .
