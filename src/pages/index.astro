          <p>Say hi &rarr; <a href="mailto:lyla.huangyanling@gmail.com" style="color: var(--orange);">lyla.huangyanling@gmail.com</a></p>
        </div>
      </div>
      <div class="notes-sep"></div>
      <div class="notes-page">
        <div class="notes-page-date">5 April 2026 at 20:37</div>
        <h1 class="notes-page-title">todo</h1>
        <div class="notes-page-body">
          <div class="notes-todo">
