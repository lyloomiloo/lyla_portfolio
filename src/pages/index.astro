<script>
  document.body.classList.add('os-desktop');

  // Lock screen dismiss
  const lockScreen = document.getElementById('lockScreen');
  const lockButton = document.getElementById('lockButton');

  if (lockScreen && !document.documentElement.classList.contains('skip-lock')) {
    const dismiss = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      lockScreen.classList.add('dismissing');
      sessionStorage.setItem('lyla-visited', 'true');

      setTimeout(() => {
        lockScreen.style.display = 'none';
      }, 450);

      // Wait for window-manager to be ready, then open about
      const tryOpen = () => {
        if (typeof window.openWindow === 'function') {
          window.openWindow('about');
        } else {
          setTimeout(tryOpen, 100);
        }
      };
      setTimeout(tryOpen, 1500);

      if (lockButton) lockButton.removeEventListener('click', dismiss);
      document.removeEventListener('keydown', dismissKey);
    };

    const dismissKey = (e: Event) => dismiss(e);

    if (lockButton) lockButton.addEventListener('click', dismiss);
    document.addEventListener('keydown', dismissKey);
  }

  // Record player track cycling
  const playlist = [
    { track: 'Tycho \u2014 Awake', next: 'Bonobo \u2014 Kerala' },
    { track: 'Bonobo \u2014 Kerala', next: 'Khruangbin \u2014 Time (You and I)' },
    { track: 'Khruangbin \u2014 Time (You and I)', next: 'Nujabes \u2014 Feather' },
    { track: 'Nujabes \u2014 Feather', next: 'Tití Me Preguntó \u2014 Bad Bunny' },
    { track: 'Tití Me Preguntó \u2014 Bad Bunny', next: 'Tycho \u2014 Awake' },
  ];
  let rpIdx = 0;
  const rpTrack = document.getElementById('rp-track');
  const rpQueue = document.getElementById('rp-queue');
  if (rpTrack && rpQueue) {
    setInterval(() => {
      rpIdx = (rpIdx + 1) % playlist.length;
      rpTrack.textContent = playlist[rpIdx].track;
      rpQueue.textContent = playlist[rpIdx].next;
    }, 5000);
  }
</script>

<style is:global>
  .record-player {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    background: #1E1E1E;
    margin: -1.5rem;
    padding: 1.2rem;
    image-rendering: pixelated;
  }

  .rp-stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 0 0.6rem;
  }

  /* Pixel art vinyl — 12x12 grid */
  .pixel-vinyl {
    display: grid;
    grid-template-columns: repeat(12, 10px);
    grid-template-rows: repeat(12, 10px);
    image-rendering: pixelated;
    animation: vinyl-spin 4s linear infinite;
  }
  .pixel-vinyl div { width: 10px; height: 10px; }
  .pv-d { background: #222; }
  .pv-g { background: #333; }
  .pv-o { background: #FF6B00; }
  .pv-k { background: #111; }

  /* Pixel tone arm — 5x3 grid */
  .pixel-arm {
    display: grid;
    grid-template-columns: repeat(3, 6px);
    grid-template-rows: repeat(5, 6px);
    image-rendering: pixelated;
    position: absolute;
    top: 8px;
    right: 20px;
  }
  .pixel-arm div { width: 6px; height: 6px; }
  .pa-p { background: #888; }
  .pa-t { background: #FF6B00; }

  @keyframes vinyl-spin {
    to { transform: rotate(360deg); }
  }

  .rp-info {
    text-align: left;
    font-family: var(--font-mono);
    padding: 0.6rem 0.4rem 0;
    width: 100%;
    border-top: 2px solid #333;
  }

  .rp-now {
    font-size: 0.65rem;
    color: #39FF14;
    letter-spacing: 0.1em;
    margin-bottom: 0.15rem;
  }

  .rp-track {
    font-size: 0.85rem;
    color: #FF6B00;
    font-weight: 700;
    min-height: 1.2em;
    margin-bottom: 0.4rem;
  }

  .rp-divider {
    font-size: 0.6rem;
    color: #333;
    margin-bottom: 0.4rem;
    letter-spacing: 2px;
  }

  .rp-next {
    font-size: 0.6rem;
    color: #39FF14;
    letter-spacing: 0.1em;
    margin-bottom: 0.15rem;
  }

  .rp-queue {
    font-size: 0.75rem;
    color: #888;
    min-height: 1em;
  }
</style>
