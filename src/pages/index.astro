---
import BaseLayout from '../layouts/BaseLayout.astro';
import Desktop from '../components/Desktop.astro';
import Window from '../components/Window.astro';
import MobilePanel from '../components/MobilePanel.astro';
import Taskbar from '../components/Taskbar.astro';
import LockScreen from '../components/LockScreen.astro';
import MobileLockScreen from '../components/MobileLockScreen.astro';
import MobileHomeScreen from '../components/MobileHomeScreen.astro';
import ProjectsWindow from '../components/ProjectsWindow.astro';
import AboutWindow from '../components/AboutWindow.astro';
import SkillsWindow from '../components/SkillsWindow.astro';
import ContactWindow from '../components/ContactWindow.astro';
import ProjectDetail from '../components/ProjectDetail.astro';
---

<BaseLayout title="Portfolio">
  <LockScreen />
  <MobileLockScreen />
  <Desktop />
  <MobileHomeScreen />

  <!-- Desktop Windows -->
  <Window id="projects" title="projects.exe" width="90vw" height="85vh" top="4vh" left="5vw">
    <ProjectsWindow />
  </Window>
  <Window id="about" title="about.exe" width="55vw" height="65vh" top="5vh" left="5vw" darkMode>
    <AboutWindow />
  </Window>
  <Window id="skills" title="capabilities.dll" width="50vw" height="50vh" top="8vh" left="8vw">
    <SkillsWindow />
  </Window>
  <Window id="contact" title="contact.txt" width="32vw" height="auto" top="10vh" left="10vw">
    <ContactWindow />
  </Window>

  <!-- Easter Egg Windows -->
  <Window id="readme" title="readme.txt" width="360px" height="380px" top="25vh" left="35vw">
    <div style="font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.8; color: var(--text);">
      <p>Hey! You found the readme.</p>
      <br>
      <p>This portfolio was built with Astro, too many sleepless nights, and long conversations with Claude.</p>
      <br>
      <p>If you're reading this, you're the kind of person I want to work with!</p>
      <br>
      <p>Say hi &rarr; <a href="mailto:lyla.huangyanling@gmail.com" style="color: var(--orange);">lyla.huangyanling@gmail.com</a></p>
    </div>
  </Window>

  <Window id="todo" title="todo.md" width="420px" height="auto" top="12vh" left="35vw">
    <div style="font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.8; color: var(--text);">
      <p>&#9745; Move to Barcelona</p>
      <p>&#9745; Learn to vibe code (enough to prototype)</p>
      <p>&#9745; Build a few things I actually like</p>
      <p>&#9745; Make a new portfolio</p>
      <p style="margin: 0.4rem 0;"></p>
      <p style="color: var(--orange);">&#9744; Find a role that feels right</p>
      <p>&#9744; Improve Spanish (beyond survival)</p>
      <p>&#9744; Touch grass</p>
    </div>
  </Window>

  <Window id="recycle" title="bin/" width="280px" height="200px" top="30vh" left="38vw">
    <div style="font-family: var(--font-mono); font-size: 1rem; color: var(--text-dim); text-align: center; padding: 1.5rem 0;">
      <p style="font-size: 1.5rem;">&#128465;</p>
      <p style="font-size: 0.85rem;">(empty - i deleted my imposter syndrome.)</p>
    </div>
  </Window>

  <Window id="selfie" title="selfie.jpg — Preview" width="220px" height="240px" top="22vh" left="42vw">
    <div style="text-align: center; padding: 1rem;">
      <div style="width: 80px; height: 80px; background: var(--dark); border-radius: 50%; margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 2rem; color: var(--orange);">:)</div>
      <p style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim);">close enough.</p>
    </div>
  </Window>

  <Window id="playlist" title="playlist.m3u" width="320px" height="auto" top="18vh" left="36vw">
    <div class="mp" style="margin:-1.5rem;">
      <div class="mp-title" id="playerTitle">Tití Me Preguntó</div>
      <div class="mp-artist" id="playerArtist">Bad Bunny</div>
      <div class="mp-progress">
        <span class="mp-time" id="playerElapsed">0:00</span>
        <div class="mp-bar">
          <div class="mp-bar-fill" id="playerFill"></div>
        </div>
        <span class="mp-time" id="playerDuration">-5:21</span>
      </div>
      <div class="mp-controls">
        <button class="mp-btn" id="playerPrev" aria-label="Previous">
          <div class="px-prev"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div>
        </button>
        <button class="mp-btn mp-btn--play" id="playerPlay" aria-label="Play">
          <div class="px-play" id="playerPlayIcon"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div>
        </button>
        <button class="mp-btn" id="playerNext" aria-label="Next">
          <div class="px-next"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div>
        </button>
      </div>
      <div class="mp-next">
        <span class="mp-next-label">NEXT</span> <span id="playerNextTrack">TURiSTA &mdash; Bad Bunny</span>
      </div>
    </div>
  </Window>

  <!-- New Easter Eggs -->
  <Window id="resume" title="resume.pdf — Downloading..." width="360px" height="220px" top="15vh" left="30vw">
    <div style="font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.8; color: var(--text); text-align: center; padding: 0.5rem 0; margin: -1rem;">
      <p style="font-size: 2rem; margin-bottom: 0.5rem;">&#128196;</p>
      <p style="font-weight: 700;">Lyla_Huang_Resume_2026.pdf</p>
      <p style="color: var(--text-dim); font-size: 0.8rem; margin-top: 0.3rem;">Downloading...</p>
      <div style="width: 80%; margin: 1rem auto 0; height: 6px; background: var(--border); overflow: hidden;">
        <div style="height: 100%; background: var(--orange); animation: loadFill 2s ease-out forwards; width: 0%;"></div>
      </div>
    </div>
  </Window>

  <!-- Duck Runner Game — Desktop -->
  <Window id="duckgame" title="quack.exe" width="100vw" height="calc(100vh - 38px)" top="0" left="0">
    <canvas id="duckGameDesktop" style="width:100%; height:100%; display:block; image-rendering:pixelated; background:#87CEEB;"></canvas>
  </Window>

  <!-- Project Detail Windows -->
  <Window id="reroute-detail" title="project_01.exe — (RE)ROUTE" width="82vw" height="78vh" top="4vh" left="6vw">
    <ProjectDetail
      slug="reroute" order={1} title="(RE)ROUTE"
      hook="(re)Route is a walking app that asks a different question. 'What kind of walk do you need right now?' Type a mood, a vibe, or a destination in natural language. The AI routes you through Barcelona's most interesting, safest, or calmest streets depending on what the moment calls for."
      tags="AI · UX Research · Product Design · Data"
      location="Barcelona" status="Prototype · On-going"
      appType="Web Application" context="Master's Thesis — ELISAVA" year="2026"
      isMobile={true}
      video="/images/projects/reroute/main.mov"
      link="https://rerouted.vercel.app/"
      gallery={[
        { src: '/images/projects/reroute/explore_mode.mov', name: 'explore_mode.mov', type: 'video' },
        { src: '/images/projects/reroute/smart_search.mov', name: 'smart_search.mov', type: 'video' },
        { src: '/images/projects/reroute/themed_walks.mov', name: 'themed_walks.mov', type: 'video' },
        { src: '/images/projects/reroute/wander_mode.jpg', name: 'wander_mode.jpg', type: 'image' },
      ]}
      stats={[{ number: '119K', label: 'street segments\nscored' }, { number: '386', label: 'curated\nPOIs' }, { number: '3', label: 'new ways\nto walk' }]}
      problem='Every navigation app solves the same problem: getting you there fast. But what about making the walk worth taking? (re)Route does more than just get you from A to B — it brings the city to you, with journeys that spark.'
      approaches={[
        { label: 'INTENT OVER INPUT', desc: 'Users type feelings, not addresses. One AI call interprets mood as navigation intent.' },
        { label: 'DATA-INFORMED ROUTES', desc: '119K street segments scored for noise, safety, greenery. Routes built from real characteristics, not just distance.' },
        { label: 'SAFETY AS DEFAULT', desc: 'After dark, every route auto-shifts to well-lit streets. Not a toggle — a baseline.' },
      ]}
      features={[
        { title: '119K street segments scored', desc: 'Noise, greenery, cleanliness, cultural richness, safety — real data, not guesses.' },
        { title: 'AI-powered discovery', desc: '"Artsy date" → experimental galleries, design bookshops, natural wine bars. Verified against real place data.' },
        { title: 'Safety as baseline', desc: 'After dark, every route shifts to well-lit, active streets. Not a mode — always on.' },
        { title: '386 hand-curated POIs', desc: `Places that don't appear on commercial platforms. Themed walks, bloom calendars, hidden courtyards.` },
      ]}
      mockups={[
        { label: 'GO MODE', caption: 'GO — destination routing', video: '/images/projects/reroute/go-mode.mov' },
        { label: 'EXPLORE MODE', caption: 'EXPLORE — vibe-based discovery', video: '/images/projects/reroute/explore-mode.mov' },
        { label: 'WANDER MODE', caption: 'WANDER — compass + curated pins', image: '/images/projects/reroute/wander-mode.jpg' },
      ]}
    />
  </Window>

  <Window id="snapp-detail" title="project_02.exe — SNAPP" width="78vw" height="78vh" top="4vh" left="8vw">
    <ProjectDetail
      slug="snapp" order={2} title="SNAPP"
      hook="Snapp is a location-based photo scavenger hunt. Each day, players get a single word prompt to search for around them. Photos land on a shared map, then disappear at midnight. It's a game about noticing the small stuff and sharing them with zero pretense."
      tags="Product Design · Full-Stack · UX · Gamification"
      location="Global" status="Deployed"
      appType="Mobile Web App" context="Personal Project" year="2026"
      isMobile={true}
      video="/images/projects/snapp/beta_test.mov"
      link="https://ohsnapp.vercel.app/"
      gallery={[
        { src: '/images/projects/snapp/beta_test.mov', name: 'beta_test.mov', type: 'video' },
        { src: '/images/projects/snapp/daily_prompt.jpg', name: 'daily_prompt.jpg', type: 'image' },
      ]}
      stats={[{ number: '1', label: 'word\na day' }, { number: '24hr', label: 'challenge' }, { number: '∞', label: 'moments\nof beauty' }]}
      problem='We walk past a thousand interesting things every day without noticing them. Snapp turns our everyday environment into a canvas for discovery, with a daily word prompt that gets everyone looking up and sharing what they find.'
      approaches={[
        { label: 'ONE CONSTRAINT', desc: 'One word per day. The constraint IS the creativity. Limits create focus.' },
        { label: 'EPHEMERAL BY DESIGN', desc: 'Map resets at midnight. No archive, no likes. The impermanence creates urgency without anxiety.' },
        { label: 'COLLECTIVE SEEING', desc: 'Same prompt, different eyes. The city becomes a collaborative gallery through shared interpretation.' },
      ]}
      features={[
        { title: 'Anti-social media', desc: 'No algorithm, no followers, no likes. Using a phone to make you look up from it.' },
        { title: 'Ephemeral by design', desc: `The map resets at midnight. Today's gallery lives for exactly one day.` },
        { title: 'Deliberate constraints', desc: 'One word + one day = focus. The shared map creates connection without competition.' },
        { title: 'City-wide collaboration', desc: 'Barcelona becomes a collaborative, ever-changing gallery that lives for one day.' },
      ]}
      mockups={[
        { label: 'DAILY PROMPT', caption: 'Daily word prompt' },
        { label: 'PHOTO CAPTURE', caption: 'Camera + location tagging' },
        { label: 'SHARED MAP', caption: 'City-wide shared gallery' },
      ]}
    />
  </Window>

  <Window id="planmytrip-detail" title="project_03.exe — PLANMYTRIP" width="90vw" height="82vh" top="2vh" left="5vw">
    <ProjectDetail
      slug="planmytrip" order={3} title="PLANMYTRIP"
      hook="Trip planning tools are either ugly spreadsheets or rigid templates. PlanMyTrip is a planning surface that's editable, data-connected, and pretty enough to download directly. AI can even generate a base to help you get started."
      tags="Frontend · Editorial Design · Interactive"
      location="Global" status="Deployed"
      appType="Web Application" context="Personal Project — AI-assisted build" year="2026"
      isMobile={false}
      video="/images/projects/planmytrip/main.mov"
      link="https://mytrippp.vercel.app/"
      gallery={[
        { src: '/images/projects/planmytrip/main.mov', name: 'main.mov', type: 'video' },
        { src: '/images/projects/planmytrip/euro_alps_tour.pdf', name: 'euro_alps_tour.pdf', type: 'pdf', preview: '/images/projects/planmytrip/euro_alps_tour.pdf.png' },
        { src: '/images/projects/planmytrip/trip_overview.pdf', name: 'trip_overview.pdf', type: 'pdf', preview: '/images/projects/planmytrip/trip_overview.pdf.png' },
        { src: '/images/projects/planmytrip/preview.jpg', name: 'preview.jpg', type: 'image' },
      ]}
      stats={[{ number: 'LIVE', label: 'weather' }, { number: 'AI', label: 'recommendations' }, { number: 'PDF', label: 'downloads' }]}
      problem={`Trip planning tools are either ugly spreadsheets or rigid templates. I wanted something useful that also looks like something you'd want to look at.`}
      approaches={[
        { label: 'EDITOR NOT SPREADSHEET', desc: 'Planning should feel like designing a magazine, not filling cells. The interface IS the experience.' },
        { label: 'LIVE DATA LAYER', desc: 'Weather, images, and schedules pull in real-time. The tool stays current so you don\'t have to.' },
        { label: 'DESIGN-FIRST WORKFLOW', desc: 'Start with how it looks, then fill in the details. Visual hierarchy drives the planning process, not the other way around.' },
      ]}
      features={[
        { title: 'Magazine-quality layouts', desc: 'City intro slides, photo galleries, day timelines — planning you\'d actually screenshot and share.' },
        { title: 'Multi-provider image search', desc: 'Find and place destination photos or auto-fill to populate the itinerary instantly.' },
        { title: 'Weather-aware itineraries', desc: 'Live Open-Meteo data per destination. See conditions for every day of the trip, updated in real-time.' },
        { title: 'Inline everything', desc: 'Click any text to edit. Drag to reorder. No modals, no forms — just direct manipulation.' },
      ]}
      mockups={[
        { label: 'ITINERARY VIEW', caption: 'City intro + day overview' },
        { label: 'WEATHER & DETAILS', caption: 'Weather widgets + timeline' },
      ]}
    />
  </Window>

  <!-- Mobile Panels -->

  <!-- MOBILE: About — RPG Character Sheet -->
