      <div class="spotify-tracks">
        <div class="spotify-track"><span class="spotify-num">1</span><div class="spotify-track-info"><span class="spotify-track-name">Tit&iacute; Me Pregunt&oacute;</span><span class="spotify-track-artist">Bad Bunny</span></div><span class="spotify-dur">5:21</span></div>
        <div class="spotify-track"><span class="spotify-num">2</span><div class="spotify-track-info"><span class="spotify-track-name">TURiSTA</span><span class="spotify-track-artist">Bad Bunny</span></div><span class="spotify-dur">3:45</span></div>
        <div class="spotify-track"><span class="spotify-num">3</span><div class="spotify-track-info"><span class="spotify-track-name">NUEVAYoL</span><span class="spotify-track-artist">Bad Bunny</span></div><span class="spotify-dur">3:30</span></div>
        <div class="spotify-track"><span class="spotify-num">4</span><div class="spotify-track-info"><span class="spotify-track-name">DtMF</span><span class="spotify-track-artist">Bad Bunny</span></div><span class="spotify-dur">3:15</span></div>
