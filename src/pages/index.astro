---
import BaseLayout from '../layouts/BaseLayout.astro';
import Desktop from '../components/Desktop.astro';
import Window from '../components/Window.astro';
import MobilePanel from '../components/MobilePanel.astro';
import Taskbar from '../components/Taskbar.astro';
import LockScreen from '../components/LockScreen.astro';
import ProjectsWindow from '../components/ProjectsWindow.astro';
import AboutWindow from '../components/AboutWindow.astro';
import SkillsWindow from '../components/SkillsWindow.astro';
import ContactWindow from '../components/ContactWindow.astro';
import ProjectDetail from '../components/ProjectDetail.astro';
---

<BaseLayout title="Portfolio">
  <LockScreen />
  <Desktop />

  <!-- Desktop Windows -->
  <Window id="projects" title="projects.exe" width="90vw" height="85vh" top="4vh" left="5vw">
    <ProjectsWindow />
  </Window>
  <Window id="about" title="about.exe" width="55vw" height="65vh" top="5vh" left="5vw" darkMode>
    <AboutWindow />
  </Window>
  <Window id="skills" title="capabilities.dll" width="50vw" height="50vh" top="8vh" left="8vw">
    <SkillsWindow />
  </Window>
  <Window id="contact" title="contact.txt" width="30vw" height="auto" top="10vh" left="10vw">
    <ContactWindow />
  </Window>

  <!-- Easter Egg Windows -->
  <Window id="readme" title="readme.txt" width="360px" height="380px" top="25vh" left="35vw">
    <div style="font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.8; color: var(--text);">
      <p>Hey! You found the readme.</p>
      <br>
      <p>This portfolio was built with Astro, too many sleepless nights, and long conversations with Claude.</p>
      <br>
      <p>If you're reading this, you're the kind of person I want to work with!</p>
      <br>
      <p>Say hi &rarr; <a href="mailto:lyla.huangyanling@gmail.com" style="color: var(--orange);">lyla.huangyanling@gmail.com</a></p>
    </div>
  </Window>

  <Window id="todo" title="todo.md" width="420px" height="auto" top="12vh" left="35vw">
    <div style="font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.8; color: var(--text);">
      <p>&#9745; Move to Barcelona</p>
      <p>&#9745; Learn to vibe code (enough to prototype)</p>
      <p>&#9745; Build a few things I actually like</p>
      <p>&#9745; Make a new portfolio</p>
      <p style="margin: 0.4rem 0;"></p>
      <p style="color: var(--orange);">&#9744; Find a role that feels right</p>
      <p>&#9744; Improve Spanish (beyond survival)</p>
      <p>&#9744; Touch grass</p>
    </div>
  </Window>

  <Window id="recycle" title="recycle_bin/" width="280px" height="200px" top="30vh" left="38vw">
    <div style="font-family: var(--font-mono); font-size: 1rem; color: var(--text-dim); text-align: center; padding: 1.5rem 0;">
      <p style="font-size: 1.5rem;">&#128465;</p>
      <p style="font-size: 0.85rem;">(empty - i deleted my imposter syndrome.)</p>
    </div>
  </Window>

  <Window id="selfie" title="selfie.jpg — Preview" width="220px" height="240px" top="22vh" left="42vw">
    <div style="text-align: center; padding: 1rem;">
      <div style="width: 80px; height: 80px; background: var(--dark); border-radius: 50%; margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 2rem; color: var(--orange);">:)</div>
      <p style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim);">close enough.</p>
    </div>
  </Window>

  <Window id="playlist" title="playlist.m3u" width="320px" height="230px" top="18vh" left="36vw">
    <div style="font-family: var(--font-mono); font-size: 0.85rem; line-height: 2; color: var(--text);">
      <p>1. Tití Me Preguntó &mdash; Bad Bunny</p>
      <p>2. TURiSTA &mdash; Bad Bunny</p>
      <p>3. Nujabes &mdash; Feather</p>
      <p>4. NUEVAYoL &mdash; Bad Bunny</p>
      <p>5. DtMF &mdash; Bad Bunny</p>
    </div>
  </Window>

  <!-- New Easter Eggs -->
  <Window id="resume" title="resume.pdf — Downloading..." width="360px" height="200px" top="15vh" left="30vw">
    <div style="font-family: var(--font-mono); font-size: 0.9rem; line-height: 1.8; color: var(--text); text-align: center; padding: 1rem 0;">
      <p style="font-size: 2rem; margin-bottom: 0.5rem;">&#128196;</p>
      <p style="font-weight: 700;">Lyla_Huang_Resume_2025.pdf</p>
      <p style="color: var(--text-dim); font-size: 0.8rem; margin-top: 0.3rem;">Downloading...</p>
      <div style="width: 80%; margin: 1rem auto 0; height: 6px; background: var(--border); overflow: hidden;">
        <div style="height: 100%; background: var(--orange); animation: loadFill 2s ease-out forwards; width: 0%;"></div>
      </div>
    </div>
  </Window>

  <!-- Project Detail Windows -->
  <Window id="reroute-detail" title="project_01.exe — (RE)ROUTE" width="68vw" height="65vh" top="4vh" left="10vw">
    <ProjectDetail
      slug="reroute" order={1} title="(RE)ROUTE"
      hook="What if navigation optimised for how you feel, not just where you go? Reimagining walking as an experience with routing for safety, discovery, and human-ness."
      tags="Agentic Workflows · UX Research · Product Design · Data"
      location="Barcelona" status="Master's Thesis · Prototype · 2025"
      isMobile={true}
      stats={[{ number: '119K', label: 'street segments scored' }, { number: '372', label: 'hand-curated POIs' }, { number: '3', label: 'modes of navigation' }]}
      problem='Every navigation app solves the same problem: getting you there fast. But what about making the walk worth taking? (re)Route does more than just get you from A to B — it brings the city to you, with journeys that spark.'
      approaches={[
        { label: 'GO MODE', desc: 'The old maps but with new route options and smarter.' },
        { label: 'EXPLORE MODE', desc: 'Discover, plan, or experience the city with AI-powered recommendations.' },
        { label: 'WANDER MODE', desc: 'No destination, no route line. Just a compass and POIs nearby.' },
      ]}
      features={[
        { title: '119K street segments scored', desc: 'Noise, greenery, cleanliness, cultural richness, safety — real data, not guesses.' },
        { title: 'AI-powered discovery', desc: '"Artsy date" → experimental galleries, design bookshops, natural wine bars. Verified against real place data.' },
        { title: 'Safety as baseline', desc: 'After dark, every route shifts to well-lit, active streets. Not a mode — always on.' },
        { title: '386 hand-curated POIs', desc: `Places that don't appear on commercial platforms. Themed walks, bloom calendars, hidden courtyards.` },
      ]}
      mockups={[
        { label: 'GO MODE', caption: 'GO — destination routing' },
        { label: 'EXPLORE MODE', caption: 'EXPLORE — vibe-based discovery' },
        { label: 'WANDER MODE', caption: 'WANDER — compass + curated pins' },
      ]}
    />
  </Window>

  <Window id="snapp-detail" title="project_02.exe — SNAPP" width="65vw" height="65vh" top="7vh" left="14vw">
    <ProjectDetail
      slug="snapp" order={2} title="SNAPP"
      hook="What if we turned a map into a daily quest for beauty? A word a day. A shared visual diary for all."
      tags="Product Design · Full-Stack · UX · Gamification"
      location="Barcelona" status="In use · Feb 2026"
      isMobile={true}
      stats={[{ number: 'X', label: 'XXX' }, { number: 'X', label: 'XXX' }, { number: 'X', label: 'XXXX' }]}
      problem='We walk past a thousand interesting things every day without noticing them. Snapp turns our everyday environment into a canvas for discovery, with a daily word prompt that gets everyone looking up and sharing what they find.'
      approaches={[
        { label: 'PROMPT', desc: 'One word each day (e.g., texture, tiny, bright). Every user gets the same theme.' },
        { label: 'CAPTURE', desc: 'Step outside, look around, and snap a relevant image to capture the everyday beauty.' },
        { label: 'SHARE', desc: 'Photos drop on a shared city map. At midnight (UTC+1), the map resets. No pretense.' },
      ]}
      features={[
        { title: 'Anti-social media', desc: 'No algorithm, no followers, no likes. Using a phone to make you look up from it.' },
        { title: 'Ephemeral by design', desc: `The map resets at midnight. Today's gallery lives for exactly one day.` },
        { title: 'Deliberate constraints', desc: 'One word + one day = focus. The shared map creates connection without competition.' },
        { title: 'City-wide collaboration', desc: 'Barcelona becomes a collaborative, ever-changing gallery that lives for one day.' },
      ]}
      mockups={[
        { label: 'DAILY PROMPT', caption: 'Daily word prompt' },
        { label: 'PHOTO CAPTURE', caption: 'Camera + location tagging' },
        { label: 'SHARED MAP', caption: 'City-wide shared gallery' },
      ]}
    />
  </Window>

  <Window id="planmytrip-detail" title="project_03.exe — PLANMYTRIP" width="66vw" height="65vh" top="10vh" left="18vw">
    <ProjectDetail
      slug="planmytrip" order={3} title="PLANMYTRIP"
      hook="A planning tool that thinks like an editor, not a spreadsheet. Live weather, image search, and inline editing — all in one flow."
      tags="Frontend · APIs · Editorial Design · Interactivity"
      location="Personal Project" status="In use · Mar 2025"
      isMobile={false}
      stats={[{ number: 'XX', label: 'XX' }, { number: 'XXX', label: 'XXX' }, { number: 'XXX', label: 'XXX' }]}
      problem={`"Trip planning tools are either ugly spreadsheets or rigid templates. I wanted something useful that also looks like something you'd want to look at."`}
      approaches={[
        { label: 'EDITORIAL', desc: 'Layout inspired by travel magazines. City intros, photo galleries, timelines.' },
        { label: 'LIVE DATA', desc: 'Weather API per destination. Image search built in. Real-time, not static.' },
        { label: 'INLINE EDIT', desc: `Click to edit everything. A planning tool that's also beautiful enough to screenshot.` },
      ]}
      features={[
        { title: 'Editorial design meets utility', desc: 'City intro slides with split typography, day pages with photo galleries and timelines.' },
        { title: 'Live weather integration', desc: 'Real-time weather data per destination via Open-Meteo API.' },
        { title: 'Built-in image search', desc: 'Find and place photos without leaving the tool.' },
        { title: 'AI-assisted planning', desc: 'Generate itinerary suggestions based on user preferences and real-time data with AI.' },
      ]}
      mockups={[
        { label: 'ITINERARY VIEW', caption: 'City intro + day overview' },
        { label: 'WEATHER & DETAILS', caption: 'Weather widgets + timeline' },
      ]}
    />
  </Window>

  <!-- Mobile Panels -->
  <MobilePanel id="projects" title="projects.exe">
    <ProjectsWindow />
  </MobilePanel>
  <MobilePanel id="about" title="about.exe">
    <AboutWindow />
  </MobilePanel>
  <MobilePanel id="skills" title="capabilities.dll">
    <SkillsWindow />
  </MobilePanel>
  <MobilePanel id="contact" title="contact.txt">
    <ContactWindow />
  </MobilePanel>
  <MobilePanel id="reroute-detail" title="project_01.exe — (RE)ROUTE">
    <ProjectDetail
      slug="reroute" order={1} title="(RE)ROUTE"
      hook="What if navigation optimised for how you feel, not just where you go?"
      tags="AI · UX Research · Product Design · Data" location="Barcelona" status="Master's Thesis · 2025"
      isMobile={true}
      stats={[{ number: '119K', label: 'segments' }, { number: '386', label: 'POIs' }, { number: '89%', label: 'vary routes' }]}
      problem={`"Every navigation app gets you there fast. But what about making the walk worth taking?"`}
      approaches={[{ label: 'GO', desc: 'Destination routing.' }, { label: 'EXPLORE', desc: 'Vibe-based discovery.' }, { label: 'WANDER', desc: 'Compass + pins.' }]}
      features={[{ title: '119K segments scored', desc: 'Real data on noise, greenery, safety.' }, { title: 'AI discovery', desc: 'Verified place recommendations.' }, { title: 'Safety baseline', desc: 'Well-lit routes after dark.' }]}
      mockups={[{ label: 'GO', caption: 'GO mode' }, { label: 'EXPLORE', caption: 'EXPLORE mode' }, { label: 'WANDER', caption: 'WANDER mode' }]}
    />
  </MobilePanel>
  <MobilePanel id="snapp-detail" title="project_02.exe — SNAPP">
    <ProjectDetail
      slug="snapp" order={2} title="SNAPP"
      hook="One word. One photo. One day."
      tags="Product Design · Full-Stack · UX" location="Barcelona" status="In use · 2026"
      isMobile={true}
      stats={[{ number: '1', label: 'word/day' }, { number: '1', label: 'photo' }, { number: '∞', label: 'perspectives' }]}
      problem={`"We walk past interesting things every day without seeing them."`}
      approaches={[{ label: 'PROMPT', desc: 'One word per day.' }, { label: 'CAPTURE', desc: 'Find it, snap it.' }, { label: 'SHARE', desc: 'City map, resets at midnight.' }]}
      features={[{ title: 'Anti-social media', desc: 'No algorithm, no followers.' }, { title: 'Ephemeral', desc: 'Resets at midnight.' }, { title: 'Constraints = focus', desc: 'One word, one day.' }]}
      mockups={[{ label: 'PROMPT', caption: 'Daily prompt' }, { label: 'MAP', caption: 'Shared map' }, { label: 'CAPTURE', caption: 'Photo capture' }]}
    />
  </MobilePanel>
  <MobilePanel id="planmytrip-detail" title="project_03.exe — PLANMYTRIP">
    <ProjectDetail
      slug="planmytrip" order={3} title="PLANMYTRIP"
      hook="A planning tool that thinks like an editor, not a spreadsheet."
      tags="Frontend · APIs · Editorial Design" location="Personal Project" status="In use · 2025"
      isMobile={false}
      stats={[{ number: '15', label: 'days' }, { number: '9', label: 'cities' }, { number: 'LIVE', label: 'weather' }]}
      problem={`"Trip planning tools are ugly spreadsheets or rigid templates."`}
      approaches={[{ label: 'EDITORIAL', desc: 'Magazine-style layout.' }, { label: 'LIVE DATA', desc: 'Weather + images.' }, { label: 'INLINE', desc: 'Click to edit.' }]}
      features={[{ title: 'Editorial design', desc: 'City intros, photo galleries, timelines.' }, { title: 'Live weather', desc: 'Open-Meteo API per destination.' }, { title: 'AI-assisted build', desc: 'Designed system, Claude Code built it.' }]}
      mockups={[{ label: 'ITINERARY', caption: 'Day overview' }, { label: 'WEATHER', caption: 'Weather widgets' }]}
    />
  </MobilePanel>

  <Taskbar />
</BaseLayout>

<script>
  document.body.classList.add('os-desktop');

  // Lock screen dismiss
  const lockScreen = document.getElementById('lockScreen');
  const lockButton = document.getElementById('lockButton');

  if (lockScreen && !document.documentElement.classList.contains('skip-lock')) {
    const dismiss = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      lockScreen.classList.add('dismissing');
      sessionStorage.setItem('lyla-visited', 'true');

      setTimeout(() => {
        lockScreen.style.display = 'none';
      }, 450);

      // Wait for window-manager to be ready, then open about
      const tryOpen = () => {
        if (typeof window.openWindow === 'function') {
          window.openWindow('about');
        } else {
          setTimeout(tryOpen, 100);
        }
      };
      setTimeout(tryOpen, 1500);

      if (lockButton) lockButton.removeEventListener('click', dismiss);
      document.removeEventListener('keydown', dismissKey);
    };

    const dismissKey = (e: Event) => dismiss(e);

    if (lockButton) lockButton.addEventListener('click', dismiss);
    document.addEventListener('keydown', dismissKey);
  }
</script>
