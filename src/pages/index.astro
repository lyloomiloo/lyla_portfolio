    overflow: hidden;
  }
  .stats-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }
  .stats-role {
    font-family: var(--font-mono);
    font-size: 0.7rem;
