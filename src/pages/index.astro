    grid-template-columns: repeat(8, 8px);
    grid-template-rows: repeat(8, 8px);
    image-rendering: pixelated;
  }
  .m-contact-pixel-grid div {
    width: 8px;
    height: 8px;
  }
  .m-contact-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.04em;
  }
  .m-contact-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-top: 2px;
  }
  .m-contact-links {
    background: var(--bg-card);
    border-radius: 12px;
    margin: 0 1rem 1rem;
    overflow: hidden;
  }
  .m-contact-link {
    display: flex;
    align-items: center;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    gap: 12px;
  }
  .m-contact-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    min-width: 52px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .m-contact-value {
