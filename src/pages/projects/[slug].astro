---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import GlitchText from '../../components/GlitchText.astro';
import RetroButton from '../../components/RetroButton.astro';
import RetroElements from '../../components/RetroElements.astro';
import Taskbar from '../../components/Taskbar.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.data.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;
const isMobileApp = ['reroute', 'snapp'].includes(d.slug);
const heroSrc = d.heroImage || '';
const isVideo = heroSrc.endsWith('.mp4') || heroSrc.endsWith('.webm');
---

<BaseLayout title={d.displayTitle} description={d.tagline}>
  <Nav />
  <main class="pd-page">
    <div class="pd-back">
      <RetroButton href="/#projects" text="← Back" />
    </div>

    <!-- Project info in a window frame -->
    <div class="pd-window">
      <div class="pd-window-bar">
        <span class="pd-window-dots">
          <span style="background: var(--orange)"></span>
          <span style="background: var(--green)"></span>
          <span style="background: #999"></span>
        </span>
        <span class="pd-window-title">project_0{d.order}.exe — {d.displayTitle.toLowerCase()}</span>
        <span class="pd-window-x">&times;</span>
      </div>
      <div class="pd-window-body">
        <div class="pd-layout">
          <div class="pd-info">
            <span class="pd-index">0{d.order}</span>
            <GlitchText text={d.displayTitle} tag="h1" class="pd-title" intensity="bold" interval={3500} playEntrance={true} />
            <p class="pd-hook">{d.hook}</p>
            <div class="pd-tags">
              {d.tags.map((t: string) => <span>{t}</span>)}
            </div>
            {d.type && <div class="pd-location">{d.type}</div>}
            <div class="pd-meta">{d.status}</div>
          </div>

          {heroSrc && (
            <div class="pd-mockup">
              {isMobileApp ? (
                <div class="pd-phone-tilt">
                  <div class="pd-phone">
                    <div class="pd-phone-notch"></div>
                    <div class="pd-phone-screen">
                      {isVideo
                        ? <video src={heroSrc} autoplay loop muted playsinline />
                        : <img src={heroSrc} alt={`${d.displayTitle} screenshot`} />
                      }
                    </div>
                  </div>
                </div>
              ) : (
                <div class="pd-browser">
                  <div class="pd-browser-chrome">
                    <span class="pd-chrome-dots">
                      <span style="background: var(--orange)"></span>
                      <span style="background: var(--green)"></span>
                      <span style="background: #666"></span>
                    </span>
                    <span class="pd-chrome-url">{d.slug}.app</span>
                  </div>
                  <div class="pd-browser-viewport">
                    {isVideo
                      ? <video src={heroSrc} autoplay loop muted playsinline />
                      : <img src={heroSrc} alt={`${d.displayTitle} screenshot`} />
                    }
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>

    <RetroElements type="marquee" />

    <!-- Prose in a window frame -->
    <div class="pd-window">
      <div class="pd-window-bar">
        <span class="pd-window-dots">
          <span style="background: var(--orange)"></span>
          <span style="background: var(--green)"></span>
          <span style="background: #999"></span>
        </span>
        <span class="pd-window-title">{d.slug}_writeup.md</span>
        <span class="pd-window-x">&times;</span>
      </div>
      <div class="pd-window-body pd-prose-body">
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>
  </main>

  <Taskbar active="projects" />
</BaseLayout>

<style is:global>
  .pd-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 6rem 2.5rem 5rem;
  }

  .pd-back {
    margin-bottom: 1.5rem;
  }

  /* Window frame */
  .pd-window {
    border: 1px solid var(--border);
    background: var(--bg-card);
    box-shadow: 4px 4px 0 rgba(0,0,0,0.06);
    margin-bottom: 2rem;
  }

  .pd-window-bar {
    display: flex;
    align-items: center;
    padding: 6px 12px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .pd-window-dots {
    display: flex;
    gap: 5px;
  }

  .pd-window-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .pd-window-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .pd-window-x {
    font-family: var(--font-mono);
    color: var(--text-dim);
    font-size: 1rem;
  }

  .pd-window-body {
    padding: 2rem;
  }

  .pd-prose-body {
    padding: 2rem 2.5rem 2.5rem;
  }

  .pd-layout {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .pd-info {
    flex: 1;
    min-width: 0;
  }

  .pd-mockup {
    flex: 0 0 auto;
  }

  /* Card-style info */
  .pd-index {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.6rem;
  }

  .pd-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: 0.8rem;
  }

  .pd-hook {
    font-family: var(--font-body);
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--text-mid);
    line-height: 1.6;
    margin-bottom: 1.2rem;
  }

  .pd-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 0.5rem;
  }

  .pd-tags span {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border: 1px solid var(--border);
    color: var(--text-dim);
  }

  .pd-location {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  .pd-meta {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-dim);
    padding-top: 0.8rem;
    border-top: 1px solid var(--border);
  }

  /* Phone mockup — tilted right */
  .pd-phone-tilt {
    transform: rotate(6deg);
  }

  .pd-phone {
    width: 220px;
    background: var(--dark);
    border-radius: 24px;
    border: 3px solid #444;
    overflow: hidden;
    box-shadow: 10px 16px 30px rgba(0,0,0,0.18);
  }

  .pd-phone-notch {
    width: 80px;
    height: 5px;
    background: #444;
    border-radius: 0 0 8px 8px;
    margin: 0 auto;
  }

  .pd-phone-screen {
    aspect-ratio: 9 / 16;
    overflow: hidden;
  }

  .pd-phone-screen img,
  .pd-phone-screen video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Browser mockup */
  .pd-browser {
    width: 360px;
    border: 1px solid var(--border);
    overflow: hidden;
    box-shadow: 8px 12px 24px rgba(0,0,0,0.12);
  }

  .pd-browser-chrome {
    background: var(--dark);
    padding: 6px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid #444;
  }

  .pd-chrome-dots {
    display: flex;
    gap: 4px;
  }

  .pd-chrome-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .pd-chrome-url {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #888;
    flex: 1;
    text-align: center;
  }

  .pd-browser-viewport {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .pd-browser-viewport img,
  .pd-browser-viewport video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Prose */
  .prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--text);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .prose h3 {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 0.8rem;
  }

  .prose p {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 300;
    line-height: 1.75;
    margin-bottom: 1.4rem;
    color: var(--text-mid);
  }

  .prose ul,
  .prose ol {
    margin-left: 1.2rem;
    margin-bottom: 1.4rem;
  }

  .prose li {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-mid);
    margin-bottom: 0.5rem;
  }

  .prose strong {
    font-weight: 500;
    color: var(--text);
  }

  .prose em {
    font-style: italic;
  }

  @media (max-width: 768px) {
    .pd-page {
      padding: 5rem 1.5rem 3rem;
    }

    .pd-layout {
      flex-direction: column;
      gap: 2rem;
    }

    .pd-mockup {
      align-self: center;
    }

    .pd-phone {
      width: 180px;
    }

    .pd-browser {
      width: 100%;
    }
  }
</style>
