---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlitchText from '../../components/GlitchText.astro';
import Taskbar from '../../components/Taskbar.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((p) => ({
    params: { slug: p.data.slug },
    props: { project: p, allProjects: sorted },
  }));
}

const { project, allProjects } = Astro.props;
const { Content } = await render(project);
const d = project.data;
const isMobileApp = ['reroute', 'snapp'].includes(d.slug);
const otherProjects = allProjects.filter((p: any) => p.data.slug !== d.slug);
const screenshots = d.screenshots || [];
const screenLabels: Record<string, string[]> = {
  reroute: ['GO MODE', 'EXPLORE MODE', 'WANDER MODE'],
  snapp: ['DAILY PROMPT', 'SHARED MAP', 'PHOTO CAPTURE'],
  planmytrip: ['ITINERARY VIEW', 'WEATHER & DETAILS'],
};
const screens = screenLabels[d.slug] || ['SCREEN 1', 'SCREEN 2'];
---

<BaseLayout title={d.displayTitle} description={d.tagline}>
  <!-- WINDOW TITLE BAR — replaces nav -->
  <div class="pp-titlebar">
    <div class="pp-titlebar-dots">
      <a href="/" class="pp-dot pp-dot--close" aria-label="Close"></a>
      <span class="pp-dot pp-dot--minimize"></span>
      <span class="pp-dot pp-dot--maximize"></span>
    </div>
    <span class="pp-titlebar-name">project_0{d.order}.exe — {d.displayTitle}</span>
  </div>

  <main class="pp">
    <!-- HERO SECTION — inside a window -->
    <div class="pp-section">
      <div class="pp-section-bar">
        <span class="pp-bar-dot"></span>
        <span>project_0{d.order}.exe</span>
      </div>
      <div class="pp-section-body">
        <div class="pp-hero">
          <div class="pp-hero-text">
            <span class="pp-idx">0{d.order}</span>
            <GlitchText text={d.displayTitle} tag="h1" class="pp-title" intensity="bold" interval={3500} playEntrance={true} />
            <p class="pp-hook">{d.hook}</p>
            <div class="pp-tags">
              {d.tags.map((t: string) => <span>{t}</span>)}
            </div>
            {d.type && <div class="pp-loc">{d.type}</div>}
            <div class="pp-meta">{d.status}</div>
          </div>
          <div class="pp-hero-mockup">
            <div class="pp-mockup-viewer">
              {screens.map((label: string, i: number) => (
                isMobileApp ? (
                  <div class="pp-phone">
                    <div class="pp-phone-notch"></div>
                    <div class="pp-phone-screen">
                      {screenshots[i]
                        ? <img src={screenshots[i]} alt={`${d.displayTitle} — ${label}`} />
                        : <div class="pp-ph"><span>{label}</span></div>
                      }
                    </div>
                  </div>
                ) : (
                  <div class="pp-browser-mini">
                    <div class="pp-bbar"><span class="pp-bdots"><span style="background:var(--orange)"></span><span style="background:var(--green)"></span><span style="background:#666"></span></span><span class="pp-burl">{d.slug}.app</span></div>
                    <div class="pp-bview">
                      {screenshots[i]
                        ? <img src={screenshots[i]} alt={`${d.displayTitle} — ${label}`} />
                        : <div class="pp-ph"><span>{label}</span></div>
                      }
                    </div>
                  </div>
                )
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PROSE — each h2 becomes a section window -->
    <div class="pp-prose-zone" data-prose-source>
      <div class="prose"><Content /></div>
    </div>

    <!-- OTHER PROJECTS — file browser -->
    <div class="pp-section">
      <div class="pp-section-bar">
        <span class="pp-bar-dot"></span>
        <span>more_projects/ — {otherProjects.length} items</span>
      </div>
      <div class="pp-section-body pp-files">
        {otherProjects.map((p: any) => (
          <a href={`/projects/${p.data.slug}`} class="pp-file-row">
            <span class="pp-file-icon">&#128193;</span>
            <span class="pp-file-name">{p.data.slug}/</span>
            <span class="pp-file-desc">{p.data.displayTitle} — {p.data.hook.split('.')[0]}.</span>
            <span class="pp-file-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Taskbar />
</BaseLayout>

<script>
  // Split prose into section windows
  document.addEventListener('DOMContentLoaded', () => {
    const zone = document.querySelector('.pp-prose-zone');
    if (!zone) return;
    const prose = zone.querySelector('.prose');
    if (!prose) return;

    const children = Array.from(prose.children);
    const sections: { title: string; els: Element[] }[] = [];
    let cur: { title: string; els: Element[] } | null = null;

    children.forEach(el => {
      if (el.tagName === 'H2') {
        if (cur) sections.push(cur);
        cur = { title: el.textContent || 'Section', els: [] };
      } else if (cur) {
        cur.els.push(el);
      }
    });
    if (cur) sections.push(cur);

    // Replace the prose zone with windowed sections
    zone.innerHTML = '';

    sections.forEach(section => {
      const slug = section.title.toLowerCase().replace(/[^a-z0-9]+/g, '_');

      const wrapper = document.createElement('div');
      wrapper.className = 'pp-section';

      const bar = document.createElement('div');
      bar.className = 'pp-section-bar';
      bar.innerHTML = `<span class="pp-bar-dot"></span><span>${slug}.md</span>`;

      const body = document.createElement('div');
      body.className = 'pp-section-body pp-prose-content';

      const h2 = document.createElement('h2');
      h2.textContent = section.title;
      body.appendChild(h2);
      section.els.forEach(el => body.appendChild(el.cloneNode(true)));

      wrapper.appendChild(bar);
      wrapper.appendChild(body);
      zone.appendChild(wrapper);
    });
  });
</script>

<style is:global>
  /* Page — looks like a maximized window */
  .pp {
    min-height: 100vh;
    background: var(--bg-card);
    box-shadow: inset 0 0 0 1px var(--border);
    padding-bottom: 44px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Window title bar — replaces nav */
  .pp-titlebar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    padding: 8px 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    max-width: 900px;
    margin: 0 auto;
  }

  .pp-titlebar-dots { display: flex; gap: 8px; }

  .pp-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: inline-block;
    border: none;
    text-decoration: none;
  }

  .pp-dot--close { background: #FF5F57; }
  .pp-dot--close:hover { filter: brightness(0.85); }
  .pp-dot--minimize { background: #FFBD2E; }
  .pp-dot--maximize { background: #28C840; }

  .pp-titlebar-name {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    padding-right: 50px;
  }

  /* Content sections — nested windows */
  .pp-section {
    background: var(--bg);
    border: 1px solid var(--border);
    margin: 1.5rem 1.5rem;
  }

  .pp-section-bar {
    padding: 6px 12px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-card);
  }

  .pp-bar-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    display: inline-block;
  }

  .pp-section-body { padding: 1.5rem 2rem; }

  /* Hero layout */
  .pp-hero {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .pp-hero-text { flex: 1; min-width: 0; }
  .pp-hero-mockup { flex: 0 0 auto; }

  .pp-mockup-viewer {
    background: var(--dark);
    border: 1px solid var(--border);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    border-radius: 2px;
  }

  .pp-idx { font-family: var(--font-mono); font-size: 1rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.15em; display: block; margin-bottom: 0.5rem; }
  .pp-title { font-family: var(--font-display); font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; color: var(--text); letter-spacing: -0.03em; line-height: 0.95; margin-bottom: 0.6rem; }
  .pp-hook { font-family: var(--font-body); font-size: 1.15rem; font-weight: 300; color: var(--text-mid); line-height: 1.6; margin-bottom: 1rem; }
  .pp-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 0.4rem; }
  .pp-tags span { font-family: var(--font-mono); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 8px; border: 1px solid var(--border); color: var(--text-dim); }
  .pp-loc { font-family: var(--font-mono); font-size: 0.9rem; color: var(--text-dim); margin-bottom: 0.6rem; }
  .pp-meta { font-family: var(--font-mono); font-size: 0.9rem; color: var(--text-dim); padding-top: 0.6rem; border-top: 1px solid var(--border); }

  /* Phone frames */
  .pp-phone { width: 150px; background: var(--dark); border-radius: 18px; border: 2px solid #555; overflow: hidden; }
  .pp-phone-notch { width: 50px; height: 4px; background: #555; border-radius: 0 0 4px 4px; margin: 0 auto; }
  .pp-phone-screen { aspect-ratio: 9 / 16; overflow: hidden; }
  .pp-phone-screen img { width: 100%; height: 100%; object-fit: cover; }

  /* Browser frames */
  .pp-browser-mini { width: 220px; border: 1px solid #555; overflow: hidden; background: var(--dark); }
  .pp-bbar { padding: 3px 6px; display: flex; align-items: center; gap: 4px; border-bottom: 1px solid #555; }
  .pp-bdots { display: flex; gap: 3px; }
  .pp-bdots span { width: 4px; height: 4px; border-radius: 50%; }
  .pp-burl { font-family: var(--font-mono); font-size: 0.55rem; color: #888; flex: 1; text-align: center; }
  .pp-bview { aspect-ratio: 16 / 10; overflow: hidden; }
  .pp-bview img { width: 100%; height: 100%; object-fit: cover; }

  .pp-ph { width: 100%; height: 100%; background: var(--dark); display: flex; align-items: center; justify-content: center; }
  .pp-phone .pp-ph { aspect-ratio: 9 / 16; }
  .pp-browser-mini .pp-ph { aspect-ratio: 16 / 10; }
  .pp-ph span { font-family: var(--font-mono); font-size: 0.7rem; color: #666; text-transform: uppercase; letter-spacing: 0.1em; }

  /* Prose sections */
  .pp-prose-zone { padding: 0; }

  .pp-prose-content h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 600; color: var(--text); margin-bottom: 0.8rem; }
  .pp-prose-content h3 { font-family: var(--font-display); font-size: clamp(1.1rem, 2vw, 1.4rem); font-weight: 600; color: var(--text); margin-top: 1.5rem; margin-bottom: 0.6rem; }
  .pp-prose-content p { font-family: var(--font-body); font-size: 1.05rem; font-weight: 300; line-height: 1.75; margin-bottom: 1.2rem; color: var(--text-mid); }
  .pp-prose-content ul, .pp-prose-content ol { margin-left: 1.2rem; margin-bottom: 1.2rem; }
  .pp-prose-content li { font-family: var(--font-body); font-size: 1.05rem; font-weight: 300; line-height: 1.75; color: var(--text-mid); margin-bottom: 0.3rem; }
  .pp-prose-content strong { font-weight: 500; color: var(--text); }
  .pp-prose-content em { font-style: italic; }

  /* File browser — other projects */
  .pp-files { padding: 0; }

  .pp-file-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 1.5rem;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }

  .pp-file-row:last-child { border-bottom: none; }
  .pp-file-row:hover { background: var(--bg); }

  .pp-file-icon { font-size: 1.2rem; }
  .pp-file-name { font-family: var(--font-mono); font-size: 0.9rem; font-weight: 600; color: var(--text); min-width: 10ch; }
  .pp-file-desc { font-family: var(--font-body); font-size: 0.9rem; color: var(--text-dim); flex: 1; }
  .pp-file-arrow { font-family: var(--font-mono); color: var(--orange); font-weight: 700; }

  /* Wallpaper — same sky as desktop */
  body:has(.pp) {
    background-color: #87CEEB;
    background-image: linear-gradient(to bottom, #87CEEB 0%, #B8E0F6 50%, #D4ECF7 100%);
    position: relative;
  }

  /* Pixel clouds on the background */
  body:has(.pp)::before,
  body:has(.pp)::after {
    content: '';
    position: fixed;
    background: rgba(255,255,255,0.85);
    z-index: 0;
    image-rendering: pixelated;
    pointer-events: none;
  }

  body:has(.pp)::before {
    top: 12%;
    left: 3%;
    width: 80px;
    height: 16px;
    box-shadow:
      16px -12px 0 0 rgba(255,255,255,0.85),
      28px -20px 0 0 rgba(255,255,255,0.85);
  }

  body:has(.pp)::after {
    top: 25%;
    right: 5%;
    width: 60px;
    height: 12px;
    box-shadow:
      12px -10px 0 0 rgba(255,255,255,0.85);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .pp { max-width: 100%; }
    .pp-titlebar { max-width: 100%; }
    .pp-section { margin: 1rem 0.8rem; }
    .pp-section-body { padding: 1rem 1.2rem; }
    .pp-hero { flex-direction: column; gap: 1.5rem; }
    .pp-hero-mockup { align-self: center; }
    .pp-mockup-viewer { flex-direction: row; overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .pp-phone { width: 120px; }
    .pp-browser-mini { width: 180px; flex-shrink: 0; }
    .pp-file-row { flex-wrap: wrap; }
    .pp-file-desc { width: 100%; }
  }
</style>
