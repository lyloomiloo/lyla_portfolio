---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

// Pixel art icons — clean, recognizable shapes, 2 colors max (fill + transparent)
// G=#00CC55(green), O=#FF6B00(orange), B=#0038FF(blue)
const pixelIcons: Record<string, { cols: number; rows: number; grid: string[][] }> = {
  // Direction arrow — 8×8
  reroute: {
    cols: 8, rows: 8, grid: [
      ['_','_','_','G','G','G','G','G'],
      ['_','_','_','_','G','G','G','G'],
      ['_','_','_','_','_','G','G','G'],
      ['_','_','_','_','G','G','G','_'],
      ['_','_','_','G','G','_','G','_'],
      ['_','_','G','G','_','_','_','_'],
      ['_','G','G','_','_','_','_','_'],
      ['G','G','_','_','_','_','_','_'],
    ]
  },
  // Viewfinder / crosshair — 8×8
  snapp: {
    cols: 8, rows: 8, grid: [
      ['O','O','_','_','_','_','O','O'],
      ['O','_','_','_','_','_','_','O'],
      ['_','_','_','O','O','_','_','_'],
      ['_','_','O','O','O','O','_','_'],
      ['_','_','O','O','O','O','_','_'],
      ['_','_','_','O','O','_','_','_'],
      ['O','_','_','_','_','_','_','O'],
      ['O','O','_','_','_','_','O','O'],
    ]
  },
  // Calendar — 8×10
  planmytrip: {
    cols: 8, rows: 10, grid: [
      ['_','_','B','_','_','B','_','_'],
      ['_','_','B','_','_','B','_','_'],
      ['B','B','B','B','B','B','B','B'],
      ['B','B','B','B','B','B','B','B'],
      ['B','_','_','_','_','_','_','B'],
      ['B','_','B','_','B','_','B','B'],
      ['B','_','_','_','_','_','_','B'],
      ['B','_','B','_','B','_','B','B'],
      ['B','_','_','_','_','_','_','B'],
      ['B','B','B','B','B','B','B','B'],
    ]
  },
};

const iconColors: Record<string, string> = {
  '_': 'transparent',
  'O': '#FF6B00',
  'G': '#00CC55',
  'B': '#0038FF',
};

// Mockup preview config per project
const mockupConfig: Record<string, { label: string; type: 'phone' | 'browser'; image?: string }> = {
  reroute: { label: 'GO MODE', type: 'phone', image: '/images/projects/reroute/preview.jpg' },
  snapp: { label: 'DAILY PROMPT', type: 'phone', image: '/images/projects/snapp/daily_prompt.jpg' },
  planmytrip: { label: 'ITINERARY VIEW', type: 'browser' },
};
---

<div class="pw-grid">
  {projects.map(p => {
    const icon = pixelIcons[p.data.slug];
    const mockup = mockupConfig[p.data.slug];
    return (
      <div class="pw-card" data-open-project={`${p.data.slug}-detail`}>
        {icon && (
          <div class="pw-pixel-icon" style={`grid-template-columns:repeat(${icon.cols},5px);grid-template-rows:repeat(${icon.rows},5px);`}>
            {icon.grid.flat().map(c => <div style={`background:${iconColors[c]};`} />)}
          </div>
        )}
        <span class="pw-num">0{p.data.order}</span>
        <h3 class="pw-title">{p.data.displayTitle}</h3>
        <p class="pw-hook">{p.data.hook}</p>
        <div class="pw-tags">
          {p.data.tags.map((t: string) => <span>{t}</span>)}
        </div>
        {p.data.type && <div class="pw-location">{p.data.type}</div>}
        <div class="pw-meta">{p.data.status}</div>
        <span class="pw-arrow">VIEW PROJECT →</span>

        {mockup && (
          <div class="pw-preview">
            {mockup.type === 'phone' ? (
              <div class="pw-phone-wrap">
                <div class="pw-phone">
                  <div class="pw-phone-notch"></div>
                  <div class="pw-phone-screen">
                    {mockup.image ? (
                      <img src={mockup.image} alt={mockup.label} class="pw-phone-img" />
                    ) : (
                      <span>{mockup.label}</span>
                    )}
                  </div>
                </div>
              </div>
            ) : (
              <div class="pw-phone-wrap">
                <div class="pw-browser">
                  <div class="pw-bbar">
                    <span class="pw-bdot" style="background:#FF6B00"></span>
                    <span class="pw-bdot" style="background:#39FF14"></span>
                    <span class="pw-bdot" style="background:#666"></span>
                    <span class="pw-burl">{p.data.slug}.app</span>
                  </div>
                  <div class="pw-bscreen"><span>{mockup.label}</span></div>
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    );
  })}
</div>

<style is:global>
  .pw-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    height: calc(100% + 3rem);
    margin: -1.5rem;
    cursor: url('/cursor-project.svg') 0 0, crosshair;
  }
  .pw-card {
    background: var(--bg-card);
    padding: 1.5rem 1.5rem 0;
    transition: background 0.15s;
    cursor: url('/cursor-project.svg') 0 0, crosshair;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .pw-card:hover { background: var(--bg); }

  /* Pixel art icon */
  .pw-pixel-icon {
    display: grid;
    image-rendering: pixelated;
    margin-bottom: 0.5rem;
  }
  .pw-pixel-icon div {
    width: 5px;
    height: 5px;
  }

  .pw-num { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-dim); display: block; margin-bottom: 0.3rem; }
  .pw-title { font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 700; color: var(--text); letter-spacing: -0.03em; margin-bottom: 0.4rem; line-height: 1; }
  .pw-hook { font-family: var(--font-body); font-size: 0.9rem; font-weight: 300; color: var(--text-mid); line-height: 1.4; margin-bottom: 0.5rem; }
  .pw-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 0.4rem; }
  .pw-tags span { font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 2px 6px; background: #FF6B00; color: #fff; border: none; }
  .pw-location { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-dim); margin-bottom: 0.3rem; }
  .pw-meta { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-dim); margin-bottom: 0.3rem; }
  .pw-arrow { font-family: var(--font-mono); font-size: 0.85rem; color: var(--orange); font-weight: 700; }

  /* Mockup preview at bottom of card */
  .pw-preview {
    margin-top: auto;
    overflow: hidden;
    flex: 1;
    display: flex;
    align-items: flex-start;
    padding-top: 2rem;
  }

  /* Slide-up wrapper — handles entrance animation */
  .pw-phone-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
    animation: pw-slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.3s;
    opacity: 0;
    perspective: 600px;
  }

  /* Phone frame — handles hover tilt */
  .pw-phone {
    width: 60%;
    background: #1E1E1E;
    border-radius: 20px 20px 0 0;
    border: 5px solid #444;
    border-bottom: none;
    overflow: hidden;
    transition: transform 0.05s steps(1);
  }
  .pw-card:hover .pw-phone {
    transform: rotate(3deg);
  }

  @keyframes pw-slide-up {
    0% { opacity: 0; transform: translateY(100%); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .pw-phone-notch {
    width: 32px;
    height: 3px;
    background: #444;
    border-radius: 0 0 3px 3px;
    margin: 0 auto;
  }
  .pw-phone-screen {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1E1E1E;
  }
  .pw-phone-screen span {
    font-family: var(--font-mono);
    font-size: 0.45rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .pw-phone-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Browser frame */
  .pw-browser {
    width: 100%;
    max-width: 260px;
    background: #1E1E1E;
    border: 1px solid #444;
    overflow: hidden;
  }
  .pw-bbar {
    padding: 3px 5px;
    display: flex;
    align-items: center;
    gap: 3px;
    border-bottom: 1px solid #444;
  }
  .pw-bdot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    display: inline-block;
  }
  .pw-burl {
    font-family: var(--font-mono);
    font-size: 0.45rem;
    color: #666;
    flex: 1;
    text-align: center;
  }
  .pw-bscreen {
    aspect-ratio: 16 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1E1E1E;
  }
  .pw-bscreen span {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 768px) {
    .pw-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
