---
interface Props {
  name: string;
  client: string;
  note: string;
}

const { name, client, note } = Astro.props;
---

<div class="work-tile">
  <div class="work-tile-name">{name}</div>
  <div class="work-tile-client">{client}</div>
  <div class="work-tile-note">{note}</div>
</div>

<style>
  .work-tile {
    background: var(--bg-card);
    padding: 9px 10px;
  }

  .work-tile-name {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .work-tile-client {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .work-tile-note {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--red);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-top: 2px;
  }
</style>
