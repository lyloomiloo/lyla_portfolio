---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<div class="columns-window">
  <!-- Window title bar -->
  <div class="columns-titlebar">
    <span class="columns-dots">
      <span style="background: var(--orange)"></span>
      <span style="background: var(--green)"></span>
      <span style="background: #999"></span>
    </span>
    <span class="columns-title">vibe-coding/ — {projects.length} items</span>
    <span class="columns-view">|||</span>
  </div>

  <!-- Column panels -->
  <div class="columns-body">
    {projects.map((p, i) => (
      <div class={`columns-col ${i === projects.length - 1 ? '' : 'columns-col-border'}`}>
        <ProjectCard
          displayTitle={p.data.displayTitle}
          hook={p.data.hook}
          tags={p.data.tags}
          slug={p.data.slug}
          status={p.data.status}
          order={p.data.order}
          type={p.data.type}
        />
      </div>
    ))}
  </div>
</div>

<style>
  .columns-window {
    border: 1px solid var(--border);
    background: var(--bg-card);
    box-shadow: 4px 4px 0 rgba(0,0,0,0.06);
    overflow: hidden;
  }

  .columns-titlebar {
    display: flex;
    align-items: center;
    padding: 7px 12px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .columns-dots {
    display: flex;
    gap: 5px;
  }

  .columns-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .columns-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .columns-view {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .columns-body {
    display: flex;
  }

  .columns-col {
    flex: 1;
    min-width: 0;
  }

  .columns-col-border {
    border-right: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .columns-body {
      flex-direction: column;
    }

    .columns-col-border {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
  }
</style>
