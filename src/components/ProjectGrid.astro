---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const mobileApps = ['reroute', 'snapp'];
---

<div class="project-scroll">
  {projects.map((p, i) => (
    <div class="project-scroll-item reveal" style={`transition-delay: ${i * 0.1}s;`}>
      <ProjectCard
        displayTitle={p.data.displayTitle}
        hook={p.data.hook}
        tags={p.data.tags}
        slug={p.data.slug}
        status={p.data.status}
        year={p.data.year}
        order={p.data.order}
        thumbnail={p.data.thumbnail}
        mockupType={mobileApps.includes(p.data.slug) ? 'phone' : 'browser'}
      />
    </div>
  ))}
</div>

<style>
  .project-scroll {
    display: flex;
    gap: 1px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    margin: 0 -2.5rem;
    padding: 0 2.5rem;
  }

  .project-scroll::-webkit-scrollbar {
    height: 4px;
  }

  .project-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .project-scroll::-webkit-scrollbar-thumb {
    background: var(--border);
  }

  .project-scroll-item {
    flex: 0 0 min(420px, 85vw);
    scroll-snap-align: start;
    background: var(--bg-card);
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .project-scroll {
      margin: 0 -1.5rem;
      padding: 0 1.5rem;
      gap: 12px;
    }

    .project-scroll-item {
      flex: 0 0 85vw;
    }
  }
</style>
