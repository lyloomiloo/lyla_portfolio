---
interface Props {
  active?: string;
}

const { active = '' } = Astro.props;
---

<nav class="taskbar">
  <span class="taskbar-start">▸</span>
  <a href="/" class={`taskbar-item ${active === 'home' ? 'active' : ''}`}>home.exe</a>
  <a href="/#projects" class={`taskbar-item ${active === 'projects' ? 'active' : ''}`}>projects.exe</a>
  <a href="/#about" class={`taskbar-item ${active === 'about' ? 'active' : ''}`}>about.exe</a>
  <a href="/#skills" class={`taskbar-item ${active === 'skills' ? 'active' : ''}`}>capabilities.dll</a>
  <a href="/#contact" class={`taskbar-item ${active === 'contact' ? 'active' : ''}`}>contact.txt</a>
  <span class="taskbar-clock" data-taskbar-clock></span>
</nav>

<script>
  const clock = document.querySelector('[data-taskbar-clock]');
  function updateClock() {
    if (!clock) return;
    const now = new Date();
    clock.textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 30000);
</script>

<style is:global>
  .taskbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--dark);
    border-top: 2px solid var(--orange);
    display: flex;
    align-items: center;
    padding: 0 1rem;
    height: 34px;
    gap: 0;
  }

  .taskbar-start {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--green);
    padding: 0 14px 0 4px;
    border-right: 1px solid #444;
    margin-right: 4px;
  }

  .taskbar-item {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #888;
    padding: 5px 12px;
    text-decoration: none;
    border-right: 1px solid #333;
    transition: background 0.15s, color 0.15s;
  }

  .taskbar-item:hover { background: #333; color: #ccc; }
  .taskbar-item.active { background: #444; color: var(--green); }

  .taskbar-clock {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #888;
    padding: 0 8px;
  }

  @media (max-width: 768px) {
    .taskbar-item { font-size: 0.65rem; padding: 4px 6px; }
    .taskbar-clock { display: none; }
  }
</style>
