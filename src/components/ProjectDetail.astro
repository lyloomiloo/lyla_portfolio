---
interface Props {
  slug: string;
  order: number;
  title: string;
  hook: string;
  tags: string;
  location: string;
  status: string;
  isMobile: boolean;
  stats: { number: string; label: string }[];
  problem: string;
  approaches: { label: string; desc: string }[];
  features: { title: string; desc: string }[];
  mockups: { label: string; caption: string; video?: string; image?: string }[];
  video?: string;
}

const { slug, order, title, hook, tags, location, status, isMobile, stats, problem, approaches, features, mockups, video } = Astro.props;

const allProjects = [
  { slug: 'reroute', title: 'project_01.exe — (RE)ROUTE', order: 1 },
  { slug: 'snapp', title: 'project_02.exe — SNAPP', order: 2 },
  { slug: 'planmytrip', title: 'project_03.exe — PLANMYTRIP', order: 3 },
];

// 4x4 pixel icons for solution feature items — unique per slug + index
type PxRow = string[];
const featureIcons: Record<string, PxRow[][]> = {
  reroute: [
    // Data points
    [['O','_','O','_'],['_','O','_','O'],['O','_','O','_'],['_','O','_','O']],
    // Magnifier
    [['_','G','G','_'],['G','_','_','G'],['_','G','G','_'],['_','_','_','G']],
    // Shield
    [['B','B','B','B'],['B','B','B','B'],['_','B','B','_'],['_','_','B','_']],
    // Pin
    [['_','O','O','_'],['O','O','O','O'],['_','O','O','_'],['_','_','O','_']],
  ],
  snapp: [
    // No-bell
    [['O','_','_','O'],['_','O','O','_'],['_','O','O','_'],['O','_','_','O']],
    // Clock
    [['_','G','G','_'],['G','_','G','_'],['G','_','_','G'],['_','G','G','_']],
    // Focus
    [['B','_','_','B'],['_','B','B','_'],['_','B','B','_'],['B','_','_','B']],
    // City
    [['O','_','_','O'],['O','O','_','O'],['O','O','O','O'],['O','O','O','O']],
  ],
  planmytrip: [
    // Layout
    [['O','O','_','O'],['O','O','_','O'],['_','_','_','_'],['O','_','O','O']],
    // Sun/weather
    [['_','G','G','_'],['G','G','G','G'],['G','G','G','G'],['_','G','G','_']],
    // Image
    [['B','B','B','B'],['B','_','B','_'],['B','B','_','B'],['B','B','B','B']],
    // Sparkle
    [['_','O','_','O'],['O','O','O','_'],['_','O','O','O'],['O','_','O','_']],
  ],
};

const iconColors: Record<string, string> = {
  '_': 'transparent',
  'O': '#FF6B00',
  'G': '#39FF14',
  'B': '#4A9EFF',
  'W': '#fff',
  'D': '#222',
};

const slugFeatureIcons = featureIcons[slug] || [];
---

<div class="proj-detail" data-proj-detail={slug}>
  <div class="proj-nav">
    {allProjects.map(p => (
      <button
        class={`proj-nav-tab ${p.slug === slug ? 'active' : ''}`}
        data-open-project={p.slug === slug ? undefined : `${p.slug}-detail`}
      >{p.title}</button>
    ))}
  </div>
  <div class="proj-tabs">
    <button class="proj-tab active" data-proj-section="overview">Overview</button>
    <button class="proj-tab" data-proj-section="approach">Design Thinking</button>
  </div>

  <div class="proj-content">
    <!-- OVERVIEW -->
    <div class="proj-section" data-proj-section="overview" style="display:block;">
      <div class="proj-overview">
        <div class="proj-overview-text">
          <h2 class="proj-title">{title}</h2>
          <p class="proj-hook-text">{hook}</p>
          <div class="proj-highlights">
            {stats.map(s => (
              <div class="highlight-stat">
                <span class="stat-number">{s.number}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
          <div class="proj-tags-pills">
            {tags.split('·').map(t => <span class="proj-tag">{t.trim()}</span>)}
          </div>
          <div class="proj-meta-text">{location} · {status}</div>
          <div class="proj-differentiators">
            <div class="feature-list">
              {features.map((f, i) => (
                <div class="feature-item">
                  {slugFeatureIcons[i] ? (
                    <div class="feature-pixel-icon">
                      {slugFeatureIcons[i].flat().map(c => <div style={`background:${iconColors[c]};`} />)}
                    </div>
                  ) : (
                    <span class="feature-icon">&#9670;</span>
                  )}
                  <div>
                    <strong>{f.title}</strong>
                    <p>{f.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="proj-overview-mockup">
          <div class="proj-mockup-viewer">
            {isMobile ? (
              <div class="proj-phone">
                <div class="proj-phone-notch"></div>
                <div class="proj-phone-screen">
                  {video ? (
                    <video src={video} autoplay loop muted playsinline class="proj-phone-video"></video>
                  ) : (
                    <div class="proj-ph"><span>{mockups[0]?.label || 'PREVIEW'}</span></div>
                  )}
                </div>
              </div>
            ) : (
              <div class="proj-browser">
                <div class="proj-bbar"><span class="proj-bdots"><span style="background:var(--orange)"></span><span style="background:var(--green)"></span><span style="background:#666"></span></span><span class="proj-burl">{slug}.app</span></div>
                <div class="proj-bview">
                  {video ? (
                    <video src={video} autoplay loop muted playsinline class="proj-browser-video"></video>
                  ) : (
                    <div class="proj-ph"><span>{mockups[0]?.label || 'PREVIEW'}</span></div>
                  )}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- DESIGN THINKING -->
    <div class="proj-section dt-section" data-proj-section="approach" style="display:none;">
      <div class="dt-problem">
        <h3>Problem</h3>
        <p>{problem}</p>
      </div>

      {approaches.map((a, i) => {
        const m = mockups[i];
        return (
          <div class="dt-pair">
            <div class="dt-pair-mockup">
              {isMobile ? (
                <div class="proj-phone proj-phone--dt">
                  <div class="proj-phone-notch"></div>
                  <div class="proj-phone-screen">
                    {m?.video ? (
                      <video src={m.video} autoplay loop muted playsinline class="proj-phone-video"></video>
                    ) : m?.image ? (
                      <img src={m.image} alt={m.label} class="proj-phone-video" />
                    ) : (
                      <div class="proj-ph"><span>{m?.label || a.label}</span></div>
                    )}
                  </div>
                </div>
              ) : (
                <div class="proj-browser proj-browser--dt">
                  <div class="proj-bbar"><span class="proj-bdots"><span style="background:var(--orange)"></span><span style="background:var(--green)"></span><span style="background:#666"></span></span><span class="proj-burl">{slug}.app</span></div>
                  <div class="proj-bview">
                    {m?.video ? (
                      <video src={m.video} autoplay loop muted playsinline class="proj-browser-video"></video>
                    ) : m?.image ? (
                      <img src={m.image} alt={m.label} class="proj-browser-video" />
                    ) : (
                      <div class="proj-ph"><span>{m?.label || a.label}</span></div>
                    )}
                  </div>
                </div>
              )}
            </div>
            <div class="dt-pair-text">
              <div class="dt-pair-label">{a.label}</div>
              <p class="dt-pair-desc">{a.desc}</p>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</div>

<style is:global>
  .proj-detail { display: flex; flex-direction: column; height: 100%; margin: -1.5rem; }

  .proj-nav { display: flex; background: var(--bg); border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .proj-nav-tab { font-family: var(--font-mono); font-size: 0.72rem; padding: 8px 16px; color: var(--text-dim); background: none; border: none; border-bottom: 2px solid transparent; border-right: 1px solid var(--border); }
  .proj-nav-tab:hover { color: var(--text); background: var(--bg-card); }
  .proj-nav-tab.active { color: var(--text); background: var(--bg-card); border-bottom-color: var(--orange); }

  .proj-tabs { display: flex; border-bottom: 1px solid var(--border); background: var(--bg-card); flex-shrink: 0; }
  .proj-tab { font-family: var(--font-mono); font-size: 0.7rem; padding: 8px 16px; color: var(--text-dim); background: none; border: none; border-bottom: 2px solid transparent; }
  .proj-tab:hover { color: var(--text); }
  .proj-tab.active { color: var(--orange); border-bottom-color: var(--orange); }

  .proj-content { flex: 1; overflow-y: auto; padding: 1.5rem 2rem; background: var(--bg-card); cursor: url('/cursor-project.svg') 0 0, crosshair; scrollbar-width: thin; scrollbar-color: var(--border) var(--bg); }
  .proj-content::-webkit-scrollbar { width: 12px; }
  .proj-content::-webkit-scrollbar-track { background: var(--bg); border-left: 1px solid var(--border); }
  .proj-content::-webkit-scrollbar-thumb { background: var(--border); border: 2px solid var(--bg); min-height: 40px; }
  .proj-content::-webkit-scrollbar-thumb:hover { background: #999; }
  .proj-content::-webkit-scrollbar-button { height: 12px; background: var(--bg); border-left: 1px solid var(--border); }
  .proj-nav, .proj-tabs { cursor: url('/cursor-project.svg') 0 0, crosshair; }

  /* Overview */
  .proj-overview { display: grid; grid-template-columns: 1.2fr 1fr; gap: 2rem; align-items: start; }
  .proj-overview-text { min-width: 0; }
  .proj-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: var(--text); letter-spacing: -0.03em; line-height: 0.95; margin-bottom: 0.6rem; }
  .proj-hook-text { font-family: var(--font-body); font-size: 1.05rem; font-weight: 300; color: var(--text-mid); line-height: 1.6; margin-bottom: 1rem; }
  .proj-highlights { display: flex; gap: 2rem; margin: 1.2rem 0; }
  .highlight-stat { display: flex; flex-direction: column; }
  .stat-number { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 700; color: var(--text); line-height: 1; }
  .stat-label { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); margin-top: 0.3rem; }
  .proj-tags-pills { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 0.5rem; }
  .proj-tag { background: #FF6B00; color: #FFF; border: none; padding: 4px 10px; font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .proj-meta-text { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim); }

  /* Mockup viewer */
  .proj-mockup-viewer { background: transparent; padding: 0; border-radius: 2px; }
  .proj-phone { width: 240px; background: #1E1E1E; border-radius: 26px; border: 4px solid #444; overflow: hidden; margin: 0 auto; }
  .proj-phone-notch { width: 45px; height: 3px; background: #444; border-radius: 0 0 4px 4px; margin: 0 auto; }
  .proj-phone-screen { aspect-ratio: 9 / 19.5; overflow: hidden; }
  .proj-phone--sm { width: 180px; border-radius: 20px; border-width: 3px; }
  .proj-browser { width: 100%; border: 1px solid #555; overflow: hidden; background: var(--dark); }
  .proj-browser--sm { max-width: 320px; }
  .proj-bbar { padding: 3px 6px; display: flex; align-items: center; gap: 4px; border-bottom: 1px solid #555; }
  .proj-bdots { display: flex; gap: 3px; }
  .proj-bdots span { width: 4px; height: 4px; border-radius: 50%; }
  .proj-burl { font-family: var(--font-mono); font-size: 0.55rem; color: #888; flex: 1; text-align: center; }
  .proj-bview { aspect-ratio: 16 / 10; overflow: hidden; }
  .proj-ph { width: 100%; height: 100%; background: var(--dark); display: flex; align-items: center; justify-content: center; aspect-ratio: 9/16; }
  .proj-browser .proj-ph { aspect-ratio: 16/10; }
  .proj-ph span { font-family: var(--font-mono); font-size: 0.65rem; color: #666; text-transform: uppercase; letter-spacing: 0.1em; }
  .proj-phone-video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .proj-browser-video { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Design Thinking — zigzag paired layout */
  .dt-section { padding: 0; }
  .dt-problem { margin-bottom: 1.5rem; padding-bottom: 1.2rem; border-bottom: 1px solid var(--border); }
  .dt-problem h3 { font-size: 0.85rem; font-family: var(--font-mono); color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; }
  .dt-problem p { font-size: 1rem; max-width: 600px; margin: 0; }

  .dt-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px dashed var(--border);
  }
  .dt-pair:last-child { border-bottom: none; }

  /* Alternate layout — flip columns */
  .dt-pair:nth-child(odd) { direction: rtl; }
  .dt-pair:nth-child(odd) > * { direction: ltr; }

  .dt-pair-text { padding: 0 0.5rem; }
  .dt-pair-label {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: #FF6B00;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
  }
  .dt-pair-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-mid);
    margin: 0;
  }
  .dt-pair-mockup { display: flex; justify-content: center; }

  /* Phone/browser sizes inside design thinking pairs */
  .proj-phone--dt { width: 160px; border-radius: 18px; border-width: 3px; }
  .proj-browser--dt { max-width: 280px; }

  /* Feature list */
  .proj-differentiators { margin-top: 1rem; border-top: 1px solid var(--border); padding-top: 0.8rem; }
  .feature-list { display: flex; flex-direction: column; gap: 0.4rem; }
  .feature-item { display: flex; gap: 0.6rem; align-items: flex-start; }
  .feature-icon { color: var(--orange); font-size: 0.7rem; margin-top: 3px; flex-shrink: 0; }
  .feature-pixel-icon {
    display: grid;
    grid-template-columns: repeat(4, 4px);
    grid-template-rows: repeat(4, 4px);
    image-rendering: pixelated;
    flex-shrink: 0;
    margin-top: 4px;
  }
  .feature-pixel-icon div { width: 4px; height: 4px; }
  .feature-item strong { font-family: var(--font-display); font-size: 0.95rem; display: block; margin-bottom: 0.2rem; }
  .feature-item p { font-size: 0.85rem; color: var(--text-mid); line-height: 1.5; margin: 0; }

  .proj-section h3 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 600; color: var(--text); margin-bottom: 0.8rem; }
  .proj-section p { font-family: var(--font-body); font-size: 1rem; font-weight: 300; color: var(--text-mid); line-height: 1.6; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .proj-nav { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .proj-nav-tab { white-space: nowrap; min-height: 44px; padding: 8px 12px; font-size: 0.65rem; }
    .proj-tabs { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .proj-tab { white-space: nowrap; min-height: 44px; padding: 8px 12px; }
    .proj-overview { grid-template-columns: 1fr; }
    .dt-pair { grid-template-columns: 1fr; gap: 1rem; }
    .dt-pair:nth-child(odd) { direction: ltr; }
    .proj-phone--dt { width: 140px; }
    .proj-browser--dt { max-width: 240px; }
    .proj-highlights { flex-direction: column; gap: 0.8rem; }
    .proj-content { padding: 1.2rem; }
  }
</style>
