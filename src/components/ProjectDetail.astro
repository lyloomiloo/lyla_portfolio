---
interface Props {
  slug: string;
  order: number;
  title: string;
  hook: string;
  tags: string;
  location: string;
  status: string;
  isMobile: boolean;
  stats: { number: string; label: string }[];
  problem: string;
  approaches: { label: string; desc: string }[];
  features: { title: string; desc: string }[];
  mockups: { label: string; caption: string; video?: string; image?: string }[];
  gallery?: { src: string; name: string; type: 'video' | 'image' | 'pdf'; preview?: string }[];
  link?: string;
  video?: string;
  appType?: string;
  context?: string;
  year?: string;
}

const { slug, order, title, hook, tags, location, status, isMobile, stats, problem, approaches, features, gallery = [], link, video, appType, context, year } = Astro.props;

const allProjects = [
  { slug: 'reroute', title: 'project_01.exe — (RE)ROUTE', order: 1 },
  { slug: 'snapp', title: 'project_02.exe — SNAPP', order: 2 },
  { slug: 'planmytrip', title: 'project_03.exe — PLANMYTRIP', order: 3 },
];
---

<div class="proj-detail" data-proj-detail={slug}>
  <div class="proj-nav">
    {allProjects.map(p => (
      <button
        class={`proj-nav-tab ${p.slug === slug ? 'active' : ''}`}
        data-open-project={p.slug === slug ? undefined : `${p.slug}-detail`}
      >{p.title}</button>
    ))}
  </div>
  <div class="proj-content">
      <div class="props-main">
        <div class="props-fields">
          <div class="props-file-header">
            <div class="props-file-name">{title}</div>
            {appType && <div class="props-file-kind">{appType}</div>}
          </div>

          <hr class="props-divider" />

          <div class="props-section-label">General</div>
          <div class="props-field">
            <span class="props-key">Info:</span>
            <span class="props-value">
              {tags.split('·').map(t => <span class="props-tag">{t.trim()}</span>)}
            </span>
          </div>
          <div class="props-field">
            <span class="props-key">Location:</span>
            <span class="props-value">{location}</span>
          </div>
          <div class="props-field">
            <span class="props-key">Status:</span>
            <span class="props-value">{status}</span>
          </div>
          {year && (
            <div class="props-field">
              <span class="props-key">Created:</span>
              <span class="props-value">{year}</span>
            </div>
          )}
          {context && (
            <div class="props-field">
              <span class="props-key">Context:</span>
              <span class="props-value">{context}</span>
            </div>
          )}

          <hr class="props-divider" />

          <div class="props-section-label">Stats</div>
          <div class="props-stats-row">
            {stats.map(s => (
              <div class="props-stat">
                <span class="props-stat-num">{s.number}</span>
                <span class="props-stat-label">{s.label}</span>
              </div>
            ))}
          </div>

          <hr class="props-divider" />

          <div class="props-section-label">Description</div>
          <p class="props-desc">{hook}</p>
          {link && (
            <a href={link} target="_blank" rel="noopener noreferrer" class="props-link-btn">
              TRY IT ↗
            </a>
          )}
        </div>

        <div class="props-gallery-panel" data-gallery-panel data-is-mobile={isMobile ? 'true' : 'false'} data-slug={slug}>
          <div class="gallery-preview" data-gallery-preview data-gallery-src={gallery[0]?.src} data-gallery-type={gallery[0]?.type} data-gallery-name={gallery[0]?.name}>
            {gallery.length > 0 && (
              isMobile ? (
                <div class="proj-phone gallery-phone">
                  <div class="proj-phone-notch"></div>
                  <div class="proj-phone-screen">
                    {gallery[0].type === 'video' ? (
                      <video data-lazy-src={gallery[0].src} autoplay loop muted playsinline preload="none" class="proj-phone-video"></video>
                    ) : (
                      <img src={gallery[0].src} alt={gallery[0].name} class="proj-phone-video" />
                    )}
                  </div>
                </div>
              ) : (
                <div class="proj-browser gallery-browser">
                  <div class="proj-bbar"><span class="proj-bdots"><span style="background:var(--orange)"></span><span style="background:var(--green)"></span><span style="background:#666"></span></span><span class="proj-burl">{slug}.app</span></div>
                  <div class={`proj-bview ${gallery[0].type === 'pdf' ? 'proj-bview--scroll' : ''}`}>
                    {gallery[0].type === 'video' ? (
                      <video data-lazy-src={gallery[0].src} autoplay loop muted playsinline preload="none" class="proj-browser-video"></video>
                    ) : gallery[0].type === 'pdf' ? (
                      <iframe src={`${gallery[0].src}#toolbar=0&navpanes=0&scrollbar=1`} class="proj-browser-pdf"></iframe>
                    ) : (
                      <img src={gallery[0].src} alt={gallery[0].name} class="proj-browser-video" />
                    )}
                  </div>
                </div>
              )
            )}
            <span class="gallery-label">{gallery[0]?.name}</span>
          </div>
          <div class="gallery-filmstrip-wrap">
            <button class="gallery-scroll-btn gallery-scroll-left" data-gallery-scroll="-1" aria-label="Scroll left">‹</button>
            <div class="gallery-filmstrip" data-gallery-filmstrip>
              {gallery.slice(1).map(item => (
                <button class="gallery-thumb" data-gallery-src={item.src} data-gallery-type={item.type} data-gallery-name={item.name}>
                  {item.type === 'video' ? (
                    <video data-lazy-src={item.src} muted playsinline preload="none" class="gallery-thumb-media"></video>
                  ) : item.type === 'pdf' ? (
                    item.preview ? (
                      <img src={item.preview} alt={item.name} loading="lazy" class="gallery-thumb-media" />
                    ) : (
                      <div class="gallery-thumb-pdf">PDF</div>
                    )
                  ) : (
                    <img src={item.src} alt={item.name} loading="lazy" class="gallery-thumb-media" />
                  )}
                  <span class="gallery-label">{item.name}</span>
                </button>
              ))}
            </div>
            <button class="gallery-scroll-btn gallery-scroll-right" data-gallery-scroll="1" aria-label="Scroll right">›</button>
          </div>
        </div>

        <div class={`props-col3 ${!isMobile ? 'props-col3--collapsible' : ''}`} data-col3={!isMobile ? 'true' : undefined}>
          {!isMobile && <button class="col3-toggle" data-col3-toggle aria-label="Toggle details panel">›</button>}
          <div class="col3-inner">
            <div class="props-section-label">Problem</div>
            <p class="props-desc">{problem}</p>

            <hr class="props-divider" />

            <div class="props-section-label">Approach</div>
            {approaches.map(a => (
              <div class="props-approach-item">
                <span class="props-approach-label">{a.label}</span>
                <p>{a.desc}</p>
              </div>
            ))}

            <hr class="props-divider" />

            <div class="props-section-label">Differentiators</div>
            {features.map(f => (
              <div class="props-feature-item">
                <span class="props-feature-title">{f.title}</span>
                <p>{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
  </div>
</div>

<style is:global>
  .proj-detail { display: flex; flex-direction: column; height: 100%; margin: -1.5rem; }

  .proj-nav { display: flex; background: var(--bg); border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .proj-nav-tab { font-family: var(--font-mono); font-size: 0.72rem; padding: 10px 16px; color: var(--text-dim); background: none; border: none; border-bottom: 2px solid transparent; border-right: 1px solid var(--border); }
  .proj-nav-tab:hover { color: var(--text); background: var(--bg-card); }
  .proj-nav-tab.active { color: var(--text); background: var(--bg-card); border-bottom-color: var(--orange); }

  .proj-content { flex: 1; overflow-y: auto; background: var(--bg-card); scrollbar-width: thin; scrollbar-color: var(--border) var(--bg); }
  .proj-content::-webkit-scrollbar { width: 12px; }
  .proj-content::-webkit-scrollbar-track { background: var(--bg); border-left: 1px solid var(--border); }
  .proj-content::-webkit-scrollbar-thumb { background: var(--border); border: 2px solid var(--bg); min-height: 40px; }
  .proj-content::-webkit-scrollbar-thumb:hover { background: #999; }
  .proj-content::-webkit-scrollbar-button { height: 12px; background: var(--bg); border-left: 1px solid var(--border); }

  /* ========== GENERAL TAB — 3 columns: fields | mockup | details ========== */
  .props-main {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    height: 100%;
  }

  /* Center panel — floating mockup + filmstrip */
  .props-gallery-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: 1.5rem 2rem;
    gap: 1rem;
    overflow: hidden;
    width: 280px;
    box-sizing: content-box;
  }

  .gallery-preview {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }
  .gallery-phone { width: 200px; }
  .gallery-browser { max-width: 300px; }

  .gallery-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    margin-top: 4px;
    display: block;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .gallery-filmstrip-wrap {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    width: 100%;
    max-width: 100%;
  }
  .gallery-filmstrip {
    display: flex;
    gap: 10px;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 2px;
  }
  .gallery-filmstrip::-webkit-scrollbar { display: none; }
  .gallery-scroll-btn {
    flex-shrink: 0;
    width: 22px;
    height: 60px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: color 0.15s, border-color 0.15s;
  }
  .gallery-scroll-btn:hover { color: var(--orange); border-color: var(--orange); }

  .gallery-thumb {
    width: 60px;
    flex-shrink: 0;
    border: 1px solid var(--border);
    border-radius: 0;
    overflow: hidden;
    cursor: pointer;
    background: var(--bg);
    padding: 0;
    transition: border-color 0.15s, opacity 0.15s;
    opacity: 0.7;
    display: flex;
    flex-direction: column;
  }
  .gallery-thumb:hover { border-color: var(--orange); opacity: 1; }

  .gallery-thumb-media {
    width: 100%;
    height: 60px;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .gallery-thumb .gallery-label {
    padding: 2px 4px;
    font-size: 0.5rem;
    border-top: 1px solid var(--border);
    margin-top: 0;
  }

  /* Right panel — fields */
  .props-fields {
    min-width: 0;
    padding: 1.5rem 2rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .props-file-header {
    margin-bottom: 0.3rem;
  }
  .props-file-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .props-file-kind {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-top: 0.2rem;
  }

  .props-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0.7rem 0;
  }

  /* Collapsible section labels like macOS disclosure triangles */
  .props-section-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .props-section-label::before {
    content: '▸ ';
    color: var(--text-dim);
  }

  /* Field rows */
  .props-field {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 10px;
    padding: 4px 0;
    align-items: baseline;
  }
  .props-key {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    text-align: right;
  }
  .props-value {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text);
  }

  .props-tag {
    background: #FF6B00;
    color: #FFF;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 2px 6px;
    display: inline-block;
    margin: 1px 2px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: none;
  }

  .props-link-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 6px 14px;
    margin-top: auto;
    align-self: flex-end;
    background: var(--orange);
    color: #fff;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }
  .props-link-btn:hover { background: #e55e00; }

  /* Stats row */
  .props-stats-row {
    display: flex;
    gap: 2rem;
    padding: 0.3rem 0;
  }
  .props-stat { text-align: center; }
  .props-stat-num {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    display: block;
    line-height: 1;
    color: var(--text);
  }
  .props-stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-top: 0.3rem;
    display: block;
    white-space: pre-line;
    line-height: 1.2;
  }

  /* PDF in browser frame */
  .proj-bview--scroll {
    aspect-ratio: auto;
    height: 100%;
  }
  .proj-browser-pdf {
    width: 100%;
    height: 100%;
    display: block;
    border: none;
  }
  .gallery-browser { display: flex; flex-direction: column; height: 100%; }
  .gallery-browser .proj-bview { flex: 1; min-height: 0; }
  .gallery-browser .proj-bview--scroll { overflow: hidden; }

  /* When col3 is collapsed, let the gallery panel and browser mockup expand */
  .props-main--expanded .props-gallery-panel { width: auto; }
  .props-main--expanded .gallery-browser { max-width: none; width: 100%; }

  /* PDF thumbnail */
  .gallery-thumb-pdf {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  /* Column 3 */
  .props-col3 {
    padding: 0;
    overflow-y: auto;
    position: relative;
  }
  /* Collapsible variant (desktop non-mobile projects) */
  .props-col3--collapsible {
    transition: width 0.3s ease, min-width 0.3s ease;
    min-width: 220px;
  }
  .props-col3--collapsible.collapsed {
    min-width: 0;
    width: 28px;
    overflow: hidden;
  }
  .props-col3--collapsible.collapsed .col3-inner { opacity: 0; pointer-events: none; }
  .props-col3--collapsible.collapsed .col3-toggle { transform: rotate(180deg); }

  .col3-inner {
    padding: 1.5rem 2rem;
    transition: opacity 0.2s ease;
  }

  .col3-toggle {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
    width: 28px;
    height: 28px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: none;
    border-left: none;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--orange);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }
  .col3-toggle:hover { color: #e55e00; }
  .props-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-mid);
    margin: 0;
  }
  .props-approach-item {
    margin-bottom: 0.6rem;
  }
  .props-approach-label {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--orange);
    display: block;
    margin-bottom: 0.2rem;
  }
  .props-approach-item p {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--text-mid);
    line-height: 1.5;
    margin: 0;
  }

  .props-feature-item {
    margin-bottom: 0.5rem;
  }
  .props-feature-title {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    display: block;
    margin-bottom: 0.15rem;
  }
  .props-feature-item p {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--text-mid);
    line-height: 1.5;
    margin: 0;
  }

  /* ========== Shared mockup frames ========== */
  .proj-phone { width: 240px; background: #1E1E1E; border-radius: 26px; border: 4px solid #444; overflow: hidden; margin: 0 auto; }
  .proj-phone-notch { width: 45px; height: 3px; background: #444; border-radius: 0 0 4px 4px; margin: 0 auto; }
  .proj-phone-screen { aspect-ratio: 9 / 19.5; overflow: hidden; }
  .proj-phone--sm { width: 180px; border-radius: 20px; border-width: 3px; }
  .proj-browser { width: 100%; border: 1px solid #555; overflow: hidden; background: var(--dark); }
  .proj-browser--sm { max-width: 320px; }
  .proj-bbar { padding: 3px 6px; display: flex; align-items: center; gap: 4px; border-bottom: 1px solid #555; }
  .proj-bdots { display: flex; gap: 3px; }
  .proj-bdots span { width: 4px; height: 4px; border-radius: 50%; }
  .proj-burl { font-family: var(--font-mono); font-size: 0.55rem; color: #888; flex: 1; text-align: center; }
  .proj-bview { aspect-ratio: 16 / 10; overflow: hidden; }
  .proj-ph { width: 100%; height: 100%; background: var(--dark); display: flex; align-items: center; justify-content: center; aspect-ratio: 9/16; }
  .proj-browser .proj-ph { aspect-ratio: 16/10; }
  .proj-ph span { font-family: var(--font-mono); font-size: 0.65rem; color: #666; text-transform: uppercase; letter-spacing: 0.1em; }
  .proj-phone-video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .proj-browser-video { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 768px) {
    .proj-nav { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .proj-nav-tab { white-space: nowrap; min-height: 44px; padding: 8px 12px; font-size: 0.65rem; }
    .props-main { grid-template-columns: 1fr; }
    .props-gallery-panel { border-left: none; border-right: none; border-bottom: 1px solid var(--border); padding: 1rem; }
    .gallery-phone { width: 140px; }
    .gallery-browser { max-width: 220px; }
    .gallery-thumb { width: 44px; height: 44px; }
    .props-fields { padding: 1.2rem; }
    .props-field { grid-template-columns: 80px 1fr; }
    .props-col3 { border-left: none; border-top: 1px solid var(--border); }
    .props-col3 .col3-inner { padding: 1.2rem; }
    .col3-toggle { display: none; }
    .props-col3--collapsible { min-width: 0; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-gallery-panel]').forEach(panel => {
      const preview = panel.querySelector('[data-gallery-preview]') as HTMLElement;
      const isMobile = (panel as HTMLElement).dataset.isMobile === 'true';

      const filmstrip = panel.querySelector('[data-gallery-filmstrip]') as HTMLElement;
      panel.querySelectorAll('[data-gallery-scroll]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!filmstrip) return;
          const dir = parseInt((btn as HTMLElement).dataset.galleryScroll || '1', 10);
          filmstrip.scrollBy({ left: dir * 140, behavior: 'smooth' });
        });
      });

      panel.querySelectorAll('.gallery-thumb').forEach(thumb => {
        thumb.addEventListener('click', () => {
          if (!preview) return;
          const btn = thumb as HTMLElement;

          // Capture what's currently in the preview
          const prevSrc = preview.dataset.gallerySrc!;
          const prevType = preview.dataset.galleryType!;
          const prevName = preview.dataset.galleryName!;

          // Capture what's in the clicked thumb
          const newSrc = btn.dataset.gallerySrc!;
          const newType = btn.dataset.galleryType!;
          const newName = btn.dataset.galleryName!;

          // Put new item into the preview frame
          const mediaContainer = isMobile
            ? preview.querySelector('.proj-phone-screen')
            : preview.querySelector('.proj-bview');
          if (mediaContainer) {
            const cls = isMobile ? 'proj-phone-video' : 'proj-browser-video';
            if (newType === 'pdf') {
              mediaContainer.innerHTML = `<iframe src="${newSrc}#toolbar=0&navpanes=0&scrollbar=1" class="proj-browser-pdf"></iframe>`;
              mediaContainer.classList.add('proj-bview--scroll');
            } else {
              mediaContainer.classList.remove('proj-bview--scroll');
              mediaContainer.innerHTML = newType === 'video'
                ? `<video src="${newSrc}" autoplay loop muted playsinline class="${cls}"></video>`
                : `<img src="${newSrc}" alt="${newName}" class="${cls}" />`;
            }
          }
          preview.dataset.gallerySrc = newSrc;
          preview.dataset.galleryType = newType;
          preview.dataset.galleryName = newName;
          const previewLabel = preview.querySelector('.gallery-label');
          if (previewLabel) previewLabel.textContent = newName;

          // Put old preview item into the thumb slot
          const thumbMedia = btn.querySelector('.gallery-thumb-media') || btn.querySelector('.gallery-thumb-pdf');
          if (thumbMedia) {
            let replacement: HTMLElement;
            if (prevType === 'pdf') {
              replacement = document.createElement('div');
              replacement.className = 'gallery-thumb-pdf';
              replacement.textContent = 'PDF';
            } else if (prevType === 'video') {
              replacement = document.createElement('video');
              replacement.setAttribute('src', prevSrc);
              replacement.className = 'gallery-thumb-media';
              (replacement as HTMLVideoElement).muted = true;
              replacement.setAttribute('preload', 'metadata');
              replacement.setAttribute('playsinline', '');
            } else {
              replacement = document.createElement('img');
              replacement.setAttribute('src', prevSrc);
              replacement.className = 'gallery-thumb-media';
              replacement.setAttribute('alt', prevName);
              replacement.setAttribute('loading', 'lazy');
            }
            thumbMedia.replaceWith(replacement);
          }
          btn.dataset.gallerySrc = prevSrc;
          btn.dataset.galleryType = prevType;
          btn.dataset.galleryName = prevName;
          const thumbLabel = btn.querySelector('.gallery-label');
          if (thumbLabel) thumbLabel.textContent = prevName;
        });
      });
    });

    // Col3 collapse toggle + auto-collapse (only for collapsible panels)
    document.querySelectorAll('.props-col3--collapsible[data-col3]').forEach(col3 => {
      const toggle = col3.querySelector('[data-col3-toggle]');
      const propsMain = col3.closest('.props-main') as HTMLElement;
      const fieldsCol = propsMain?.querySelector('.props-fields') as HTMLElement;
      if (!toggle || !propsMain || !fieldsCol) return;

      const collapse = () => {
        // Lock col1 width, give all remaining space to col2
        const col1Width = fieldsCol.offsetWidth;
        propsMain.style.gridTemplateColumns = `${col1Width}px 1fr 28px`;
        propsMain.classList.add('props-main--expanded');
        col3.classList.add('collapsed');
      };
      const expand = () => {
        propsMain.style.gridTemplateColumns = '';
        propsMain.classList.remove('props-main--expanded');
        col3.classList.remove('collapsed');
      };

      toggle.addEventListener('click', () => {
        col3.classList.contains('collapsed') ? expand() : collapse();
      });

      // PlanMyTrip: click the gallery mockup to toggle col3
      const galleryPanel = propsMain.querySelector('[data-gallery-panel][data-slug="planmytrip"]');
      if (galleryPanel) {
        galleryPanel.addEventListener('click', () => {
          col3.classList.contains('collapsed') ? expand() : collapse();
        });
      }
    });
  });
</script>
