---
import DesktopIcon from './DesktopIcon.astro';
---

<div class="desktop">
  <!-- Pixel landscape layers -->
  <div class="landscape">
    <!-- Sky -->
    <div class="sky"></div>
    <!-- Clouds (pixel blocks) -->
    <div class="cloud cloud-1"></div>
    <div class="cloud cloud-2"></div>
    <div class="cloud cloud-3"></div>
    <!-- Sun (decorative only now) -->
    <div class="pixel-sun"></div>
    <!-- Hills -->
    <div class="hill hill-far"></div>
    <div class="hill hill-mid"></div>
    <div class="hill hill-near"></div>
    <!-- Ground -->
    <div class="ground"></div>
    <!-- Pixel trees -->
    <div class="tree tree-1"></div>
    <div class="tree tree-2"></div>
    <div class="tree tree-3"></div>
    <div class="tree tree-4"></div>
    <!-- Pixel flowers scattered on ground -->
    <div class="flower f1"></div>
    <div class="flower f2"></div>
    <div class="flower f3"></div>
    <div class="flower f4"></div>
    <div class="flower f5"></div>
  </div>

  <!-- Name tag -->
  <div class="desktop-nametag">
    <span class="nametag-name">LYLA HUANG</span>
    <span class="nametag-desc">I spent a decade selling stuff for brands. <br> Now, I create products for people.</span>
  </div>

  <!-- Resume overlapping the sun -->
  <DesktopIcon id="resume" label="resume.pdf" icon="resume" top="8.5%" left="81%" />

  <!-- Main nav — matched from user screenshot -->
  <DesktopIcon id="about" label="about.exe" icon="terminal" top="10%" left="16%" />
  <DesktopIcon id="projects" label="projects/" icon="folder" top="28%" left="32%" />
  <DesktopIcon id="skills" label="capabilities.dll" icon="gear" top="17%" left="63%" />
  <DesktopIcon id="contact" label="contact.txt" icon="coffee" top="78%" left="90%" />

  <!-- Easter eggs — scattered sky + meadow -->
  <DesktopIcon id="playlist" label="playlist.m3u" icon="music" top="34%" left="2%" />
  <DesktopIcon id="recycle" label="recycle_bin/" icon="trash" top="3%" left="92%" />
  <DesktopIcon id="todo" label="todo.md" icon="checklist" top="32%" left="90%" />
  <DesktopIcon id="selfie" label="selfie.jpg" icon="image" top="62%" left="30%" />
  <DesktopIcon id="readme" label="readme.txt" icon="notepad" top="58%" left="72%" />

  <!-- Duck click counter -->
  <div class="duck-counter" id="duckCounter">QUACK COUNT: <span id="duckCountNum">000</span></div>

  <!-- Desktop pet duck — walks behind icons (z-index:3, icons are z-index:5) -->
<div class="duck walking" id="deskDuck">
  <!-- Frame 1: feet apart (stride)
       Row 1: _ _ Y Y Y _ _ _   head top
       Row 2: _ _ Y K Y O _ _   head with eye + beak
       Row 3: _ _ Y Y Y _ _ _   neck
       Row 4: Y Y Y Y Y Y _ _   body wide
       Row 5: Y Y Y Y Y Y _ _   body wide
       Row 6: _ Y Y Y Y Y _ _   body
       Row 7: _ _ Y Y Y _ _ _   tail taper
       Row 8: _ _ O _ _ O _ _   feet apart -->
  <div class="duck-frame duck-frame-1">
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#222"></div><div style="background:#FFE066"></div><div style="background:#FF6B00"></div><div></div><div></div>
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
    <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
    <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
    <div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
    <div></div><div></div><div style="background:#FF6B00"></div><div></div><div></div><div style="background:#FF6B00"></div><div></div><div></div>
  </div>
  <!-- Frame 2: feet together (passing) -->
  <div class="duck-frame duck-frame-2">
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#222"></div><div style="background:#FFE066"></div><div style="background:#FF6B00"></div><div></div><div></div>
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
    <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
    <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
    <div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
    <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
    <div></div><div></div><div></div><div style="background:#FF6B00"></div><div style="background:#FF6B00"></div><div></div><div></div><div></div>
  </div>
</div>
</div>

<style is:global>
  .desktop {
    position: fixed;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  /* ========== PIXEL LANDSCAPE ========== */
  .landscape {
    position: absolute;
    inset: 0;
    image-rendering: pixelated;
  }

  .sky {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 65%;
    background: linear-gradient(to bottom, #87CEEB 0%, #B8E0F6 50%, #D4ECF7 100%);
  }

  .pixel-sun {
    position: absolute;
    top: 10%;
    right: 15%;
    width: 40px;
    height: 40px;
    background: #FFE066;
    box-shadow:
      0 0 0 4px #FFD700,
      0 0 0 8px rgba(255,215,0,0.3),
      0 0 40px rgba(255,215,0,0.2);
    image-rendering: pixelated;
  }

  /* Clouds — blocky pixel rectangles */
  .cloud {
    position: absolute;
    background: rgba(255,255,255,0.85);
    image-rendering: pixelated;
  }

  .cloud::before, .cloud::after {
    content: '';
    position: absolute;
    background: rgba(255,255,255,0.85);
  }

  .cloud-1 {
    top: 15%; left: 10%;
    width: 80px; height: 16px;
  }
  .cloud-1::before { width: 48px; height: 16px; top: -12px; left: 16px; }
  .cloud-1::after { width: 32px; height: 12px; top: -20px; left: 28px; }

  .cloud-2 {
    top: 22%; left: 55%;
    width: 60px; height: 12px;
  }
  .cloud-2::before { width: 36px; height: 12px; top: -10px; left: 12px; }

  .cloud-3 {
    top: 12%; left: 40%;
    width: 48px; height: 10px;
  }
  .cloud-3::before { width: 28px; height: 10px; top: -8px; left: 10px; }

  /* Rolling hills */
  .hill {
    position: absolute;
    left: 0; right: 0;
    border-radius: 50% 50% 0 0;
  }

  .hill-far {
    bottom: 30%;
    height: 20%;
    background: #7DB87D;
    opacity: 0.5;
  }

  .hill-mid {
    bottom: 28%;
    height: 18%;
    background: #6AAF6A;
    left: -10%;
    right: -10%;
    opacity: 0.7;
  }

  .hill-near {
    bottom: 25%;
    height: 15%;
    background: #5CA05C;
    left: -5%;
    right: -5%;
  }

  /* Ground */
  .ground {
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    height: 35%;
    background: linear-gradient(to bottom, #5CA05C 0%, #4A8F4A 30%, #3D7A3D 100%);
  }

  /* Pixel trees */
  .tree {
    position: absolute;
    width: 20px;
    height: 32px;
    image-rendering: pixelated;
  }

  .tree::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 8px;
    width: 4px;
    height: 12px;
    background: #8B6B3D;
  }

  .tree::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    background: #2D7A2D;
    border-radius: 2px;
  }

  .tree-1 { bottom: 34%; left: 8%; }
  .tree-2 { bottom: 36%; left: 25%; height: 40px; }
  .tree-2::after { width: 24px; height: 26px; left: -2px; }
  .tree-2::before { height: 14px; }
  .tree-3 { bottom: 33%; right: 20%; }
  .tree-4 { bottom: 35%; right: 35%; height: 36px; }
  .tree-4::after { width: 22px; height: 24px; left: -1px; background: #267326; }
  .tree-4::before { height: 12px; }

  /* Pixel flowers on the ground */
  .flower {
    position: absolute;
    width: 4px;
    height: 4px;
    image-rendering: pixelated;
  }

  .flower::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    width: 4px;
    height: 6px;
    background: #4A8F4A;
  }

  .f1 { bottom: 30%; left: 15%; background: #FF6B00; }
  .f2 { bottom: 28%; left: 45%; background: #FFE066; }
  .f3 { bottom: 32%; right: 30%; background: #FF6B00; }
  .f4 { bottom: 26%; right: 15%; background: #FFE066; }
  .f5 { bottom: 29%; left: 60%; background: #FF6B00; }

  /* ========== DESKTOP PET DUCK ========== */
  .duck {
    position: absolute;
    bottom: 34%;
    left: 200px;
    z-index: 3;
    image-rendering: pixelated;
  }

  .duck-frame {
    display: grid;
    grid-template-columns: repeat(8, 6px);
    grid-template-rows: repeat(8, 6px);
    image-rendering: pixelated;
    position: absolute;
    top: 0; left: 0;
  }
  .duck-frame div {
    width: 6px;
    height: 6px;
  }

  /* Frame toggling — JS adds/removes .frame-2 */
  .duck-frame-2 { opacity: 0; }
  .duck.frame-2 .duck-frame-1 { opacity: 0; }
  .duck.frame-2 .duck-frame-2 { opacity: 1; }

  /* Reserve space for the sprite */
  .duck { width: 48px; height: 48px; position: absolute; }

  .duck.idle .duck-frame {
    animation: duck-idle 1s steps(2) infinite;
  }

  .duck.struggling {
    cursor: grabbing;
  }
  .duck.struggling .duck-frame {
    animation: duck-struggle 0.12s steps(2) infinite;
  }

  @keyframes duck-idle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-1px); }
  }

  @keyframes duck-struggle {
    0% { transform: rotate(-8deg) translateX(-2px); }
    25% { transform: rotate(6deg) translateX(2px); }
    50% { transform: rotate(-5deg) translateX(-1px); }
    75% { transform: rotate(7deg) translateX(1px); }
  }

  @keyframes duck-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes duck-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-3px); }
    75% { transform: translateX(3px); }
  }

  @keyframes duck-peck {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  @keyframes duck-land {
    0% { transform: scaleY(0.7) scaleX(1.2); }
    50% { transform: scaleY(1.1) scaleX(0.9); }
    100% { transform: scaleY(1) scaleX(1); }
  }

  @keyframes duck-sneeze {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(15px) scaleX(1.2); }
  }
  @keyframes duck-wave {
    0%, 100% { transform: rotate(0); }
    50% { transform: rotate(-10deg); }
  }
  @keyframes duck-dizzy {
    to { transform: rotate(1080deg); }
  }
  @keyframes duck-angry {
    0% { transform: translate(-1px, -1px); }
    100% { transform: translate(1px, 1px); }
  }

  /* Duck click counter */
  .duck-counter {
    position: fixed;
    top: 12px;
    left: 12px;
    z-index: 7;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: #888;
    pointer-events: none;
  }

  /* Name tag — small, bottom-left */
  .desktop-nametag {
    position: absolute;
    bottom: 80px;
    left: 16px;
    z-index: 3;
  }

  .nametag-name {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 1px 1px 3px rgba(0,0,0,0.5);
    display: block;
    letter-spacing: 0.05em;
  }

  .nametag-desc {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.5);
    text-shadow: 1px 1px 2px rgba(0,0,0,0.4);
    max-width: 320px;
    line-height: 1.5;
    margin-top: 0.4rem;
  }


  /* Icon labels — white with shadow for sky readability */
  .desktop-icon-label {
    color: #fff;
    text-shadow: 1px 1px 3px rgba(0,0,0,0.6);
  }

  @media (max-width: 768px) {
    .desktop-nametag { bottom: 72px; left: 10px; }
    .nametag-name { font-size: 0.8rem; }
    .pixel-sun { width: 24px; height: 24px; }
    .cloud { transform: scale(0.7); }
    .tree { transform: scale(0.8); }
  }
</style>
