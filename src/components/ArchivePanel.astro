---
import WorkTile from './WorkTile.astro';

const works = [
  { name: 'Scoot is F*cking Savage', client: 'Scoot · BLKJ', note: '4× Award Winner' },
  { name: 'Onward', client: 'MCI · BLKJ', note: 'National TVC · COVID-19' },
  { name: 'Passion Stories', client: 'Made With Passion · BLKJ', note: 'Brand Film Series' },
  { name: 'Pun with FairPrice', client: 'FairPrice · Havas', note: 'Gold · Markies 2017' },
  { name: 'See It Before The Hipsters', client: 'Scoot · BLKJ', note: 'Brand Film' },
  { name: 'Inflight Amusement', client: 'Scoot · BLKJ', note: 'Video Series' },
];

const awards = [
  { type: 'Rising Star', event: 'Creative Circles \'18' },
  { type: 'Gold', event: 'Markies \'17' },
  { type: '2S + 3B', event: 'Creative Circles \'18' },
  { type: 'Grand Prize', event: 'IG Cannes \'16' },
];
---

<div class="archive-panel">
  <h3 class="archive-headline">10 YEARS IN ADVERTISING</h3>
  <p class="archive-trail">
    <strong>BLKJ</strong> / <strong>Google</strong> / <strong>Havas</strong> / <strong>Freelance</strong>
  </p>
  <p class="archive-trail">Singapore &rarr; APAC &rarr; Barcelona</p>

  <div class="work-grid">
    {works.map(w => <WorkTile name={w.name} client={w.client} note={w.note} />)}
  </div>

  <div class="awards-row">
    {awards.map(a => (
      <span class="award-chip"><span class="award-type">{a.type}</span> &middot; {a.event}</span>
    ))}
  </div>
</div>

<style>
  .archive-panel {
    background: var(--bg-card);
    padding: 1.8rem;
  }

  .archive-headline {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .archive-trail {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 0.3rem;
  }

  .archive-trail strong {
    color: var(--text);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    margin-top: 1.2rem;
    margin-bottom: 1.2rem;
  }

  .awards-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.2rem;
    border-top: 1px solid var(--border);
    padding-top: 0.7rem;
  }

  .award-chip {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
  }

  .award-type {
    color: var(--red);
  }

  @media (max-width: 768px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
