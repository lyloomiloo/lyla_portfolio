---
interface Props {
  variant: 'hero' | 'contact' | 'section';
}

interface Artifact {
  type: 'square' | 'xbutton' | 'scrollbar' | 'smiley';
  color?: string;
  size?: number;
  height?: number;
  top?: string;
  right?: string;
  bottom?: string;
  left?: string;
  opacity?: number;
}

const { variant } = Astro.props;

const configs: Record<string, Artifact[]> = {
  hero: [
    { type: 'square', color: 'var(--orange)', size: 10, top: '20%', right: '20%', opacity: 1 },
    { type: 'square', color: 'var(--green)', size: 10, top: '32%', right: '10%', opacity: 0.8 },
    { type: 'square', color: '#999', size: 8, top: '60%', right: '30%', opacity: 0.4 },
    { type: 'square', color: 'var(--text)', size: 6, top: '44%', right: '5%', opacity: 0.3 },
    { type: 'xbutton', top: '27%', right: '34%', opacity: 0.6 },
    { type: 'xbutton', top: '52%', right: '16%', opacity: 0.4 },
    { type: 'scrollbar', height: 50, top: '36%', right: '42%', opacity: 0.3 },
    { type: 'square', color: 'var(--orange)', size: 6, top: '72%', right: '38%', opacity: 0.5 },
    { type: 'square', color: 'var(--green)', size: 6, bottom: '18%', right: '7%', opacity: 0.6 },
    { type: 'smiley', top: '45%', right: '25%', opacity: 0.4 },
  ],
  contact: [
    { type: 'square', color: 'var(--orange)', size: 10, top: '-6px', right: '-6px', opacity: 1 },
    { type: 'square', color: 'var(--green)', size: 6, bottom: '-5px', left: '-5px', opacity: 0.8 },
    { type: 'square', color: '#999', size: 4, top: '50%', right: '-10px', opacity: 0.4 },
  ],
  section: [
    { type: 'square', color: 'var(--orange)', size: 6, top: '10%', right: '3%', opacity: 0.5 },
    { type: 'xbutton', top: '80%', right: '5%', opacity: 0.3 },
  ],
};

const artifacts = configs[variant] || [];

function buildStyle(a: Artifact): string {
  let s = 'position:absolute;pointer-events:none;';
  if (a.top) s += `top:${a.top};`;
  if (a.right) s += `right:${a.right};`;
  if (a.bottom) s += `bottom:${a.bottom};`;
  if (a.left) s += `left:${a.left};`;
  if (a.opacity !== undefined) s += `opacity:${a.opacity};`;

  if (a.type === 'square') {
    s += `width:${a.size}px;height:${a.size}px;background:${a.color || '#999'};image-rendering:pixelated;`;
  } else if (a.type === 'xbutton') {
    s += 'width:13px;height:13px;border:1px solid var(--border);background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:8px;color:#CCC;line-height:1;';
  } else if (a.type === 'scrollbar') {
    s += `width:8px;height:${a.height || 50}px;background:repeating-linear-gradient(0deg,var(--border) 0px,var(--border) 1px,transparent 1px,transparent 3px);`;
  } else if (a.type === 'smiley') {
    s += 'font-family:var(--font-mono);font-size:10px;color:var(--text-dim);';
  }
  return s;
}

const rendered = artifacts.map(a => ({
  ...a,
  style: buildStyle(a),
}));
---

<div class="pixel-artifacts" data-parallax="slow">
  {rendered.map((a) => (
    a.type === 'xbutton'
      ? <div class="artifact" style={a.style}>&times;</div>
      : a.type === 'smiley'
        ? <span class="artifact" style={a.style}>:)</span>
        : <div class="artifact" style={a.style} />
  ))}
</div>

<style>
  .pixel-artifacts {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .pixel-artifacts {
      display: none;
    }
  }
</style>
