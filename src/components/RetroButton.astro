---
interface Props {
  href: string;
  text: string;
  variant?: 'purple' | 'yellow' | 'outline';
  target?: string;
}

const { href, text, variant = 'purple', target } = Astro.props;
---

<a href={href} class={`retro-btn retro-btn-${variant}`} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined}>{text}</a>

<style>
  .retro-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 8px 16px;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.1s;
    text-decoration: none;
  }

  .retro-btn-purple {
    background: var(--purple);
    color: var(--yellow);
    border: 2px solid var(--purple);
    border-top-color: rgba(255,255,255,0.2);
    border-left-color: rgba(255,255,255,0.2);
    border-bottom-color: rgba(0,0,0,0.3);
    border-right-color: rgba(0,0,0,0.3);
  }

  .retro-btn-yellow {
    background: var(--yellow);
    color: var(--dark);
    border: 2px solid var(--yellow);
    border-top-color: rgba(255,255,255,0.4);
    border-left-color: rgba(255,255,255,0.4);
    border-bottom-color: rgba(0,0,0,0.2);
    border-right-color: rgba(0,0,0,0.2);
  }

  .retro-btn-outline {
    background: transparent;
    color: var(--purple);
    border: 2px solid var(--purple);
  }

  .retro-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 0 var(--dark);
  }

  .retro-btn:active {
    transform: translateY(1px);
    box-shadow: none;
  }
</style>
