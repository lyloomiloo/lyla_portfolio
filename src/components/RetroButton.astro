---
interface Props {
  href: string;
  text: string;
  target?: string;
}

const { href, text, target } = Astro.props;
---

<a href={href} class="retro-btn" target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined}>{text}</a>

<style>
  .retro-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 8px 16px;
    cursor: pointer;
    text-decoration: none;
    background: transparent;
    color: var(--text);
    border: 2px solid var(--text);
    transition: background 0.15s, color 0.15s, transform 0.1s;
  }

  .retro-btn:hover {
    background: var(--text);
    color: var(--bg);
    transform: translateY(-1px);
  }

  .retro-btn:active {
    transform: translateY(1px);
  }
</style>
