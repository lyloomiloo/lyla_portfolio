---
import PixelArtifacts from './PixelArtifacts.astro';
---

<div class="contact-box">
  <PixelArtifacts variant="contact" />
  <p class="contact-line"><a href="mailto:lyla.huangyanling@gmail.com">lyla.huangyanling@gmail.com</a></p>
  <p class="contact-line"><a href="https://linkedin.com/in/lylahuang" target="_blank" rel="noopener noreferrer">linkedin.com/in/lylahuang</a></p>
  <p class="contact-line">Barcelona, ES</p>
  <div class="contact-status">Open to product, UX, and strategy roles.</div>
</div>

<style>
  .contact-box {
    border: 1px solid var(--green);
    padding: 1.8rem;
    max-width: 380px;
    background: var(--bg-card);
    position: relative;
  }

  .contact-line {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .contact-line a {
    color: var(--text);
    border-bottom: 1px solid var(--border);
    transition: border-color 0.2s;
  }

  .contact-line a:hover {
    border-color: var(--green);
  }

  .contact-status {
    margin-top: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--green);
    letter-spacing: 0.04em;
  }
</style>
