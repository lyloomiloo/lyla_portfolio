---
import PixelArtifacts from './PixelArtifacts.astro';
import RetroButton from './RetroButton.astro';
---

<div class="contact-box">
  <PixelArtifacts variant="contact" />
  <div class="contact-buttons">
    <RetroButton href="mailto:lyla.huangyanling@gmail.com" text="lyla.huangyanling@gmail.com" />
    <RetroButton href="https://linkedin.com/in/lylahuang" text="linkedin.com/in/lylahuang" target="_blank" />
  </div>
  <p class="contact-location">Barcelona, ES</p>
  <div class="contact-status">Open to product, UX, and strategy roles.</div>
</div>

<style>
  .contact-box {
    border: 2px solid var(--green);
    padding: 1.8rem;
    max-width: 480px;
    background: var(--bg-card);
    position: relative;
  }

  .contact-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .contact-location {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .contact-status {
    margin-top: 1.2rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--orange);
    letter-spacing: 0.04em;
  }
</style>
