---
const avatar = [
  ['_','_','H','H','H','H','_','_'],
  ['_','H','H','H','H','H','H','_'],
  ['_','H','S','S','S','S','H','_'],
  ['_','S','E','S','S','E','S','_'],
  ['_','S','S','S','S','S','S','_'],
  ['_','S','S','M','M','S','S','_'],
  ['_','_','S','S','S','S','_','_'],
  ['_','_','_','S','S','_','_','_'],
];
const avatarColors: Record<string, string> = {
  '_': 'transparent', 'S': '#F4C89A', 'H': '#222', 'E': '#222', 'M': '#FF6B00',
};
---

<div class="phone-lock" id="phoneLockScreen">
  <div class="phone-lock-content">
    <div class="phone-lock-time" data-phone-lock-clock></div>
    <div class="phone-lock-date" data-phone-lock-date></div>
    <div class="phone-lock-avatar">
      {avatar.flat().map(c => <div style={`background:${avatarColors[c]};`} />)}
    </div>
    <div class="phone-lock-name">LYLA HUANG</div>
    <div class="phone-lock-hint">tap to unlock</div>
  </div>
</div>

<noscript>
  <style>.phone-lock { display: none !important; }</style>
</noscript>

<style is:global>
  .phone-lock {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: transform 0.4s ease, opacity 0.4s ease;
  }
  .phone-lock-content {
    text-align: center;
    transition: opacity 0.3s ease;
  }
  .phone-lock-time {
    font-family: var(--font-mono);
    font-size: 4rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .phone-lock-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
    margin-bottom: 2rem;
  }
  .phone-lock-avatar {
    width: 64px;
    height: 64px;
    margin: 0 auto 1rem;
    display: grid;
    grid-template-columns: repeat(8, 8px);
    grid-template-rows: repeat(8, 8px);
    image-rendering: pixelated;
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    overflow: hidden;
    background: #333;
  }
  .phone-lock-avatar div {
    width: 8px;
    height: 8px;
  }
  .phone-lock-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .phone-lock-hint {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.05em;
    animation: phone-lock-pulse 2s ease-in-out infinite;
  }
  @keyframes phone-lock-pulse {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 0.7; }
  }

  .phone-lock.dismissing {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
  }

  /* Skip on return visits */
  .skip-lock .phone-lock { display: none !important; }

  /* Hide on desktop */
  @media (min-width: 769px) {
    .phone-lock { display: none !important; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const lock = document.getElementById('phoneLockScreen');
    if (!lock || lock.style.display === 'none') return;

    // Clock
    function updateLockClock() {
      const timeEl = lock.querySelector('[data-phone-lock-clock]');
      const dateEl = lock.querySelector('[data-phone-lock-date]');
      const now = new Date();
      if (timeEl) timeEl.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      if (dateEl) {
        dateEl.textContent = now.toLocaleDateString([], { weekday: 'long', month: 'long', day: 'numeric' });
      }
    }
    updateLockClock();
    const clockInterval = setInterval(updateLockClock, 30000);

    // Dismiss on tap
    function dismiss() {
      lock.classList.add('dismissing');
      sessionStorage.setItem('lyla-visited', 'true');
      clearInterval(clockInterval);
      setTimeout(() => {
        lock.style.display = 'none';
      }, 400);
    }

    lock.addEventListener('click', dismiss);
    lock.addEventListener('touchend', (e) => {
      e.preventDefault();
      dismiss();
    }, { passive: false });
  });
</script>
