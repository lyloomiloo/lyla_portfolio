---
---

<div class="phone-lock" id="phoneLockScreen">
  <div class="phone-lock-clock">
    <div class="phone-lock-time" data-phone-lock-clock></div>
    <div class="phone-lock-date" data-phone-lock-date></div>
  </div>
  <div class="phone-lock-bottom">
    <div class="phone-lock-name">LYLA HUANG</div>
    <div class="phone-lock-swipe">&#9650; swipe up to unlock</div>
  </div>
</div>

<noscript>
  <style>.phone-lock { display: none !important; }</style>
</noscript>

<style is:global>
  .phone-lock {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: calc(15vh + env(safe-area-inset-top, 0px));
    padding-bottom: calc(2rem + env(safe-area-inset-bottom, 0px));
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    touch-action: pan-y;
  }

  .phone-lock-clock {
    text-align: center;
  }
  .phone-lock-time {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 15vw, 5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .phone-lock-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #888;
    margin-top: 0.3rem;
  }

  .phone-lock-bottom {
    margin-top: auto;
    text-align: center;
  }
  .phone-lock-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #666;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }
  .phone-lock-swipe {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #555;
    animation: swipe-hint 2s ease-in-out infinite;
  }
  @keyframes swipe-hint {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(-6px); opacity: 1; }
  }

  /* Skip on return visits */
  .skip-lock .phone-lock { display: none !important; }

  /* Hide on desktop */
  @media (min-width: 769px) {
    .phone-lock { display: none !important; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const lock = document.getElementById('phoneLockScreen');
    if (!lock || lock.style.display === 'none') return;

    // Clock
    function updateLockClock() {
      const timeEl = lock.querySelector('[data-phone-lock-clock]');
      const dateEl = lock.querySelector('[data-phone-lock-date]');
      const now = new Date();
      if (timeEl) timeEl.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      if (dateEl) {
        dateEl.textContent = now.toLocaleDateString([], { weekday: 'long', month: 'long', day: 'numeric' });
      }
    }
    updateLockClock();
    const clockInterval = setInterval(updateLockClock, 30000);

    function dismiss() {
      lock.style.transition = 'transform 0.3s ease';
      lock.style.transform = 'translateY(-100%)';
      sessionStorage.setItem('lyla-visited', 'true');
      clearInterval(clockInterval);
      setTimeout(() => { lock.style.display = 'none'; }, 300);
    }

    // Swipe up to dismiss
    let touchStartY = 0;
    lock.addEventListener('touchstart', (e) => {
      touchStartY = e.touches[0].clientY;
      lock.style.transition = 'none';
    }, { passive: true });

    lock.addEventListener('touchmove', (e) => {
      const diff = touchStartY - e.touches[0].clientY;
      if (diff > 0) {
        lock.style.transform = `translateY(${-diff}px)`;
      }
    }, { passive: true });

    lock.addEventListener('touchend', (e) => {
      const diff = touchStartY - e.changedTouches[0].clientY;
      if (diff > 80) {
        dismiss();
      } else {
        lock.style.transition = 'transform 0.2s ease';
        lock.style.transform = 'translateY(0)';
      }
    });

    // Tap fallback
    lock.addEventListener('click', dismiss);
  });
</script>
