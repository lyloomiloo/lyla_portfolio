---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  dark?: boolean;
  class?: string;
}

const { size = 'md', dark = false, class: className = '' } = Astro.props;

// O=orange, W=white, _=transparent
const grid = [
  ['O','_','_','_','_','_','_'],
  ['O','O','_','_','_','_','_'],
  ['O','W','O','_','_','_','_'],
  ['O','W','W','O','_','_','_'],
  ['O','W','W','W','O','_','_'],
  ['O','W','W','W','W','O','_'],
  ['O','W','W','O','O','O','O'],
  ['O','O','W','O','_','_','_'],
  ['O','_','O','W','O','_','_'],
  ['_','_','_','O','O','_','_'],
];

const colorMap: Record<string, string> = {
  O: 'px-o',
  W: 'px-w',
  _: 'px-t',
};
---

<div class={`pixel-cursor pixel-cursor--${size} ${dark ? 'pixel-cursor--dark' : ''} ${className}`}>
  <div class="pixel-cursor-grid">
    {grid.flat().map(c => <div class={`px ${colorMap[c]}`} />)}
  </div>
  <div class="pixel-cursor-click-dot"></div>
</div>

<script>
  document.querySelectorAll('.pixel-cursor').forEach(el => {
    el.addEventListener('mouseenter', () => {
      const grid = el.querySelector('.pixel-cursor-grid') as HTMLElement;
      const dot = el.querySelector('.pixel-cursor-click-dot') as HTMLElement;
      if (grid) { grid.style.animation = 'none'; requestAnimationFrame(() => { grid.style.animation = ''; }); }
      if (dot) { dot.style.animation = 'none'; requestAnimationFrame(() => { dot.style.animation = ''; }); }
    });
  });
</script>

<style>
  .pixel-cursor {
    position: relative;
    display: inline-block;
    image-rendering: pixelated;
  }

  .pixel-cursor--dark {
    background: var(--dark);
    padding: 12px;
  }

  .pixel-cursor-grid {
    display: grid;
    animation: cursor-click 3.5s ease infinite;
  }

  /* Sizes */
  .pixel-cursor--sm .pixel-cursor-grid { grid-template-columns: repeat(7, 3px); gap: 1px; }
  .pixel-cursor--sm .px { width: 3px; height: 3px; }

  .pixel-cursor--md .pixel-cursor-grid { grid-template-columns: repeat(7, 8px); gap: 2px; }
  .pixel-cursor--md .px { width: 8px; height: 8px; }

  .pixel-cursor--lg .pixel-cursor-grid { grid-template-columns: repeat(7, 12px); gap: 2px; }
  .pixel-cursor--lg .px { width: 12px; height: 12px; }

  /* Colors */
  .px-o { background: var(--orange); }
  .px-w { background: #fff; }
  .px-t { background: transparent; }

  /* Click animation */
  @keyframes cursor-click {
    0%, 85%, 100% { transform: translate(0, 0); }
    88% { transform: translate(2px, 2px); }
    92% { transform: translate(2px, 2px); }
    95% { transform: translate(0, 0); }
  }

  /* Click dot */
  .pixel-cursor-click-dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    opacity: 0;
    animation: click-dot 3.5s ease infinite;
  }

  .pixel-cursor--sm .pixel-cursor-click-dot { width: 3px; height: 3px; }
  .pixel-cursor--lg .pixel-cursor-click-dot { width: 8px; height: 8px; }

  @keyframes click-dot {
    0%, 87%, 96%, 100% { opacity: 0; transform: scale(0); }
    90% { opacity: 1; transform: scale(1); }
    93% { opacity: 0.5; transform: scale(2); }
  }
</style>
