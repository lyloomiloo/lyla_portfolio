---
import GlitchText from './GlitchText.astro';
---
<section id="hero" class="hero">
  <div class="hero-content">
    <GlitchText text="LYLA\nHUANG." tag="h1" class="hero-title reveal" intensity="bold" interval={3000} playEntrance={true} />
    <p class="hero-sub reveal" style="transition-delay: 0.08s;">Strategist &rarr; Builder</p>
    <p class="hero-desc reveal" style="transition-delay: 0.16s;">
      I spent a decade turning noise into signal for brands.
      Now I design and build the products myself —
      using AI as a collaborator, not a crutch.
    </p>
  </div>
</section>

<style is:global>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 0 3rem;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 22rem);
    font-weight: 700;
    color: var(--text);
    line-height: 0.85;
    letter-spacing: -0.05em;
    padding: 0 0.5rem;
    width: 100%;
    display: block;
  }

  .hero-sub {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    color: var(--text-dim);
    margin-top: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding-left: 1.5rem;
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--text-mid);
    max-width: 520px;
    margin-top: 0.8rem;
    line-height: 1.7;
    padding-left: 1.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 2rem;
    }

    .hero-title {
      font-size: clamp(4rem, 18vw, 10rem);
    }

    .hero-desc {
      font-size: 1.1rem;
      padding-left: 1rem;
    }

    .hero-sub {
      padding-left: 1rem;
    }
  }
</style>
