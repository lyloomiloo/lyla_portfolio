---
import GlitchText from './GlitchText.astro';
import RetroButton from './RetroButton.astro';

interface Props {
  displayTitle: string;
  hook: string;
  tags: string[];
  slug: string;
  status: string;
  year: string;
  order: number;
  thumbnail?: string;
  mockupType?: 'phone' | 'browser';
}

const { displayTitle, hook, tags, slug, status, year, order, thumbnail, mockupType = 'browser' } = Astro.props;
---

<article class="project-card">
  <span class="project-index-watermark">0{order}</span>
  <span class="project-index">0{order}</span>
  {mockupType === 'phone' ? (
    <div class="phone-frame">
      <div class="phone-notch"></div>
      <div class="phone-status">
        <span>9:41</span>
        <span class="phone-icons">● ● ●</span>
      </div>
      <div class="phone-screen">
        {thumbnail
          ? <img src={thumbnail} alt={`${displayTitle} preview`} />
          : <span class="project-mockup-placeholder">&gt;_ {displayTitle.toLowerCase()}</span>
        }
      </div>
    </div>
  ) : (
    <div class="mockup-frame">
      <div class="mockup-chrome">
        <span class="chrome-dots">
          <span style="background: var(--orange)"></span>
          <span style="background: var(--green)"></span>
          <span style="background: #666"></span>
        </span>
        <span class="chrome-url">{slug}.app</span>
      </div>
      <div class="project-mockup">
        {thumbnail
          ? <img src={thumbnail} alt={`${displayTitle} preview`} />
          : <span class="project-mockup-placeholder">&gt;_ {displayTitle.toLowerCase()}</span>
        }
      </div>
    </div>
  )}
  <GlitchText text={displayTitle} tag="h3" class="project-name" intensity="bold" interval={4000 + order * 500} />
  <p class="project-hook">{hook}</p>
  <div class="project-tags">
    {tags.map(t => <span>{t}</span>)}
  </div>
  <RetroButton href={`/projects/${slug}`} text="View Project →" />
  <div class="project-meta">{status} &middot; {year}</div>
</article>

<style is:global>
  .project-card {
    padding: 1.8rem;
    background: var(--bg-card);
    position: relative;
    overflow: hidden;
  }

  .project-index-watermark {
    position: absolute;
    top: -0.2rem;
    right: 0.5rem;
    font-family: var(--font-display);
    font-size: 8rem;
    font-weight: 800;
    color: var(--text);
    opacity: 0.05;
    line-height: 1;
    pointer-events: none;
    z-index: 0;
  }

  .project-index {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 1.2rem;
    position: relative;
    z-index: 1;
  }

  /* Phone frame */
  .phone-frame {
    margin: 0 auto 1.2rem;
    max-width: 220px;
    background: var(--dark);
    border-radius: 20px;
    border: 3px solid #444;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .phone-notch {
    width: 80px;
    height: 6px;
    background: #444;
    border-radius: 0 0 8px 8px;
    margin: 0 auto;
  }

  .phone-status {
    display: flex;
    justify-content: space-between;
    padding: 4px 14px 2px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: #888;
  }

  .phone-icons {
    font-size: 0.5rem;
    letter-spacing: 2px;
  }

  .phone-screen {
    aspect-ratio: 9 / 16;
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .phone-screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Browser frame */
  .mockup-frame {
    margin-bottom: 1.2rem;
    position: relative;
    z-index: 1;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .mockup-chrome {
    background: var(--dark);
    padding: 6px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid #444;
  }

  .chrome-dots {
    display: flex;
    gap: 4px;
  }

  .chrome-dots span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  .chrome-url {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #888;
    flex: 1;
    text-align: center;
  }

  .project-mockup {
    aspect-ratio: 16 / 10;
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .project-mockup img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-mockup-placeholder {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #666;
  }

  .project-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
    position: relative;
    z-index: 1;
  }

  .project-hook {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--text-mid);
    line-height: 1.65;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .project-tags span {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 7px;
    border: 1px solid var(--border);
    color: var(--text-dim);
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--orange);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: letter-spacing 0.2s;
    position: relative;
    z-index: 1;
  }

  .project-link:hover {
    letter-spacing: 0.16em;
  }

  .project-meta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-top: 1rem;
    padding-top: 0.7rem;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }
</style>
