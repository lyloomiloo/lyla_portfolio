---
import GlitchText from './GlitchText.astro';
import RetroButton from './RetroButton.astro';

interface Props {
  displayTitle: string;
  hook: string;
  tags: string[];
  slug: string;
  status: string;
  year: string;
  order: number;
  thumbnail?: string;
  mockupType?: 'phone' | 'browser';
}

const { displayTitle, hook, tags, slug, status, year, order, thumbnail, mockupType = 'browser' } = Astro.props;
---

<article class="project-card" data-project-card>
  <div class="pc-layout">
    <!-- Left: text -->
    <div class="pc-text-col">
      <span class="pc-index">0{order}</span>
      <GlitchText text={displayTitle} tag="h3" class="pc-title" intensity="bold" interval={4000 + order * 500} />
      <p class="pc-hook">{hook}</p>
      <div class="pc-tags">
        {tags.map(t => <span>{t}</span>)}
      </div>
      <RetroButton href={`/projects/${slug}`} text="View Project →" />
      <div class="pc-meta">{status} &middot; {year}</div>
    </div>

    <!-- Right: mockup -->
    <div class="pc-mockup-col">
      {mockupType === 'phone' ? (
        <div class="phone-frame">
          <div class="phone-notch"></div>
          <div class="phone-status">
            <span>9:41</span>
            <span class="phone-icons">● ● ●</span>
          </div>
          <div class="phone-screen">
            {thumbnail
              ? <img src={thumbnail} alt={`${displayTitle} preview`} />
              : <span class="pc-placeholder">&gt;_ {displayTitle.toLowerCase()}</span>
            }
          </div>
        </div>
      ) : (
        <div class="browser-frame">
          <div class="browser-chrome">
            <span class="chrome-dots">
              <span style="background: var(--orange)"></span>
              <span style="background: var(--green)"></span>
              <span style="background: #666"></span>
            </span>
            <span class="chrome-url">{slug}.app</span>
          </div>
          <div class="browser-viewport">
            {thumbnail
              ? <img src={thumbnail} alt={`${displayTitle} preview`} />
              : <span class="pc-placeholder">&gt;_ {displayTitle.toLowerCase()}</span>
            }
          </div>
        </div>
      )}
    </div>
  </div>

</article>

<style is:global>
  .project-card {
    padding: 2rem;
    background: var(--bg-card);
    position: relative;
    overflow: hidden;
  }

  .pc-layout {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .pc-mockup-col {
    flex: 0 0 auto;
    position: relative;
    z-index: 1;
  }

  .pc-text-col {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .pc-index {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.8rem;
  }

  /* Phone frame */
  .phone-frame {
    width: 200px;
    background: var(--dark);
    border-radius: 22px;
    border: 3px solid #444;
    overflow: hidden;
  }

  .phone-notch {
    width: 70px;
    height: 5px;
    background: #444;
    border-radius: 0 0 8px 8px;
    margin: 0 auto;
  }

  .phone-status {
    display: flex;
    justify-content: space-between;
    padding: 3px 12px 2px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: #888;
  }

  .phone-icons {
    font-size: 0.45rem;
    letter-spacing: 2px;
  }

  .phone-screen {
    aspect-ratio: 9 / 16;
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .phone-screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Browser frame */
  .browser-frame {
    width: 320px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .browser-chrome {
    background: var(--dark);
    padding: 5px 10px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid #444;
  }

  .chrome-dots {
    display: flex;
    gap: 4px;
  }

  .chrome-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .chrome-url {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #888;
    flex: 1;
    text-align: center;
  }

  .browser-viewport {
    aspect-ratio: 16 / 10;
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .browser-viewport img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pc-placeholder {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #666;
  }

  .pc-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.03em;
    margin-bottom: 0.6rem;
    line-height: 0.95;
  }

  .pc-hook {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 300;
    color: var(--text-mid);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .pc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 1.2rem;
  }

  .pc-tags span {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 7px;
    border: 1px solid var(--border);
    color: var(--text-dim);
  }

  .pc-meta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-top: 1rem;
    padding-top: 0.7rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .pc-layout {
      flex-direction: column;
      gap: 1.5rem;
    }

    .phone-frame {
      width: 160px;
      margin: 0 auto;
    }

    .browser-frame {
      width: 100%;
    }

    .pc-title {
      font-size: clamp(1.8rem, 8vw, 3rem);
    }
  }
</style>
