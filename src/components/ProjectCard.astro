---
import GlitchText from './GlitchText.astro';
import RetroButton from './RetroButton.astro';

interface Props {
  displayTitle: string;
  hook: string;
  tags: string[];
  slug: string;
  status: string;
  order: number;
  type?: string;
}

const { displayTitle, hook, tags, slug, status, order, type } = Astro.props;
---

<article class="project-card" data-tilt>
  <span class="pc-index">0{order}</span>
  <GlitchText text={displayTitle} tag="h3" class="pc-title" intensity="bold" interval={4000 + order * 500} />
  <p class="pc-hook">{hook}</p>
  <div class="pc-tags">
    {tags.map(t => <span>{t}</span>)}
  </div>
  {type && <div class="pc-location">{type}</div>}
  <RetroButton href={`/projects/${slug}`} text="View Project →" variant="primary" />
  <div class="pc-meta">{status}</div>
</article>

<style is:global>
  .project-card {
    padding: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .pc-index {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 0.6rem;
  }

  .pc-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    line-height: 0.95;
  }

  .pc-hook {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-mid);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex: 1;
  }

  .pc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 0.5rem;
  }

  .pc-tags span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border: 1px solid var(--border);
    color: var(--text-dim);
  }

  .pc-location {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 0.8rem;
    margin-top: -0.1rem;
  }

  .pc-meta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-top: 0.8rem;
    padding-top: 0.6rem;
    border-top: 1px solid var(--border);
  }
</style>
