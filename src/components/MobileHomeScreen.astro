---
import { icons, colorMap } from '../data/pixel-icons';

// App grid config: icon key, label, panel ID
const gridApps = [
  { icon: 'image', label: 'photos', id: 'photos', bg: '#FFFFFF' },
  { icon: 'messages', label: 'messages', id: 'messages', bg: '#34C759' },
  { icon: 'weather', label: 'weather', id: 'weather', bg: '#5BC0EB' },
  { icon: 'checklist', label: 'notes', id: 'notes', bg: '#FFB84D' },
  { icon: 'music', label: 'playlist', id: 'playlist', bg: '#FF6B00' },
  { icon: 'resume', label: 'resume', id: 'resume', bg: '#888', bottom: true },
];

const dockApps = [
  { icon: 'folder', label: 'projects', id: 'projects', bg: '#FF6B00' },
  { icon: 'terminal', label: 'about', id: 'about', bg: '#1E1E1E' },
  { icon: 'gear', label: 'skills', id: 'skills', bg: '#2A5DB0' },
  { icon: 'coffee', label: 'contact', id: 'contact', bg: '#6B4226' },
];
---

<div class="phone-home" id="phoneHome">
  <!-- Status Bar -->
  <div class="phone-status-bar">
    <span class="phone-time" data-phone-clock></span>
    <div class="phone-status-icons">
      <span>&#9679;</span>
      <span>&#9650;</span>
      <span>&#9608;</span>
    </div>
  </div>

  <!-- App Grid -->
  <div class="phone-app-grid">
    {gridApps.map(app => {
      if (!app) return <div />;
      const grid = icons[app.icon] || icons['notepad'];
      return (
        <button class={`phone-app ${app.bottom ? 'phone-app--bottom' : ''}`} data-open-app={app.id}>
          <div class="phone-app-icon" style={`background:${app.bg};`}>
            <div class="phone-app-pixels">
              {grid.flat().map(c => <div style={`background:${colorMap[c]};`} />)}
            </div>
          </div>
          <span class="phone-app-label">{app.label}</span>
        </button>
      );
    })}
  </div>

  <!-- Mobile Duck -->
  <div class="duck walking mobile-duck" id="mobileDuck">
    <div class="duck-frame duck-frame-1">
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#222"></div><div style="background:#FFE066"></div><div style="background:#FF6B00"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div style="background:#FF6B00"></div><div></div><div></div><div style="background:#FF6B00"></div><div></div><div></div>
    </div>
    <div class="duck-frame duck-frame-2">
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#222"></div><div style="background:#FFE066"></div><div style="background:#FF6B00"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div></div><div style="background:#FF6B00"></div><div style="background:#FF6B00"></div><div></div><div></div><div></div>
    </div>
  </div>

  <!-- Dock -->
  <div class="phone-dock">
    {dockApps.map(app => {
      const grid = icons[app.icon] || icons['notepad'];
      return (
        <button class="phone-dock-app" data-open-app={app.id}>
          <div class="phone-dock-icon" style={`background:${app.bg};`}>
            <div class="phone-dock-pixels">
              {grid.flat().map(c => <div style={`background:${colorMap[c]};`} />)}
            </div>
          </div>
          <span class="phone-app-label">{app.label}</span>
        </button>
      );
    })}
  </div>
</div>

<style is:global>
  .phone-home {
    position: fixed;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: transparent;
  }

  /* Status Bar */
  .phone-status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 20px;
    padding-top: calc(8px + env(safe-area-inset-top, 0px));
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }
  .phone-status-icons {
    display: flex;
    gap: 6px;
    font-size: 0.5rem;
  }

  /* App Grid */
  .phone-app-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto 1fr auto;
    gap: 24px 8px;
    padding: 32px 20px;
    align-content: start;
    position: relative;
    z-index: 2;
  }
  .phone-app--bottom {
    grid-column: 4;
    grid-row: -1;
    align-self: end;
  }

  .phone-app, .phone-dock-app {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    padding: 0;
    min-height: 48px;
    -webkit-tap-highlight-color: transparent;
  }
  .phone-app:active .phone-app-icon,
  .phone-dock-app:active .phone-app-icon {
    transform: scale(0.9);
  }

  .phone-app-icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.1s ease;
  }
  .phone-app-pixels {
    display: grid;
    grid-template-columns: repeat(10, 4.5px);
    grid-template-rows: repeat(10, 4.5px);
    image-rendering: pixelated;
  }
  .phone-app-pixels div {
    width: 4.5px;
    height: 4.5px;
  }

  .phone-app-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: #fff;
    text-align: center;
    max-width: 76px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
  }

  /* Dock icon — colored rounded square with pixel art inside */
  .phone-dock-icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.1s ease;
  }
  .phone-dock-app:active .phone-dock-icon {
    transform: scale(0.9);
  }
  .phone-dock-pixels {
    display: grid;
    grid-template-columns: repeat(10, 4px);
    grid-template-rows: repeat(10, 4px);
    image-rendering: pixelated;
  }
  .phone-dock-pixels div {
    width: 4px;
    height: 4px;
  }

  /* Dock — aligned with app grid */
  .phone-dock {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    padding: 10px 20px;
    padding-bottom: calc(16px + env(safe-area-inset-bottom, 0px));
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  /* Mobile duck positioning — in the meadow, above the dock */
  .mobile-duck {
    position: absolute;
    bottom: 40%;
    left: 30%;
    z-index: 3;
    transform: scale(0.7);
  }

  /* Hide on desktop */
  @media (min-width: 769px) {
    .phone-home { display: none !important; }
  }
</style>

<script>
  // Phone clock
  function updatePhoneClock() {
    const el = document.querySelector('[data-phone-clock]');
    if (!el) return;
    const now = new Date();
    el.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }
  updatePhoneClock();
  setInterval(updatePhoneClock, 30000);
</script>
