---
import { icons, colorMap } from '../data/pixel-icons';

// App grid config: icon key, label, panel ID
const gridApps = [
  { icon: 'weather', label: 'weather', id: 'weather', bg: '#3B7DD8' },
  { icon: 'image', label: 'photos', id: 'photos', bg: '#FFFFFF' },
  { icon: 'music_m', label: 'playlist', id: 'playlist', bg: '#E85D00' },
  null,
  { icon: 'checklist', label: 'notes', id: 'notes', bg: '#333', border: true },
  { icon: 'messages', label: 'messages', id: 'messages', bg: '#30B850' },
  { icon: 'download', label: 'download', id: 'resume', bg: '#9B59B6' },
];

// Project folder contents — shown when tapping folder icon
const projectApps = [
  { icon: 'reroute_app', label: '(re)route', id: 'reroute-detail', bg: '#87CEEB' },
  { icon: 'snapp_app', label: 'snapp', id: 'snapp-detail', bg: '#E85D00' },
  { icon: 'planmytrip_app', label: 'planmytrip', id: 'planmytrip-detail', bg: '#FFFFFF' },
];

const dockApps = [
  { icon: 'face', label: 'about', id: 'about', bg: '#A8B4C0' },
  { icon: 'gear', label: 'skills', id: 'skills', bg: '#9ECAE1' },
  { icon: 'folder', label: 'projects', id: 'projects-folder', bg: '#444' },
  { icon: 'coffee', label: 'contact', id: 'contact', bg: '#F5A623' },
];
---

<div class="phone-home" id="phoneHome">
  <!-- Status Bar -->
  <div class="phone-status-bar">
    <span class="phone-time" data-phone-clock></span>
    <div class="phone-status-icons">
      <span>&#9679;</span>
      <span>&#9650;</span>
      <span>&#9608;</span>
    </div>
  </div>

  <!-- App Grid -->
  <div class="phone-app-grid">
    {gridApps.map(app => {
      if (!app) return <div />;
      const grid = icons[app.icon] || icons['notepad'];
      return (
        <button class="phone-app" data-open-app={app.id}>
          <div class="phone-app-icon" style={`background:${app.bg};${(app as any).border ? 'border:1px solid rgba(255,255,255,0.5);' : ''}`}>
            <div class="phone-app-pixels">
              {grid.flat().map(c => <div style={`background:${colorMap[c]};`} />)}
            </div>
          </div>
          <span class="phone-app-label">{app.label}</span>
        </button>
      );
    })}
  </div>

  <!-- Mobile Duck -->
  <div class="duck walking mobile-duck" id="mobileDuck">
    <div class="duck-frame duck-frame-1">
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#222"></div><div style="background:#FFE066"></div><div style="background:#FF6B00"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div style="background:#FF6B00"></div><div></div><div></div><div style="background:#FF6B00"></div><div></div><div></div>
    </div>
    <div class="duck-frame duck-frame-2">
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#222"></div><div style="background:#FFE066"></div><div style="background:#FF6B00"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div>
      <div></div><div></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div style="background:#FFE066"></div><div></div><div></div><div></div>
      <div></div><div></div><div></div><div style="background:#FF6B00"></div><div style="background:#FF6B00"></div><div></div><div></div><div></div>
    </div>
  </div>

  <!-- Dock -->
  <div class="phone-dock">
    {dockApps.map(app => {
      if (app.id === 'projects-folder') {
        return (
          <button class="phone-dock-app" data-open-app={app.id}>
            <div class="phone-dock-icon phone-folder-icon" style={`background:${app.bg};`}>
              {projectApps.map(p => {
                const pg = icons[p.icon] || icons['notepad'];
                return (
                  <div class="phone-folder-mini" style={`background:${p.bg};`}>
                    <div class="phone-folder-mini-pixels">
                      {pg.flat().map(c => <div style={`background:${colorMap[c]};`} />)}
                    </div>
                  </div>
                );
              })}
            </div>
            <span class="phone-app-label">{app.label}</span>
          </button>
        );
      }
      const grid = icons[app.icon] || icons['notepad'];
      return (
        <button class="phone-dock-app" data-open-app={app.id}>
          <div class="phone-dock-icon" style={`background:${app.bg};`}>
            <div class="phone-dock-pixels">
              {grid.flat().map(c => <div style={`background:${colorMap[c]};`} />)}
            </div>
          </div>
          <span class="phone-app-label">{app.label}</span>
        </button>
      );
    })}
  </div>

  <!-- Projects folder popup -->
  <div class="phone-folder-overlay" id="phoneFolderOverlay" style="display:none">
    <div class="phone-folder-popup">
      <div class="phone-folder-title">projects</div>
      <div class="phone-folder-grid">
        {projectApps.map(app => {
          const grid = icons[app.icon] || icons['notepad'];
          return (
            <button class="phone-app" data-open-app={app.id} data-close-folder>
              <div class="phone-app-icon" style={`background:${app.bg};`}>
                <div class="phone-app-pixels">
                  {grid.flat().map(c => <div style={`background:${colorMap[c]};`} />)}
                </div>
              </div>
              <span class="phone-app-label">{app.label}</span>
            </button>
          );
        })}
      </div>
    </div>
  </div>
</div>

<style is:global>
  .phone-home {
    position: fixed;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: transparent;
  }

  /* Status Bar */
  .phone-status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 20px;
    padding-top: calc(8px + env(safe-area-inset-top, 0px));
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }
  .phone-status-icons {
    display: flex;
    gap: 6px;
    font-size: 0.5rem;
  }

  /* App Grid */
  .phone-app-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px 8px;
    padding: 32px 20px;
    align-content: start;
    position: relative;
    z-index: 2;
  }

  .phone-app, .phone-dock-app {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    padding: 0;
    min-height: 48px;
    -webkit-tap-highlight-color: transparent;
  }
  .phone-app:active .phone-app-icon,
  .phone-dock-app:active .phone-app-icon {
    transform: scale(0.9);
  }

  .phone-app-icon {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.1s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    border: none;
  }
  .phone-app-pixels {
    width: 40px;
    height: 40px;
    display: grid;
    grid-template-columns: repeat(10, 4px);
    grid-template-rows: repeat(10, 4px);
    image-rendering: pixelated;
  }
  .phone-app-pixels div {
    width: 4px;
    height: 4px;
  }

  .phone-app-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: #fff;
    text-align: center;
    max-width: 76px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
  }

  /* Dock icon — colored rounded square with pixel art inside */
  .phone-dock-app {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .phone-dock-icon {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.1s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    border: none;
  }
  .phone-dock-app:active .phone-dock-icon {
    transform: scale(0.9);
  }
  .phone-dock-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 16px;
  }
  .phone-dock-text {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
  }
  .phone-dock-pixels {
    width: 40px;
    height: 40px;
    display: grid;
    grid-template-columns: repeat(10, 4px);
    grid-template-rows: repeat(10, 4px);
    image-rendering: pixelated;
  }
  .phone-dock-pixels div {
    width: 4px;
    height: 4px;
  }

  /* Dock — aligned with app grid */
  .phone-dock {
    display: flex;
    justify-content: center;
    gap: 24px;
    padding: 10px 20px;
    padding-bottom: calc(16px + env(safe-area-inset-bottom, 0px));
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  /* Mobile duck — smaller via cell size, not scale (avoids subpixel gaps) */
  .mobile-duck {
    position: absolute;
    bottom: 40%;
    left: 30%;
    z-index: 3;
  }
  .mobile-duck .duck-frame {
    grid-template-columns: repeat(8, 4px) !important;
    grid-template-rows: repeat(8, 4px) !important;
  }
  .mobile-duck .duck-frame div {
    width: 4px !important;
    height: 4px !important;
  }

  /* Folder icon with mini app previews */
  .phone-folder-icon {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 3px;
    padding: 6px;
    align-items: center;
    justify-items: center;
    align-content: center;
  }
  .phone-folder-mini {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .phone-folder-mini-pixels {
    display: grid;
    grid-template-columns: repeat(10, 1.6px);
    grid-template-rows: repeat(10, 1.6px);
    image-rendering: pixelated;
  }
  .phone-folder-mini-pixels div {
    width: 1.6px;
    height: 1.6px;
  }

  /* Projects folder popup */
  .phone-folder-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .phone-folder-popup {
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 16px;
    width: 100%;
    max-width: 280px;
  }
  .phone-folder-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    text-align: center;
    margin-bottom: 12px;
  }
  .phone-folder-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .phone-folder-grid .phone-app-label {
    color: var(--text);
    text-shadow: none;
  }

  /* Hide on desktop */
  @media (min-width: 769px) {
    .phone-home { display: none !important; }
  }
</style>

<script>
  // Phone clock
  function updatePhoneClock() {
    const el = document.querySelector('[data-phone-clock]');
    if (!el) return;
    const now = new Date();
    el.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }
  updatePhoneClock();
  setInterval(updatePhoneClock, 30000);

  // Projects folder — open/close
  const folderOverlay = document.getElementById('phoneFolderOverlay');
  document.querySelectorAll('[data-open-app="projects-folder"]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (folderOverlay) folderOverlay.style.display = 'flex';
    });
  });
  if (folderOverlay) {
    folderOverlay.addEventListener('click', (e) => {
      if (e.target === folderOverlay) folderOverlay.style.display = 'none';
    });
    folderOverlay.querySelectorAll('[data-close-folder]').forEach(btn => {
      btn.addEventListener('click', () => {
        folderOverlay.style.display = 'none';
      });
    });
  }
</script>
