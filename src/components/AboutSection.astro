---
---
<div class="console">
  <div class="console-bar">
    <span class="console-dots">
      <span style="background: var(--orange)"></span>
      <span style="background: var(--green)"></span>
      <span style="background: #666"></span>
    </span>
    <span class="console-title">Console — about.exe</span>
    <span class="console-x">&times;</span>
  </div>
  <div class="console-body">
    <div class="log-line">
      <span class="log-ts">00:00:01</span>
      <span class="log-tag info">INFO</span>
      <span class="log-msg">Booting lyla_huang.exe...</span>
    </div>
    <div class="log-line">
      <span class="log-ts">00:00:02</span>
      <span class="log-tag ok">OK</span>
      <span class="log-msg">Identity loaded: <span class="hl">Strategist turned builder</span></span>
    </div>
    <div class="log-line">
      <span class="log-ts">00:00:03</span>
      <span class="log-tag info">INFO</span>
      <span class="log-msg">Running career.log...</span>
    </div>

    <div class="log-line indent">
      <span class="log-ts">00:00:04</span>
      <span class="log-tag log">LOG</span>
      <span class="log-msg"><span class="log-date-inline">[2015]</span> <span class="accent">SIGNAL_START</span> — Graduated NUS. Started writing ads.</span>
    </div>
    <div class="log-line indent">
      <span class="log-ts">00:00:04</span>
      <span class="log-tag log">LOG</span>
      <span class="log-msg"><span class="log-date-inline">[2015–17]</span> <span class="accent">HAVAS_SG</span> — Grew client IG <span class="hl">4000%</span>. First awards.</span>
    </div>
    <div class="log-line indent">
      <span class="log-ts">00:00:05</span>
      <span class="log-tag log">LOG</span>
      <span class="log-msg"><span class="log-date-inline">[2018–21]</span> <span class="accent">BLKJ_SENIOR</span> — Senior Writer. Led <span class="hl">8 creatives</span>.</span>
    </div>
    <div class="log-line indent">
      <span class="log-ts">00:00:05</span>
      <span class="log-tag log">LOG</span>
      <span class="log-msg"><span class="log-date-inline">[2021–22]</span> <span class="accent">GOOGLE_APAC</span> — <span class="hl">133 SMEs</span> across APAC.</span>
    </div>
    <div class="log-line indent">
      <span class="log-ts">00:00:06</span>
      <span class="log-tag log">LOG</span>
      <span class="log-msg"><span class="log-date-inline">[2022–25]</span> <span class="accent">FREELANCE</span> — <span class="hl">20+ clients</span>. Strategy, copy, brand.</span>
    </div>
    <div class="log-line indent">
      <span class="log-ts">00:00:06</span>
      <span class="log-tag warn">WARN</span>
      <span class="log-msg"><span class="log-date-inline">[2024–25]</span> <span class="accent">ELISAVA</span> — Barcelona. Master's in Human Interaction &amp; AI.</span>
    </div>
    <div class="log-line indent">
      <span class="log-ts">00:00:07</span>
      <span class="log-tag ok">OK</span>
      <span class="log-msg"><span class="log-date-inline">[2026]</span> <span class="accent">BUILD_MODE</span> — Code. Products. AI. <span class="dim">// current</span></span>
    </div>

    <div class="log-line">
      <span class="log-ts">00:00:08</span>
      <span class="log-tag info">INFO</span>
      <span class="log-msg">Scanning /archive/...</span>
    </div>

    <div class="archive-block">
      <div class="archive-entry"><span class="dir">scoot-savage/</span> <span class="note">4x Award Winner</span></div>
      <div class="archive-entry"><span class="dir">onward/</span> <span class="note">National TVC</span></div>
      <div class="archive-entry"><span class="dir">passion-stories/</span> <span class="note">Brand Film Series</span></div>
      <div class="archive-entry"><span class="dir">fairprice-pun/</span> <span class="note">Gold Markies 2017</span></div>
      <div class="archive-entry"><span class="dir">hipsters/</span> <span class="note">Brand Film</span></div>
      <div class="archive-entry"><span class="dir">inflight/</span> <span class="note">Video Series</span></div>
    </div>

    <div class="log-line">
      <span class="log-ts">00:00:10</span>
      <span class="log-tag info">INFO</span>
      <span class="log-msg">Awards: Rising Star '18 | Gold Markies '17 | 2S+3B '18 | Grand Prize IG Cannes '16</span>
    </div>

    <div class="log-line signal-line">
      <span class="log-ts">00:00:11</span>
      <span class="log-tag warn">WARN</span>
      <span class="log-msg">Signal detected:</span>
    </div>
    <div class="signal-quote">
      "I spent a decade learning to turn noise into signal for brands. Now I design the signal itself."
    </div>

    <div class="log-line">
      <span class="log-ts">00:00:12</span>
      <span class="log-tag ok">OK</span>
      <span class="log-msg">Process complete. <span class="cursor-blink">_</span></span>
    </div>
  </div>
</div>

<style>
  .console {
    background: var(--dark);
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .console-bar {
    background: var(--dark-light);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #444;
  }

  .console-dots {
    display: flex;
    gap: 6px;
  }

  .console-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .console-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #666;
  }

  .console-x {
    font-family: var(--font-mono);
    color: #555;
    font-size: 1.1rem;
  }

  .console-body {
    padding: 2rem 2.5rem 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .log-line {
    display: flex;
    gap: 0.8rem;
    align-items: baseline;
    margin-bottom: 0.4rem;
  }

  .log-line.indent {
    padding-left: 2rem;
  }

  .log-ts {
    color: #555;
    font-size: 0.8rem;
    flex-shrink: 0;
    min-width: 8ch;
  }

  .log-tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 8px;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    min-width: 4.5ch;
    text-align: center;
  }

  .log-tag.info { background: #333; color: #aaa; }
  .log-tag.ok { background: var(--green); color: var(--dark); }
  .log-tag.warn { background: var(--orange); color: #fff; }
  .log-tag.log { background: transparent; color: #555; border: 1px solid #444; }

  .log-msg {
    color: #ccc;
    white-space: normal;
    word-break: break-word;
  }

  .log-date-inline {
    color: #888;
  }

  .hl { color: var(--green); font-weight: 600; }
  .accent { color: var(--orange); font-weight: 600; }
  .dim { color: #555; }

  .archive-block {
    padding: 0.5rem 0 0.5rem 2rem;
    margin-bottom: 0.4rem;
  }

  .archive-entry {
    margin-bottom: 0.2rem;
    color: #bbb;
  }

  .dir {
    color: var(--green);
    display: inline-block;
    min-width: 18ch;
  }

  .note { color: #888; }

  .signal-quote {
    padding: 0.8rem 2rem;
    margin-bottom: 0.6rem;
    color: var(--green);
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    font-style: italic;
    font-family: var(--font-serif);
    line-height: 1.6;
    border-left: 3px solid var(--orange);
  }

  .cursor-blink {
    color: var(--green);
    animation: blink 1s step-end infinite;
  }

  @media (max-width: 768px) {
    .console { width: 100vw; }
    .console-body { padding: 1.2rem 1.2rem 1.5rem; font-size: 0.85rem; }
    .log-line { flex-wrap: wrap; }
    .log-line.indent { padding-left: 1rem; }
    .log-ts { display: none; }
    .archive-block { padding-left: 1rem; }
    .dir { min-width: 14ch; }
  }
</style>
