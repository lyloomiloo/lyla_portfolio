---
import SignalLog from './SignalLog.astro';
import ArchivePanel from './ArchivePanel.astro';
---

<div class="about-grid reveal">
  <SignalLog />
  <ArchivePanel />
</div>

<p class="pullquote reveal">
  "I spent a decade learning to turn noise into signal for brands. Now I <span class="pullquote-highlight">design the signal itself.</span>"
</p>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .pullquote {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
    color: var(--text);
    max-width: 620px;
    margin-top: 3rem;
    line-height: 1.55;
    padding-left: 1.2rem;
    border-left: 4px solid var(--yellow);
  }

  .pullquote-highlight {
    background: linear-gradient(to top, var(--yellow) 40%, transparent 40%);
    padding: 0 2px;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      background: none;
      gap: 12px;
    }

    .about-grid > :global(*) {
      border: 1px solid var(--border);
    }
  }
</style>
