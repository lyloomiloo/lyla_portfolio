---
import SignalLog from './SignalLog.astro';
import ArchivePanel from './ArchivePanel.astro';
---

<div class="about-grid reveal">
  <SignalLog />
  <ArchivePanel />
</div>

<p class="pullquote reveal">
  "I spent a decade learning to turn noise into signal for brands. Now I design the signal itself."
</p>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .pullquote {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-style: italic;
    color: var(--text);
    max-width: 560px;
    margin-top: 3rem;
    line-height: 1.55;
    padding-left: 1.2rem;
    border-left: 2px solid var(--green);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      background: none;
      gap: 12px;
    }

    .about-grid > :global(*) {
      border: 1px solid var(--border);
    }
  }
</style>
